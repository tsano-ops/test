                var dashL = lw + 10, circleL = lw + 30, wrapW = circleL + 60, pillW = wrapW + 30;
                var btn = el.querySelector('.unsaved-save-btn');
                var dash = el.querySelector('.unsaved-save-dash');
                var circle = el.querySelector('.unsaved-save-circle');
                if (btn)    { btn.style.width = wrapW + 'px'; }
                if (dash)   { dash.style.left = dashL + 'px'; }
                if (circle) { circle.style.left = circleL + 'px'; }
                // Update ::before pill via inline style override
                var styleEl = document.getElementById('_popup_pill_style');
