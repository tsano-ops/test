            }
            // Discard button: 'Don't Save' for unsaved, 'Cancel' for delete/remove
            if (d) {
                d.textContent = context.discardLabel || (context.onDiscard ? "Don't Save" : 'Cancel');
                d.style.display = '';
            }
            el.classList.add('open');
        }
