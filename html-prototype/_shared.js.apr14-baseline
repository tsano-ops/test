        // Drag to move image — mouse + touch, 60fps rAF
        (function() {
            let dragging = false, lastX = 0, lastY = 0;
            let pendingDx = 0, pendingDy = 0, rafId = null;

            function applyMove() {
                const img = document.getElementById('sidebarPhotoImg');
                if (!img) return;
                const pos = (img.style.objectPosition || '50% 50%').split(' ');
                let curX = parseFloat(pos[0]) || 50;
                let curY = parseFloat(pos[1]) || 50;
                curX = Math.max(0, Math.min(100, curX + pendingDx));
                curY = Math.max(0, Math.min(100, curY + pendingDy));
                img.style.objectPosition = curX + '% ' + curY + '%';
                pendingDx = 0; pendingDy = 0; rafId = null;
            }

            function startDrag(x, y, e) {
                if (!repoMode) return;
                if (e.target.closest && e.target.closest('.reposition-bar')) return;
                e.preventDefault();
                dragging = true;
                lastX = x; lastY = y;
                const img = document.getElementById('sidebarPhotoImg');
                if (img) img.style.cursor = 'grabbing';
            }

            function moveDrag(x, y, e) {
                if (!dragging) return;
                e.preventDefault();
                pendingDx += (x - lastX) * -1.5;
                pendingDy += (y - lastY) * -1.5;
                lastX = x; lastY = y;
                if (!rafId) rafId = requestAnimationFrame(applyMove);
            }

            function endDrag() {
                if (!dragging) return;
                dragging = false;
                if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
                if (pendingDx || pendingDy) applyMove();
                const img = document.getElementById('sidebarPhotoImg');
                if (repoMode && img) img.style.cursor = 'grab';
            }

            function attachDragListeners() {
                const container = document.querySelector('.sidebar-photo');
                if (!container) return;
                container.addEventListener('mousedown', function(e) { startDrag(e.clientX, e.clientY, e); });
                container.addEventListener('touchstart', function(e) {
                    if (!repoMode) return;
                    if (e.target.closest && e.target.closest('.reposition-bar')) return;
                    startDrag(e.touches[0].clientX, e.touches[0].clientY, e);
                }, { passive: false });
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', attachDragListeners);
            } else {
                attachDragListeners();
            }

            document.addEventListener('mousemove', function(e) { moveDrag(e.clientX, e.clientY, e); });
            document.addEventListener('mouseup', endDrag);
            document.addEventListener('touchmove', function(e) {
                if (!dragging) return;
                moveDrag(e.touches[0].clientX, e.touches[0].clientY, e);
            }, { passive: false });
            document.addEventListener('touchend', endDrag);
        })();

