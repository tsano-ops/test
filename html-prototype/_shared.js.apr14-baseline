        /* ===== DOB Custom Dropdowns ===== */
        (function initDobDropdowns() {
            const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
            const currentYear = new Date().getFullYear();

            // State
            const dob = { year: 1980, month: 6, day: 22 }; // month = 0-based index

            function buildYearItems() {
                const drop = document.getElementById('dobYearDrop');
                if (!drop) return;
                drop.innerHTML = '';
                for (let y = currentYear + 5; y >= 1900; y--) {
                    const el = document.createElement('div');
                    el.className = 'ei-dob-item' + (y === dob.year ? ' selected' : '');
                    el.textContent = y;
                    el.onclick = function(e) { e.stopPropagation(); selectDob('year', y); };
                    drop.appendChild(el);
                }
                // Scroll to selected
                const sel = drop.querySelector('.selected');
                if (sel) sel.scrollIntoView({ block: 'center' });
            }

            function buildMonthItems() {
                const drop = document.getElementById('dobMonthDrop');
                if (!drop) return;
                drop.innerHTML = '';
                MONTHS.forEach(function(m, i) {
                    const el = document.createElement('div');
                    el.className = 'ei-dob-item' + (i === dob.month ? ' selected' : '');
                    el.textContent = m;
                    el.onclick = function(e) { e.stopPropagation(); selectDob('month', i); };
                    drop.appendChild(el);
                });
                const sel = drop.querySelector('.selected');
                if (sel) sel.scrollIntoView({ block: 'center' });
            }

            function buildDayItems() {
                const drop = document.getElementById('dobDayDrop');
                if (!drop) return;
                drop.innerHTML = '';
                const daysInMonth = new Date(dob.year, dob.month + 1, 0).getDate();
                for (let d = 1; d <= daysInMonth; d++) {
                    const el = document.createElement('div');
                    el.className = 'ei-dob-item' + (d === dob.day ? ' selected' : '');
                    el.textContent = d;
                    el.onclick = function(e) { e.stopPropagation(); selectDob('day', d); };
                    drop.appendChild(el);
                }
                const sel = drop.querySelector('.selected');
                if (sel) sel.scrollIntoView({ block: 'center' });
            }

            function selectDob(type, val) {
                dob[type] = val;
                // Update hidden inputs
                document.getElementById('eiDobYear').value = dob.year;
                document.getElementById('eiDobMonth').value = dob.month;
                document.getElementById('eiDobDay').value = dob.day;
                // Update display values
                document.getElementById('dobYearVal').textContent = dob.year;
                document.getElementById('dobMonthVal').textContent = MONTHS[dob.month];
                document.getElementById('dobDayVal').textContent = dob.day;
                // Rebuild day list if year/month changed (days in month can change)
                if (type === 'year' || type === 'month') {
                    const daysInMonth = new Date(dob.year, dob.month + 1, 0).getDate();
                    if (dob.day > daysInMonth) dob.day = daysInMonth;
                    buildDayItems();
                }
                closeAllDob();
            }

            function closeAllDob() {
                ['Year','Month','Day'].forEach(function(t) {
                    const drop = document.getElementById('dob'+t+'Drop');
                    const trig = document.getElementById('dob'+t+'Trigger');
                    if (drop) drop.classList.remove('open');
                    if (trig) trig.classList.remove('open');
                });
            }

            window.toggleDobDropdown = function(type) {
                const cap = type.charAt(0).toUpperCase() + type.slice(1);
                const drop = document.getElementById('dob'+cap+'Drop');
                const trig = document.getElementById('dob'+cap+'Trigger');
                const isOpen = drop.classList.contains('open');
                closeAllDob();
                if (!isOpen) {
                    if (type === 'year') buildYearItems();
                    else if (type === 'month') buildMonthItems();
                    else buildDayItems();
                    drop.classList.add('open');
                    trig.classList.add('open');
                }
            };

            // Close on outside click
            document.addEventListener('click', function(e) {
                if (!e.target.closest('.ei-dob-field')) closeAllDob();
            });

            // Init display
            window.addEventListener('DOMContentLoaded', function() {
                const yv = document.getElementById('dobYearVal');
                const mv = document.getElementById('dobMonthVal');
                const dv = document.getElementById('dobDayVal');
                if (yv) yv.textContent = dob.year;
                if (mv) mv.textContent = MONTHS[dob.month];
                if (dv) dv.textContent = dob.day;
            });
        })();

        function saveEssentialInfo() {
            const firstName = document.getElementById('eiFirstName').value.trim();
            const middleName = document.getElementById('eiMiddleName').value.trim();
            const familyName = document.getElementById('eiFamilyName').value.trim();
            const genderBase = document.getElementById('eiGender').value;
            const genderOther = document.getElementById('eiGenderOther') ? document.getElementById('eiGenderOther').value.trim() : '';
            const gender = (genderBase === 'Other' && genderOther) ? genderOther : genderBase;
            const dobDay = document.getElementById('eiDobDay').value;
            const dobMonth = document.getElementById('eiDobMonth').value;
            const dobYear = document.getElementById('eiDobYear').value;
            const pob = document.getElementById('eiPlaceOfBirth').value.trim();
            const citizenship = document.getElementById('eiCitizenship').value.trim();
            const residence = document.getElementById('eiResidence').value.trim();

            // Validate required
            // Clear previous errors
            document.querySelectorAll('.ei-field-input-wrap.error').forEach(el => el.classList.remove('error'));
            let hasError = false;
            if (!firstName) {
                document.getElementById('eiFirstName').closest('.ei-field-input-wrap').classList.add('error');
                hasError = true;
            }
            if (!familyName) {
                document.getElementById('eiFamilyName').closest('.ei-field-input-wrap').classList.add('error');
                hasError = true;
            }
            if (!dobDay || dobMonth === '' || !dobYear) {
                document.querySelectorAll('.ei-dob-trigger').forEach(t => t.style.borderBottomColor = '#FF0000');
                hasError = true;
            }
            if (!citizenship) {
                document.getElementById('eiCitizenship').closest('.ei-field-input-wrap').classList.add('error');
                hasError = true;
            }
            if (!residence) {
                document.getElementById('eiResidence').closest('.ei-field-input-wrap').classList.add('error');
                hasError = true;
            }
            if (hasError) return;

            // Build display values
            const months3 = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
            const monthsFull = ['January','February','March','April','May','June','July','August','September','October','November','December'];
            const mi = parseInt(dobMonth);
            const displayDOB = monthsFull[mi] + ' ' + parseInt(dobDay) + ', ' + dobYear;
            const headerDOB = months3[mi] + ' ' + parseInt(dobDay) + ', ' + dobYear;

            // Calculate age
            const today = new Date();
            const birthDate = new Date(parseInt(dobYear), mi, parseInt(dobDay));
            let age = today.getFullYear() - birthDate.getFullYear();
            const m = today.getMonth() - birthDate.getMonth();
            if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) age--;

            // Full name for display
            const fullName = [firstName, middleName, familyName].filter(Boolean).join(' ');
            const headerName = firstName + ' ' + familyName; // Header shows first + last only
            const initials = (firstName[0] || '') + (familyName[0] || '');

            // Avatar
            const editAvatar = document.getElementById('eiAvatarPreview');
            const avatarSrc = editAvatar.src;

            // ===== UPDATE READ MODE =====
            document.getElementById('eiReadName').textContent = fullName;
            document.getElementById('eiReadGender').textContent = gender || '—';
            document.getElementById('eiReadDOB').textContent = displayDOB;
            document.getElementById('eiReadPOB').textContent = pob || '—';
            document.getElementById('eiReadCitizenship').textContent = citizenship;
            document.getElementById('eiReadResidence').textContent = residence;

            // ===== SYNC TO HEADER =====
            // Name
            document.querySelectorAll('.profile-name').forEach(el => el.textContent = headerName);
            // Dropdown header name
            document.querySelectorAll('.profile-dropdown-name').forEach(el => el.textContent = headerName);
            // Identity strip (sidebar mobile)
            document.querySelectorAll('.identity-name').forEach(el => el.textContent = headerName);
            // DOB + Age in meta list
            const metaValues = document.querySelectorAll('.profile-meta-value');
            if (metaValues[0]) metaValues[0].textContent = headerDOB;
            const ageEl = document.querySelector('.profile-meta-value-sm');
            if (ageEl) ageEl.textContent = age;

            // Avatar — sync everywhere via global state
            if (avatarSrc && !avatarSrc.includes('undefined')) {
                planOwnerPhotoURL = avatarSrc;
                applyPlanOwnerPhoto();
            } else {
                planOwnerPhotoURL = null;
                // Reset all avatars to initials
                const headerImg = document.getElementById('profileAvatarImg');
                const headerInitials = document.getElementById('profileAvatarInitials');
                const readAvatar = document.getElementById('eiReadAvatar');
                if (headerImg) headerImg.style.display = 'none';
                if (headerInitials) { headerInitials.textContent = initials; headerInitials.style.display = 'flex'; }
                if (readAvatar) readAvatar.src = '';
                // Settings button avatar
                const hdrImg = document.getElementById('headerAvatarImg');
                const hdrInit = document.getElementById('headerInitials');
                if (hdrImg) hdrImg.style.display = 'none';
                if (hdrInit) { hdrInit.textContent = initials; hdrInit.style.display = ''; }
            }

            // ===== SYNC TO SIDEBAR =====
            document.querySelectorAll('.profile-sidebar-name, .identity-name').forEach(el => el.textContent = headerName);

            // Exit edit mode directly (save already happened)
            var card = document.getElementById('essentialInfoCard');
            if (card) card.classList.remove('editing');
        }

