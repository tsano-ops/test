                    toggleBtn.innerHTML = '<svg width="8" height="8" viewBox="0 0 8 8" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><line x1="0.5" y1="4" x2="7.5" y2="4"/></svg>';
