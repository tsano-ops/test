        // ========== DOC-ROW DROPDOWN TOGGLE ==========
        function toggleDD(trigger) {
            event.stopPropagation();

            // Find dd — either inside trigger or already in body (moved previously)
            let dd = trigger._dd || trigger.querySelector('.doc-dropdown');
            if (!dd) return;

            const isOpen = trigger.classList.contains('open');
            closeAllDD();

            if (!isOpen) {
                // Move to body to escape any overflow/transform parents
                trigger._dd = dd;
                dd._trigger = trigger;
                document.body.appendChild(dd);

                const rect = trigger.getBoundingClientRect();
                dd.style.top  = (rect.top) + 'px';
                dd.style.left = (rect.right - 150) + 'px';

                dd.classList.add('open');
                trigger.classList.add('open');
            }
        }

        function closeAllDD() {
            document.querySelectorAll('.doc-dropdown.open').forEach(d => {
                d.classList.remove('open');
                if (d._trigger) {
                    d._trigger.classList.remove('open');
                    // Return to original parent
                    if (d._trigger._dd === d) {
                        d._trigger.appendChild(d);
                    }
                    d._trigger = null;
                }
            });
        }

        function enterCiEdit(sectionId) {
            closeAllDD();
            // Check if another section is already open
            const currentOpen = document.querySelector('.ci-section.ci-editing');
            if (currentOpen && currentOpen.id !== sectionId) {
                const currentId = currentOpen.id;
                const saveFns = {
                    'ci-emails': saveCiEmails,
                    'ci-phones': saveCiPhones,
                    'ci-addresses': saveCiAddresses,
                    'ci-social': saveCiSocial
                };
                if (ciHasChanges(currentId)) {
                    // Unsaved changes — show popup, queue opening new section after
                    showUnsavedPopup({
                        type: 'ci', sectionId: currentId, saveFn: saveFns[currentId],
                        onAfter: function() { enterCiEdit(sectionId); }
                    });
                    return;
                } else {
                    currentOpen.classList.remove('ci-editing');
                }
            }
            var section = document.getElementById(sectionId);
            if (!section) return;
            section.classList.add('ci-editing');
            if (sectionId === 'ci-phones') initPhoneEditRows();
            // Snapshot originals synchronously so ciHasChanges is accurate immediately
            section.querySelectorAll('.ci-edit-container input, .ci-edit-container select').forEach(inp => {
                inp.dataset.original = inp.value;
            });
        }
        function exitCiEdit(sectionId) {
            // Map sectionId to save function
            const saveFns = {
                'ci-emails': saveCiEmails,
                'ci-phones': saveCiPhones,
                'ci-addresses': saveCiAddresses,
                'ci-social': saveCiSocial
            };
            exitCiEditSafe(sectionId, saveFns[sectionId]);
