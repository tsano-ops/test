        function eiHasChanges() {
            const card = document.getElementById('essentialInfoCard');
            if (!card) return false;
            const inputs = card.querySelectorAll('.ei-edit-mode input, .ei-edit-mode select, .ei-edit-mode textarea');
            let changed = false;
            inputs.forEach(inp => {
                const orig = inp.dataset.original !== undefined ? inp.dataset.original : '';
                if (inp.value !== orig) changed = true;
            });
            return changed;
        }

        function ciHasChanges(sectionId) {
            const section = document.getElementById(sectionId);
            if (!section) return false;
            // Exclude inline add panels (they start empty, not "changes")
            const inputs = section.querySelectorAll(
                '.ci-edit-container input:not(.ci-inline-add-block input):not(.social-add-block input), ' +
                '.ci-edit-container select:not(.ci-inline-add-block select):not(.social-add-block select)'
            );
            let changed = false;
            inputs.forEach(inp => {
                const orig = inp.dataset.original !== undefined ? inp.dataset.original : '';
                if (inp.value !== orig) changed = true;
            });
            // Inline panel with filled fields = unsaved change
            section.querySelectorAll('.ci-inline-add-block input, .social-add-block input').forEach(inp => {
                if (inp.value && inp.value.trim() !== '') changed = true;
            });
            return changed;
        }

