        // ========== AI RESIZE (both dashboard & col4) ==========
        (function() {
            let isDragging = false, startY, startH, targetCard;
            function getResizeTarget(e) {
                const el = e.target.closest('.ai-resize');
                if (!el) return null;
                return el.closest('.ai-card-col4') || el.closest('.ai-card');
            }
            document.addEventListener('mousedown', (e) => {
                targetCard = getResizeTarget(e);
                if (!targetCard) return;
                isDragging = true; startY = e.clientY; startH = targetCard.offsetHeight;
                document.body.style.cursor = 'ns-resize'; document.body.style.userSelect = 'none';
                e.preventDefault();
            });
            document.addEventListener('mousemove', (e) => {
                if (!isDragging || !targetCard) return;
                const max = targetCard.classList.contains('ai-card-col4') ? window.innerHeight * 0.8 : window.innerHeight * 0.85;
                const min = targetCard.classList.contains('ai-card-col4') ? 300 : 200;
                const newH = Math.max(min, Math.min(max, startH + (e.clientY - startY)));
                targetCard.style.height = newH + 'px'; targetCard.style.maxHeight = newH + 'px';
                targetCard.style.maxHeight = newH + 'px';
                adaptSphereToHeight(targetCard, newH);
                // Let chat expand: remove max-height constraint
                var chat = targetCard.querySelector('.ai-chat');
                if (chat) chat.style.maxHeight = 'none';
            });
            document.addEventListener('mouseup', () => {
                if (!isDragging) return;
                isDragging = false; targetCard = null;
                document.body.style.cursor = ''; document.body.style.userSelect = '';
            });
            document.addEventListener('touchstart', (e) => {
                targetCard = getResizeTarget(e);
                if (!targetCard) return;
                isDragging = true; startY = e.touches[0].clientY; startH = targetCard.offsetHeight;
                e.preventDefault();
            }, { passive: false });
            document.addEventListener('touchmove', (e) => {
                if (!isDragging || !targetCard) return;
                const max = targetCard.classList.contains('ai-card-col4') ? window.innerHeight * 0.8 : window.innerHeight * 0.85;
                const min = targetCard.classList.contains('ai-card-col4') ? 300 : 200;
                const newH = Math.max(min, Math.min(max, startH + (e.touches[0].clientY - startY)));
                targetCard.style.height = newH + 'px';
                targetCard.style.maxHeight = newH + 'px';
                adaptSphereToHeight(targetCard, newH);
                var chat = targetCard.querySelector('.ai-chat');
                if (chat) chat.style.maxHeight = 'none';
            });
            function adaptSphereToHeight(card, h) {
                var bg = card.querySelector('.ai-bg');
                if (!bg) return;
                var isCol4 = card.classList.contains('ai-card-col4');
                var baseH = isCol4 ? 400 : 270;
                var baseSize = isCol4 ? 160 : 220;
                var scale = Math.max(1, Math.min(1.5, h / baseH));
                var newSize = Math.round(baseSize * scale);
                bg.style.setProperty('--sphere-w', newSize + 'px');
                bg.style.setProperty('--sphere-h', newSize + 'px');
            }
            document.addEventListener('touchend', () => { isDragging = false; targetCard = null; });
        })();

