        // ========== DOC-ROW DROPDOWN TOGGLE ==========
        function toggleDD(trigger) {
            event.stopPropagation();

            // Find dd — either inside trigger or already in body (moved previously)
            let dd = trigger._dd || trigger.querySelector('.doc-dropdown');
            if (!dd) return;

            const isOpen = trigger.classList.contains('open');
            closeAllDD();

            if (!isOpen) {
                // Move to body to escape any overflow/transform parents
                trigger._dd = dd;
                dd._trigger = trigger;
                document.body.appendChild(dd);

                const rect = trigger.getBoundingClientRect();
                dd.style.top  = (rect.top) + 'px';
                dd.style.left = (rect.right - 150) + 'px';

                dd.classList.add('open');
                trigger.classList.add('open');
            }
        }

        function closeAllDD() {
            document.querySelectorAll('.doc-dropdown.open').forEach(d => {
                d.classList.remove('open');
                if (d._trigger) {
                    d._trigger.classList.remove('open');
                    // Return to original parent
                    if (d._trigger._dd === d) {
                        d._trigger.appendChild(d);
                    }
                    d._trigger = null;
                }
            });
        }

        function enterCiEdit(sectionId) {
            closeAllDD();
            // Check if another section is already open
            const currentOpen = document.querySelector('.ci-section.ci-editing');
            if (currentOpen && currentOpen.id !== sectionId) {
                const currentId = currentOpen.id;
                const saveFns = {
                    'ci-emails': saveCiEmails,
                    'ci-phones': saveCiPhones,
                    'ci-addresses': saveCiAddresses,
                    'ci-social': saveCiSocial
                };
                if (ciHasChanges(currentId)) {
                    // Unsaved changes — show popup, queue opening new section after
                    showUnsavedPopup({
                        type: 'ci', sectionId: currentId, saveFn: saveFns[currentId],
                        onAfter: function() { enterCiEdit(sectionId); }
                    });
                    return;
                } else {
                    currentOpen.classList.remove('ci-editing');
                }
            }
            var section = document.getElementById(sectionId);
            if (!section) return;
            // Close any open inline add-block (Edit + Add New are mutually exclusive)
            const addZone = document.getElementById(sectionId + '-add-zone');
            if (addZone) {
                const openBlock = addZone.querySelector('.ci-inline-add-block');
                if (openBlock) { if (openBlock._label) openBlock._label.remove(); openBlock.remove(); }
            }
            section.classList.add('ci-editing');
            if (sectionId === 'ci-phones') initPhoneEditRows();
            if (sectionId === 'ci-addresses') initAddressEditRows();
            // Snapshot originals synchronously so ciHasChanges is accurate immediately
            section.querySelectorAll('.ci-edit-container input, .ci-edit-container select').forEach(inp => {
                inp.dataset.original = inp.value;
            });
        }
        function exitCiEdit(sectionId) {
            // Map sectionId to save function
            const saveFns = {
                'ci-emails': saveCiEmails,
                'ci-phones': saveCiPhones,
                'ci-addresses': saveCiAddresses,
                'ci-social': saveCiSocial
            };
            exitCiEditSafe(sectionId, saveFns[sectionId]);
        }

        function saveCiEmails() {
            const section = document.getElementById('ci-emails');
            // Validate all email inputs
            const inputs = section.querySelectorAll('.ci-edit-input-wrap input[type="email"]');
            let valid = true;
            inputs.forEach(inp => {
                const wrap = inp.closest('.ci-edit-input-wrap');
                const val = inp.value.trim();
                const isValid = val === '' || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
                wrap.classList.toggle('error', !isValid);
                if (!isValid) valid = false;
            });
            if (!valid) return;

            // Sync primary card
            const primaryInput = section.querySelector('.ci-edit-primary-box input');
            const primaryCard = section.querySelector('.ci-primary-card .data-value');
            if (primaryCard && primaryInput) primaryCard.textContent = primaryInput.value.trim();

            // Sync extra group
            const extraGroup = section.querySelector('.ci-extra-group');
            const additionalInputs = section.querySelectorAll('.ci-edit-extra-box .ci-edit-field-row input');
            if (extraGroup) {
                // Remove old data-value entries (keep data-label)
                extraGroup.querySelectorAll('.data-value').forEach(el => el.remove());
                const label = extraGroup.querySelector('.data-label');
                let hasValues = false;
                additionalInputs.forEach(inp => {
                    const val = inp.value.trim();
                    if (val) {
                        hasValues = true;
                        const div = document.createElement('div');
                        div.className = 'data-value';
                        div.textContent = val;
                        extraGroup.insertBefore(div, label);
                    }
                });
                if (!hasValues) extraGroup.remove();
            }

            section.classList.remove('ci-editing');
        }

        function saveCiSection(sectionId, validateFn) {
            const section = document.getElementById(sectionId);
            const inputs = section.querySelectorAll('.ci-edit-container input');
            let valid = true;
            inputs.forEach(inp => {
                const wrap = inp.closest('.ci-edit-input-wrap');
                const val = inp.value.trim();
                const ok = validateFn ? validateFn(inp, val) : true;
                wrap.classList.toggle('error', !ok);
                if (!ok) valid = false;
            });
            if (!valid) return;
            const primaryInput = section.querySelector('.ci-edit-container .ci-edit-primary input, .ci-edit-primary-box input');
            const primaryCard = section.querySelector('.ci-primary-card .data-value');
            if (primaryCard && primaryInput) primaryCard.textContent = primaryInput.value.trim();
            const extraGroup = section.querySelector('.ci-extra-group');
            if (extraGroup) {
                const additionalInputs = section.querySelectorAll('.ci-edit-extra-box .ci-edit-field-row input, .ci-edit-container .ci-edit-field-row input');
                extraGroup.querySelectorAll('.data-value').forEach(el => el.remove());
                const label = extraGroup.querySelector('.data-label');
                let hasValues = false;
                additionalInputs.forEach(inp => {
                    const val = inp.value.trim();
                    if (val) {
                        hasValues = true;
                        const div = document.createElement('div');
                        div.className = 'data-value';
                        div.textContent = val;
                        extraGroup.insertBefore(div, label);
                    }
                });
                if (!hasValues) extraGroup.remove();
            }
            section.classList.remove('ci-editing');
        }
        // ── PHONE PICKER HELPERS ──────────────────────────────────────────────
        // Emoji → flag SVG file map (keep emoji in data for backward compat,
        // but render <img> in the UI per XD spec).
        const FLAG_FILE = {
            '🇺🇸': 'US.svg', '🇨🇦': 'CA.svg', '🇬🇧': 'GB.svg', '🇩🇪': 'DE.svg',
            '🇫🇷': 'FR.svg', '🇧🇬': 'BG.svg', '🇦🇺': 'AU.svg', '🇯🇵': 'JP.svg',
            '🇮🇳': 'IN.svg', '🇨🇳': 'CN.svg',
        };
        function flagImgHTML(emoji) {
            const file = FLAG_FILE[emoji] || 'US.svg';
            return `<img class="ci-phone-flag" src="img/${file}" alt="" width="30" height="20">`;
        }
        const TRASH_IMG_HTML = `<img src="img/trash.png" srcset="img/trash.png 1x, img/trash@2x.png 2x" alt="" width="18" height="20">`;

        // buildPhoneRow → returns a wrapper element containing:
        //   - the 2-field row (country code trigger + phone number input + trash)
        //   - primary checkbox row (checkbox + "Primary Phone Number" label)
        //   - info text (PRIMARY ROW ONLY: "This phone number is used to protect…")
        // Wrapper class: ci-phone-wrapper (+ optional data-extra for additional).
        function buildPhoneRow(flag, code, number, withTrash, isPrimary) {
            const items = CI_COUNTRIES.map(c =>
                `<div class="ci-phone-country-item" onclick="ciPhonePickerSelect(this,'${c.flag}','${c.code}')">
                    <span class="ci-flag">${c.flag}</span>
                    <span class="ci-phone-item-code">${c.code}</span>
                    <span class="ci-phone-item-name">${c.name}</span>
                </div>`).join('');
            const trashHtml = withTrash
                ? `<div class="ci-edit-trash" onclick="deleteCiField(this,'phone')">${TRASH_IMG_HTML}</div>`
                : '';
            const infoText = isPrimary
                ? `<div class="ci-primary-info-text">This phone number is used to protect your account and verify your identity when necessary.</div>`
                : '';
            const wrapper = document.createElement('div');
            wrapper.className = 'ci-phone-wrapper';
            wrapper.innerHTML = `
                <div class="ci-edit-field-row ci-phone-row">
                    <div class="ci-edit-field ci-phone-code-field">
                        <div class="ci-edit-input-wrap ci-phone-trigger" onclick="togglePhoneTrigger(this,event)">
                            ${flagImgHTML(flag)}
                            <span class="ci-phone-flag-emoji" data-emoji="${flag}" style="display:none">${flag}</span>
                            <span class="ci-phone-code-display">${code}</span>
                            <span class="ci-phone-chev"></span>
                            <div class="ci-phone-country-dd">${items}</div>
                        </div>
                        <div class="ci-edit-label">Country Code</div>
                    </div>
                    <div class="ci-edit-field" style="flex:1">
                        <div class="ci-edit-input-wrap">
                            <input type="tel" class="ci-phone-number-inp" value="${number}" placeholder="Phone" oninput="this.closest('.ci-edit-input-wrap').classList.remove('error')">
                            ${trashHtml}
                        </div>
                        <div class="ci-edit-label">Phone Number</div>
                    </div>
                </div>
                <div class="ci-primary-checkbox-row">
                    <div class="ci-primary-checkbox${isPrimary ? ' checked' : ''}" onclick="togglePhonePrimary(this)"></div>
                    <span class="ci-primary-checkbox-label" onclick="togglePhonePrimary(this.previousElementSibling)">Primary Phone Number</span>
                </div>
                ${infoText}`;
            // Outside-click closes the dropdown
            const dd = wrapper.querySelector('.ci-phone-country-dd');
            const trig = wrapper.querySelector('.ci-phone-trigger');
            document.addEventListener('click', function closeDD(e) {
                if (!trig.contains(e.target)) {
                    dd.classList.remove('open');
                    trig.classList.remove('open');
                    document.removeEventListener('click', closeDD);
                }
            });
            return wrapper;
        }

        // Dropdown + chevron toggle — stops propagation from child clicks
        function togglePhoneTrigger(trig, ev) {
            if (ev && ev.target.closest('.ci-phone-country-dd')) return; // click inside DD
            trig.classList.toggle('open');
            trig.querySelector('.ci-phone-country-dd').classList.toggle('open');
        }
        window.togglePhoneTrigger = togglePhoneTrigger;

        // Primary checkbox: only one per section can be checked (exclusive).
        function togglePhonePrimary(checkbox) {
            const section = checkbox.closest('.ci-section');
            if (!section) return;
            section.querySelectorAll('.ci-primary-checkbox').forEach(cb => cb.classList.remove('checked'));
            checkbox.classList.add('checked');
        }
        window.togglePhonePrimary = togglePhonePrimary;

        function ciPhonePickerSelect(el, flag, code) { ciPhoneSelectCountry(el, flag, code); }

        function getPhoneRowValue(row) {
            const code = row.querySelector('.ci-phone-code-display').textContent.trim();
            const num  = row.querySelector('.ci-phone-number-inp').value.trim();
            return num ? code + ' ' + num : '';
        }

        function saveCiPhones() {
            const section = document.getElementById('ci-phones');
            const container = document.getElementById('ci-phones-edit-container');
            // Validate all phone number inputs across all wrappers
            const wrappers = container.querySelectorAll('.ci-phone-wrapper');
            let valid = true;
            wrappers.forEach(w => {
                const inp = w.querySelector('.ci-phone-number-inp');
                const val = inp.value.trim();
                const wrap = inp.closest('.ci-edit-input-wrap');
                const ok = val === '' || /^[\d\s\(\)\-\.]{4,}$/.test(val);
                wrap.classList.toggle('error', !ok);
                if (!ok) valid = false;
            });
            if (!valid) return;
            // Determine which wrapper has the checked primary checkbox
            let primaryWrapper = null;
            wrappers.forEach(w => {
                if (w.querySelector('.ci-primary-checkbox.checked')) primaryWrapper = w;
            });
            if (!primaryWrapper) primaryWrapper = wrappers[0]; // fallback
            // Collect values
            const allRows = [];
            wrappers.forEach(w => {
                const val = getPhoneRowValue(w);
                if (val) allRows.push({ value: val, isPrimary: w === primaryWrapper });
            });
            // Sync primary card
            const primaryCard = section.querySelector('.ci-primary-card .data-value');
            const primaryEntry = allRows.find(r => r.isPrimary);
            if (primaryCard && primaryEntry) primaryCard.textContent = primaryEntry.value;
            // Sync extra group
            const extras = allRows.filter(r => !r.isPrimary);
            let extraGroup = section.querySelector('.ci-extra-group');
            if (extras.length > 0) {
                if (!extraGroup) {
                    extraGroup = document.createElement('div');
                    extraGroup.className = 'ci-extra-group';
                    section.insertBefore(extraGroup, document.getElementById('ci-phones-add-zone'));
                    const lbl = document.createElement('div');
                    lbl.className = 'data-label';
                    lbl.textContent = 'Additional Phone Number(s)';
                    extraGroup.appendChild(lbl);
                }
                extraGroup.querySelectorAll('.data-value').forEach(el => el.remove());
                const lbl = extraGroup.querySelector('.data-label');
                extras.forEach(r => {
                    const div = document.createElement('div');
                    div.className = 'data-value';
                    div.textContent = r.value;
                    extraGroup.insertBefore(div, lbl);
                });
            } else if (extraGroup) {
                extraGroup.remove();
            }
            section.classList.remove('ci-editing');
        }

        function addPhoneField(btn) {
            const wrapper = buildPhoneRow('🇺🇸', '+1', '', true, false);
            wrapper.dataset.extra = '1';
            const container = btn.closest('.ci-edit-container');
            // Find or create extra-box
            let extraBox = container.querySelector('.ci-edit-extra-box');
            if (!extraBox) {
                extraBox = document.createElement('div');
                extraBox.className = 'ci-edit-extra-box';
                container.insertBefore(extraBox, btn);
            }
            extraBox.appendChild(wrapper);
            const cap = document.createElement('div');
            cap.className = 'ci-phone-section-caption';
            cap.textContent = 'Additional Phone Number';
            extraBox.appendChild(cap);
            wrapper.querySelector('.ci-phone-number-inp').focus();
        }
        // Rebuild extra address edit rows from view-mode .ci-primary-card entries.
         // Called on enterCiEdit('ci-addresses') — mirrors initPhoneEditRows.
        function initAddressEditRows() {
            const section = document.getElementById('ci-addresses');
            const extraBox = document.getElementById('ci-addr-extra-box');
            if (!section || !extraBox) return;
            // Clear previous extras
            extraBox.innerHTML = '';
            // Find additional cards in view (not is-primary) — they need edit rows
            const extraCards = section.querySelectorAll('.ci-primary-card:not(.is-primary) .data-value');
            extraCards.forEach(valEl => {
                const parts = valEl.innerHTML.split(/<br\s*\/?>/i).map(s => s.trim());
                const street = parts[0] || '';
                const city = parts[1] || '';
                const zip = parts[2] || '';
                const country = parts[3] || '';
                const COUNTRY_OPTS = ['United Kingdom','United States','Bulgaria','Germany','France','Australia','Canada','Japan','India','Other']
                    .map(c => `<option value="${c}"${c === country ? ' selected' : ''}>${c}</option>`).join('');
                // Each additional address gets its own secondary pad
                // (opacity 0.3 — less saturated than primary's 0.5 to keep
                //  primary visually dominant).
                const pad = document.createElement('div');
                pad.className = 'ci-edit-secondary-box';
                const group = document.createElement('div');
                group.className = 'ci-edit-addr-group ci-edit-extra-addr ci-addr-wrapper';
                group.innerHTML = `
                    <div class="ci-edit-field-row">
                        <div class="ci-edit-field">
                            <div class="ci-edit-input-wrap">
                                <input type="text" class="ci-addr-street" value="${street.replace(/"/g,'&quot;')}" placeholder="Street">
                                <div class="ci-edit-trash" onclick="deleteCiField(this,'address')">
                                    <img src="img/trash.png" srcset="img/trash.png 1x, img/trash@2x.png 2x" alt="" width="18" height="20">
                                </div>
                            </div>
                            <div class="ci-edit-label">Address</div>
                        </div>
                    </div>
                    <div class="ci-edit-field-row">
                        <div class="ci-edit-field">
                            <div class="ci-edit-input-wrap"><input type="text" class="ci-addr-city" value="${city.replace(/"/g,'&quot;')}" placeholder="City / Town"></div>
                            <div class="ci-edit-label">City / Town</div>
                        </div>
                        <div class="ci-edit-field ci-zip-field">
                            <div class="ci-edit-input-wrap"><input type="text" class="ci-addr-zip" value="${zip.replace(/"/g,'&quot;')}" placeholder="ZIP / Post Code"></div>
                            <div class="ci-edit-label">ZIP / Post Code</div>
                        </div>
                    </div>
                    <div class="ci-edit-field-row">
                        <div class="ci-edit-field">
                            <div class="ci-edit-input-wrap">
                                <select class="ci-addr-country"><option value="" disabled>Select Country</option>${COUNTRY_OPTS}</select>
                                <span class="ci-addr-chev"></span>
                            </div>
                            <div class="ci-edit-label">Country</div>
                        </div>
                    </div>
                    <div class="ci-primary-checkbox-row">
                        <div class="ci-primary-checkbox" onclick="togglePhonePrimary(this)"></div>
                        <span class="ci-primary-checkbox-label" onclick="togglePhonePrimary(this.previousElementSibling)">Primary Address</span>
                    </div>`;
                pad.appendChild(group);
                extraBox.appendChild(pad);
                const cap = document.createElement('div');
                cap.className = 'ci-addr-section-caption';
                cap.textContent = 'Additional Address';
                extraBox.appendChild(cap);
            });
        }

        function addCiAddrField(btn) {
            const box = document.getElementById('ci-addr-extra-box');
            const COUNTRY_OPTS = ['United Kingdom','United States','Bulgaria','Germany','France','Australia','Canada','Japan','India','Other']
                .map(c=>`<option value="${c}">${c}</option>`).join('');
            const group = document.createElement('div');
            group.className = 'ci-edit-addr-group ci-edit-extra-addr ci-addr-wrapper';
            group.innerHTML = `
                <div class="ci-edit-field-row">
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap">
                            <input type="text" class="ci-addr-street" placeholder="Street">
                            <div class="ci-edit-trash" onclick="deleteCiField(this,'address')">
                                <img src="img/trash.png" srcset="img/trash.png 1x, img/trash@2x.png 2x" alt="" width="18" height="20">
                            </div>
                        </div>
                        <div class="ci-edit-label">Address</div>
                    </div>
                </div>
                <div class="ci-edit-field-row">
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap"><input type="text" class="ci-addr-city" placeholder="City / Town"></div>
                        <div class="ci-edit-label">City / Town</div>
                    </div>
                    <div class="ci-edit-field ci-zip-field">
                        <div class="ci-edit-input-wrap"><input type="text" class="ci-addr-zip" placeholder="ZIP / Post Code"></div>
                        <div class="ci-edit-label">ZIP / Post Code</div>
                    </div>
                </div>
                <div class="ci-edit-field-row">
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap">
                            <select class="ci-addr-country"><option value="" disabled selected>Select Country</option>${COUNTRY_OPTS}</select>
                            <span class="ci-addr-chev"></span>
                        </div>
                        <div class="ci-edit-label">Country</div>
                    </div>
                </div>
                <div class="ci-primary-checkbox-row">
                    <div class="ci-primary-checkbox" onclick="togglePhonePrimary(this)"></div>
                    <span class="ci-primary-checkbox-label" onclick="togglePhonePrimary(this.previousElementSibling)">Primary Address</span>
                </div>`;
            box.appendChild(group);
            // Add "Additional Address" caption after the wrapper
            const cap = document.createElement('div');
            cap.className = 'ci-addr-section-caption';
            cap.textContent = 'Additional Address';
            box.appendChild(cap);
            group.querySelector('input').focus();
        }

        function saveCiAddresses() {
            const section = document.getElementById('ci-addresses');
            // Gather all address wrappers (primary + additionals)
            const wrappers = section.querySelectorAll('.ci-edit-container .ci-addr-wrapper');
            // Determine which is marked primary via new checkbox
            let primaryWrapper = null;
            wrappers.forEach(w => {
                if (w.querySelector('.ci-primary-checkbox.checked')) primaryWrapper = w;
            });
            if (!primaryWrapper) primaryWrapper = wrappers[0];
            // Extract values per wrapper
            const collect = (w) => {
                const street = (w.querySelector('.ci-addr-street, input[placeholder="Street"]') || {}).value?.trim() || '';
                const city   = (w.querySelector('.ci-addr-city, input[placeholder="City / Town"]') || {}).value?.trim() || '';
                const zip    = (w.querySelector('.ci-addr-zip, input[placeholder="ZIP / Post Code"]') || {}).value?.trim() || '';
                const sel    = w.querySelector('select');
                const country = sel ? sel.value : '';
                return { street, city, zip, country, parts: [street, city, zip, country].filter(Boolean) };
            };
            // Rebuild primary card
            const primaryCard = section.querySelector('.ci-primary-card.is-primary');
            const p = collect(primaryWrapper);
            if (primaryCard && p.parts.length) {
                primaryCard.querySelector('.data-value').innerHTML = p.parts.join('<br>');
            }
            // Clear existing additional cards
            const zone = document.getElementById('ci-addresses-add-zone');
            section.querySelectorAll('.ci-primary-card:not(.is-primary)').forEach(c => c.remove());
            // Add additionals from other wrappers
            wrappers.forEach(w => {
                if (w === primaryWrapper) return;
                const d = collect(w);
                if (!d.street && !d.city) return;
                const newCard = document.createElement('div');
                newCard.className = 'ci-primary-card';
                newCard.innerHTML = `<div class="data-value">${d.parts.join('<br>')}</div><div class="data-label">Additional Address</div>`;
                section.insertBefore(newCard, zone);
            });
            section.classList.remove('ci-editing');
        }

        function ciSocialAutoUrl(sel) {
            const row = sel.closest('.ci-edit-field-row');
            const nextRow = row.nextElementSibling;
            if (!nextRow) return;
            const urlInp = nextRow.querySelector('.ci-social-url-inp');
            const handleInp = row.querySelector('.ci-social-handle-inp');
            if (!urlInp || !handleInp) return;
            const handle = handleInp.value.trim();
            const bases = {
                'Facebook':'https://www.facebook.com/',
                'Instagram':'https://www.instagram.com/',
                'Linkedin':'https://www.linkedin.com/in/',
                'X (Twitter)':'https://x.com/',
                'TikTok':'https://www.tiktok.com/@',
                'Other':''
            };
            if (handle && bases[sel.value] !== undefined) urlInp.value = bases[sel.value] + handle;
        }

        function ciDeleteSocial(btn) {
            const fieldRow = btn.closest('.ci-edit-field-row');
            const urlRow = fieldRow.nextElementSibling;
            showSystemPopup({
                title: 'Delete Social Media Profile?',
                body: 'Are you sure you want to delete this social media profile? This action cannot be undone.',
                discardLabel: 'Cancel',
                actionLabel: 'Delete',
                onAction: function() {
                    if (urlRow && urlRow.querySelector('.ci-social-url-inp')) urlRow.remove();
                    fieldRow.remove();
                }
            });
        }


        // ── Inline Add Block helpers ──────────────────────────────────────────
        // All markup uses ONLY CSS classes — zero typography/spacing inline styles.
        // Fields follow the locked standard:
        //   .ci-edit-field-row  → padding:10px 100px 0 100px, gap:20px
        //   .ci-edit-field      → (row child) padding:0, flex:1
        //   .ci-edit-input-wrap → h:40px, border-bottom 1px rgba(0,0,0,0.14)
        //   input/select        → font:600 16px/24px Inter, color:#000, padding-left:20px
        //   placeholder         → font:400 16px/24px Inter, color:rgba(0,0,0,0.28)
        //   .ci-edit-label      → font:400 12px/15px Inter, opacity:0.5, padding-left:20px, mt:4px
        //   .ci-inline-add-block → inherits padding from ci-edit-container context (100px L/R)
        //   Save btn             → .ei-save-btn-wrap (existing class, locked)
        //   Add link             → .ci-add-btn (existing class, locked)

        function closeInlineBlock(btn) {
            var b = btn; while(b && !b.classList.contains('ci-inline-add-block')) b = b.parentElement;
            if(b) { if(b._label) b._label.remove(); b.remove(); }
        }
        function closeSocialBlock(btn) {
            var b = btn; while(b && !b.classList.contains('social-add-block')) b = b.parentElement;
            if(b) { if(b._label) b._label.remove(); b.remove(); }
        }

        document.addEventListener('click', function(e) {
            const inlineClose = e.target.closest('.ci-inline-add-close');
            if (inlineClose) { e.stopPropagation(); closeInlineBlock(inlineClose); return; }
            const socialClose = e.target.closest('.social-add-block-close');
            if (socialClose) { e.stopPropagation(); closeSocialBlock(socialClose); return; }
        });

        const CANCEL_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 21.5 21.5" style="pointer-events:none;display:block"><g transform="translate(-18824.645 -2141.644)"><circle cx="10" cy="10" r="10" transform="translate(18825.395 2142.394)" fill="none" stroke="#000" stroke-width="1.5"/><line x2="9.868" transform="translate(18831.906 2148.905) rotate(45)" fill="none" stroke="#000" stroke-linecap="round" stroke-width="1.5"/><line y2="9.868" transform="translate(18838.883 2148.906) rotate(45)" fill="none" stroke="#000" stroke-linecap="round" stroke-width="1.5"/></g></svg>`;
        const INLINE_CLOSE_BTN = `<button class="ci-inline-add-close">${CANCEL_SVG}</button>`;

        function inlineSaveBtn(fn) {
            return `<div class="ei-save-btn-wrap ci-inline-save" onclick="${fn}(this)" ontouchstart="this.classList.add('touching')" ontouchend="setTimeout(()=>this.classList.remove('touching'),300)"><span class="ei-save-btn-label">Save</span><span class="ei-save-btn-dash"></span><span class="ei-save-btn-circle"><svg class="ei-save-btn-arrow" width="9" height="16" viewBox="0 0 9 16" fill="none" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 1l7 7-7 7"/></svg></span></div>`;
        }

        // ── ADD E-MAIL ────────────────────────────────────────────────────────
        function ciAddEmailInline() {
            const zone = document.getElementById('ci-emails-add-zone');
            if (!zone) return;
            // Mutual exclusion: close edit mode when opening Add New
            const section = document.getElementById('ci-emails');
            if (section && section.classList.contains('ci-editing')) {
                section.classList.remove('ci-editing');
            }
            zone.innerHTML = '';
            const block = document.createElement('div');
            block.className = 'ci-inline-add-block';
            block.innerHTML = `${INLINE_CLOSE_BTN}
                <div class="ci-edit-field-row">
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap">
                            <input type="email" class="ci-new-email-inp" placeholder="E-mail">
                        </div>
                        <div class="ci-edit-label">Additional E-mail</div>
                    </div>
                </div>
                ${inlineSaveBtn('ciSaveInlineEmail')}`;
            zone.appendChild(block);
            const lbl = document.createElement('div');
            lbl.style.cssText = 'padding-left:20px;margin-top:4px;font:400 12px/15px Inter,sans-serif;color:rgba(0,0,0,0.5);';
            lbl.textContent = 'Add New E-mail';
            block._label = lbl;
            zone.appendChild(lbl);
            block.querySelector('.ci-new-email-inp').focus();
        }

        function ciSaveInlineEmail(btn) {
            const block = btn.closest('.ci-inline-add-block');
            if(block && block._label) block._label.remove();
            const inp = block.querySelector('.ci-new-email-inp');
            const val = inp.value.trim();
            if (!val) { block.remove(); return; }
            const section = document.getElementById('ci-emails');
            let extra = section.querySelector('.ci-extra-group');
            if (!extra) {
                extra = document.createElement('div');
                extra.className = 'ci-extra-group';
                section.insertBefore(extra, document.getElementById('ci-emails-add-zone'));
                const lbl = document.createElement('div');
                lbl.className = 'data-label';
                lbl.textContent = 'Additional E-mail(s)';
                extra.appendChild(lbl);
            }
            const newLine = document.createElement('div');
            newLine.className = 'data-value';
            newLine.textContent = val;
            extra.insertBefore(newLine, extra.querySelector('.data-label'));
            block.remove();
        }

        // ── ADD PHONE ─────────────────────────────────────────────────────────
        const CI_COUNTRIES = [
            {flag:'🇺🇸',code:'+1',name:'United States'},
            {flag:'🇨🇦',code:'+1',name:'Canada'},
            {flag:'🇬🇧',code:'+44',name:'United Kingdom'},
            {flag:'🇩🇪',code:'+49',name:'Germany'},
            {flag:'🇫🇷',code:'+33',name:'France'},
            {flag:'🇧🇬',code:'+359',name:'Bulgaria'},
            {flag:'🇦🇺',code:'+61',name:'Australia'},
            {flag:'🇯🇵',code:'+81',name:'Japan'},
            {flag:'🇮🇳',code:'+91',name:'India'},
            {flag:'🇨🇳',code:'+86',name:'China'}
        ];

        function parsePhoneToFlagCode(fullPhone) {
            // Try to match against known CI_COUNTRIES codes
            const sorted = [...CI_COUNTRIES].sort((a,b) => b.code.length - a.code.length);
            for (const c of sorted) {
                if (fullPhone.startsWith(c.code + ' ') || fullPhone.startsWith(c.code)) {
                    const num = fullPhone.slice(c.code.length).trim();
                    return { flag: c.flag, code: c.code, number: num };
                }
            }
            // Fallback: try to detect +XX prefix
            const m = fullPhone.match(/^(\+\d{1,3})\s*(.*)/);
            if (m) return { flag: '🌐', code: m[1], number: m[2] };
            return { flag: '🇺🇸', code: '+1', number: fullPhone };
        }

        function initPhoneEditRows() {
            const section = document.getElementById('ci-phones');
            const container = document.getElementById('ci-phones-edit-container');
            const addBtn = container.querySelector('.ci-add-btn');
            // Remove existing wrappers, boxes, captions
            container.querySelectorAll('.ci-edit-primary-box, .ci-edit-extra-box, .ci-phone-section-caption').forEach(el => el.remove());

            // Primary phone from view
            const primaryText = (section.querySelector('.ci-primary-card .data-value') || {}).textContent || '';
            const primary = parsePhoneToFlagCode(primaryText.trim());
            const primaryBox = document.createElement('div');
            primaryBox.className = 'ci-edit-primary-box';
            primaryBox.appendChild(buildPhoneRow(primary.flag, primary.code, primary.number, false, true));
            container.insertBefore(primaryBox, addBtn);

            // "Primary Phone Number" caption — OUTSIDE the primary box
            const primaryCaption = document.createElement('div');
            primaryCaption.className = 'ci-phone-section-caption';
            primaryCaption.textContent = 'Primary Phone Number';
            container.insertBefore(primaryCaption, addBtn);

            // Additional phones from view
            const extras = section.querySelectorAll('.ci-extra-group .data-value');
            if (extras.length > 0) {
                const extraBox = document.createElement('div');
                extraBox.className = 'ci-edit-extra-box';
                extras.forEach(el => {
                    const p = parsePhoneToFlagCode(el.textContent.trim());
                    const w = buildPhoneRow(p.flag, p.code, p.number, true, false);
                    w.dataset.extra = '1';
                    extraBox.appendChild(w);
                    const cap = document.createElement('div');
                    cap.className = 'ci-phone-section-caption';
                    cap.textContent = 'Additional Phone Number';
                    extraBox.appendChild(cap);
                });
                container.insertBefore(extraBox, addBtn);
            }
        }

        function ciAddPhoneInline() {
            const zone = document.getElementById('ci-phones-add-zone');
            if (!zone) return;
            // Mutual exclusion: close edit mode when opening Add New
            const section = document.getElementById('ci-phones');
            if (section && section.classList.contains('ci-editing')) {
                section.classList.remove('ci-editing');
            }
            zone.innerHTML = '';
            const items = CI_COUNTRIES.map(c =>
                `<div class="ci-phone-country-item" onclick="ciPhoneSelectCountry(this,'${c.flag}','${c.code}')">
                    <span class="ci-flag">${c.flag}</span>
                    <span class="ci-phone-item-code">${c.code}</span>
                    <span class="ci-phone-item-name">${c.name}</span>
                </div>`).join('');
            const block = document.createElement('div');
            block.className = 'ci-inline-add-block';
            block.innerHTML = `${INLINE_CLOSE_BTN}
                <div class="ci-edit-field-row ci-phone-row">
                    <div class="ci-edit-field ci-phone-code-field">
                        <div class="ci-edit-input-wrap ci-phone-trigger" onclick="togglePhoneTrigger(this,event)">
                            ${flagImgHTML('🇺🇸')}
                            <span class="ci-phone-flag-emoji" data-emoji="🇺🇸" style="display:none">🇺🇸</span>
                            <span class="ci-phone-code-display">+1</span>
                            <span class="ci-phone-chev"></span>
                            <div class="ci-phone-country-dd">${items}</div>
                        </div>
                        <div class="ci-edit-label">Country Code</div>
                    </div>
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap">
                            <input type="tel" class="ci-new-phone-inp" placeholder="Phone">
                        </div>
                        <div class="ci-edit-label">Phone Number</div>
                    </div>
                </div>
                <div class="ci-primary-checkbox-row">
                    <div class="ci-primary-checkbox" onclick="this.classList.toggle('checked')"></div>
                    <span class="ci-primary-checkbox-label" onclick="this.previousElementSibling.classList.toggle('checked')">Primary Phone Number</span>
                </div>
                ${inlineSaveBtn('ciSaveInlinePhone')}`;
            zone.appendChild(block);
            // Add label outside block (same pattern as email)
            const lbl = document.createElement('div');
            lbl.className = 'ci-inline-add-label';
            lbl.style.cssText = 'margin-top:4px;padding-left:20px;font:400 12px/15px Inter,sans-serif;opacity:0.5;';
            lbl.textContent = 'Add New Phone Number';
            zone.appendChild(lbl);
            block._label = lbl;
            const dd = block.querySelector('.ci-phone-country-dd');
            document.addEventListener('click', function closeDd(e) {
                if (!block.querySelector('.ci-phone-trigger').contains(e.target)) {
                    dd.classList.remove('open');
                    document.removeEventListener('click', closeDd);
                }
            });
            block.querySelector('.ci-new-phone-inp').focus();
        }

        function ciPhoneSelectCountry(el, flag, code) {
            // Works for both inline add-block and edit mode rows
            const wrap = el.closest('.ci-phone-trigger');
            if (wrap) {
                // Update flag IMG (new), plus legacy emoji span + code text
                const flagImgEl = wrap.querySelector('.ci-phone-flag');
                if (flagImgEl) {
                    const file = FLAG_FILE[flag] || 'US.svg';
                    flagImgEl.src = 'img/' + file;
                }
                const emojiEl = wrap.querySelector('.ci-phone-flag-emoji, .ci-phone-flag-display');
                if (emojiEl) {
                    emojiEl.textContent = flag;
                    if (emojiEl.dataset) emojiEl.dataset.emoji = flag;
                }
                wrap.querySelector('.ci-phone-code-display').textContent = code;
                wrap.classList.remove('open');
            }
            el.closest('.ci-phone-country-dd').classList.remove('open');
        }

        function ciSaveInlinePhone(btn) {
            const block = btn.closest('.ci-inline-add-block');
            const code = block.querySelector('.ci-phone-code-display').textContent.trim();
            const num = block.querySelector('.ci-new-phone-inp').value.trim();
            const wrap = block.querySelector('.ci-new-phone-inp').closest('.ci-edit-input-wrap');
            if (!num) { if(block._label) block._label.remove(); block.remove(); return; }
            const isValid = /^[\d\s\(\)\-\.]{4,}$/.test(num);
            wrap.classList.toggle('error', !isValid);
            if (!isValid) return;
            const full = code + ' ' + num;
            const isPrimary = !!block.querySelector('.ci-primary-checkbox.checked');
            const section = document.getElementById('ci-phones');
            let extra = section.querySelector('.ci-extra-group');
            if (!extra) {
                extra = document.createElement('div');
                extra.className = 'ci-extra-group';
                section.insertBefore(extra, document.getElementById('ci-phones-add-zone'));
                const lbl = document.createElement('div');
                lbl.className = 'data-label';
                lbl.textContent = 'Additional Phone Number(s)';
                extra.appendChild(lbl);
            }
            const newLine = document.createElement('div');
            newLine.className = 'data-value';
            newLine.textContent = full;
            extra.insertBefore(newLine, extra.querySelector('.data-label'));
            if (isPrimary) {
                const pc = section.querySelector('.ci-primary-card .data-value');
                if (pc) pc.textContent = full;
            }
            // BUGFIX (2026-04-17): remove the external "Add New Phone Number"
            // label before tearing the block down — otherwise it leaks into
            // view mode and sits below the saved number. Matches the pattern
            // in ciSaveInlineEmail / ciSaveInlineAddr.
            if (block._label) block._label.remove();
            block.remove();
        }

        // ── ADD ADDRESS ───────────────────────────────────────────────────────
        function ciAddAddrInline() {
            const zone = document.getElementById('ci-addresses-add-zone');
            if (!zone) return;
            // Mutual exclusion: close edit mode when opening Add New
            const section = document.getElementById('ci-addresses');
            if (section && section.classList.contains('ci-editing')) {
                section.classList.remove('ci-editing');
            }
            const existing = zone.querySelector('.ci-inline-add-block');
            if (existing) { existing.remove(); if(existing._label) existing._label.remove(); }
            const COUNTRY_OPTS = ['United Kingdom','United States','Bulgaria','Germany','France','Australia','Canada','Japan','India','Other']
                .map(c => `<option value="${c}">${c}</option>`).join('');
            const block = document.createElement('div');
            block.className = 'ci-inline-add-block';
            block.innerHTML = `${INLINE_CLOSE_BTN}
                <div class="ci-edit-field-row">
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap">
                            <input type="text" class="ci-new-addr-street" placeholder="Street">
                        </div>
                        <div class="ci-edit-label">Address</div>
                    </div>
                </div>
                <div class="ci-edit-field-row">
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap">
                            <input type="text" class="ci-new-addr-city" placeholder="City / Town">
                        </div>
                        <div class="ci-edit-label">City / Town</div>
                    </div>
                    <div class="ci-edit-field ci-zip-field">
                        <div class="ci-edit-input-wrap">
                            <input type="text" class="ci-new-addr-zip" placeholder="ZIP / Post Code">
                        </div>
                        <div class="ci-edit-label">ZIP / Post Code</div>
                    </div>
                </div>
                <div class="ci-edit-field-row">
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap">
                            <select class="ci-new-addr-country">
                                <option value="" disabled selected>Select Country</option>
                                ${COUNTRY_OPTS}
                            </select>
                            <span class="ci-addr-chev"></span>
                        </div>
                        <div class="ci-edit-label">Country</div>
                    </div>
                </div>
                <div class="ci-primary-checkbox-row">
                    <div class="ci-primary-checkbox ci-primary-addr-chk" onclick="this.classList.toggle('checked')"></div>
                    <span class="ci-primary-checkbox-label" onclick="this.previousElementSibling.classList.toggle('checked')">Primary Address</span>
                </div>
                <div class="ci-primary-info-text">Your primary address defines the legal jurisdiction for your Will and POA template documents.</div>
                ${inlineSaveBtn('ciSaveInlineAddr')}`;
            zone.appendChild(block);
            const lbl = document.createElement('div');
            lbl.style.cssText = 'padding-left:20px;margin-top:4px;font:400 12px/15px Inter,sans-serif;color:rgba(0,0,0,0.5);';
            lbl.textContent = 'Add New Address';
            block._label = lbl;
            zone.appendChild(lbl);
            block.querySelector('.ci-new-addr-street').focus();
        }

        function ciSaveInlineAddr(btn) {
            const block = btn.closest('.ci-inline-add-block');
            const street  = block.querySelector('.ci-new-addr-street').value.trim();
            const city    = block.querySelector('.ci-new-addr-city').value.trim();
            const zip     = block.querySelector('.ci-new-addr-zip').value.trim();
            const country = block.querySelector('.ci-new-addr-country').value;
            if (!street && !city) { if(block._label) block._label.remove(); block.remove(); return; }
            const isPrimary = block.querySelector('.ci-primary-checkbox.checked, .ci-primary-addr-chk.checked, .ci-primary-addr-chk:checked') !== null;
            const section = document.getElementById('ci-addresses');
            const zone = document.getElementById('ci-addresses-add-zone');

            const newCard = document.createElement('div');
            newCard.className = 'ci-primary-card';

            if (isPrimary) {
                // demote existing primary to additional
                const existingPrimary = section.querySelector('.ci-primary-card.is-primary');
                if (existingPrimary) {
                    existingPrimary.classList.remove('is-primary');
                    const lbl = existingPrimary.querySelector('.data-label');
                    if (lbl) lbl.textContent = 'Additional Address';
                }
                const parts = [street, city, zip, country].filter(Boolean);
                newCard.classList.add('is-primary');
                newCard.innerHTML = `<div class="data-value">${parts.join('<br>')}</div><div class="data-label">Primary Address</div>`;
                section.insertBefore(newCard, section.querySelector('.ci-primary-card') || zone);
            } else {
                const parts = [street, city, zip, country].filter(Boolean);
                newCard.innerHTML = `<div class="data-value">${parts.join('<br>')}</div><div class="data-label">Additional Address</div>`;
                section.insertBefore(newCard, zone);
            }

            if(block._label) block._label.remove();
            block.remove();
        }

        function ciAddSocialInline() {
            const section = document.getElementById('ci-social');
            const existing = section.querySelector('.social-add-block');
            if (existing) existing.remove();

            const opts = ['Facebook','Instagram','Linkedin','X (Twitter)','TikTok','Other'];
            const options = opts.map(o=>`<option value="${o}">${o}</option>`).join('');

            const block = document.createElement('div');
            block.className = 'social-add-block';
            block.innerHTML = `
                <button class="social-add-block-close" onclick="closeSocialBlock(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 21.5 21.5" style="pointer-events:none;display:block">
                      <g transform="translate(-18824.645 -2141.644)">
                        <circle cx="10" cy="10" r="10" transform="translate(18825.395 2142.394)" fill="none" stroke="#000" stroke-width="1.5"/>
                        <line x2="9.868" transform="translate(18831.906 2148.905) rotate(45)" fill="none" stroke="#000" stroke-linecap="round" stroke-width="1.5"/>
                        <line y2="9.868" transform="translate(18838.883 2148.906) rotate(45)" fill="none" stroke="#000" stroke-linecap="round" stroke-width="1.5"/>
                      </g>
                    </svg>
                </button>
                <div class="ci-edit-field-row">
                    <div class="ci-edit-field ci-platform-field">
                        <div class="ci-edit-input-wrap">
                            <select class="ci-social-platform-sel" onchange="ciSocialAutoUrlBlock(this)">${options}</select>
                            <svg class="ci-chevron-sm" width="8" height="4" viewBox="0 0 8 4" fill="none"><path d="M0.5 0.5L4 3.5L7.5 0.5" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                        <div class="ci-edit-label">Platform</div>
                    </div>
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap">
                            <input type="text" class="ci-social-handle-inp" placeholder="Handle / Username" oninput="ciSocialAutoUrlBlock(this.closest('.ci-edit-field-row').querySelector('.ci-social-platform-sel'))">
                        </div>
                        <div class="ci-edit-label">Username</div>
                    </div>
                </div>
                <div class="ci-edit-field-row">
                    <div class="ci-edit-field">
                        <div class="ci-edit-input-wrap">
                            <input type="url" class="ci-social-url-inp ci-url-inp" placeholder="URL (Optional)">
                        </div>
                        <div class="ci-edit-label">Profile URL</div>
                    </div>
                </div>
                <div class="ei-save-btn-wrap" onclick="ciSaveInlineSocial(this)" ontouchstart="this.classList.add('touching')" ontouchend="setTimeout(()=>this.classList.remove('touching'),300)">
                    <span class="ei-save-btn-label">Save</span>
                    <span class="ei-save-btn-dash"></span>
                    <span class="ei-save-btn-circle">
                        <svg class="ei-save-btn-arrow" width="9" height="16" viewBox="0 0 9 16" fill="none" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 1l7 7-7 7"/></svg>
                    </span>
                </div>`;

            const editContainer = section.querySelector('.ci-edit-container');
            section.insertBefore(block, editContainer);
            const lbl = document.createElement('div');
            lbl.style.cssText = 'padding-left:20px;margin-top:4px;font:400 12px/15px Inter,sans-serif;color:rgba(0,0,0,0.5);';
            lbl.textContent = 'Add New Social Media Profile';
            section.insertBefore(lbl, editContainer);
            block._label = lbl;
            block.querySelector('.ci-social-handle-inp').focus();
        }

        function ciSocialAutoUrlBlock(sel) {
            const row = sel.closest('.ci-edit-field-row') || sel.closest('.social-add-block');
            const block = sel.closest('.social-add-block');
            const handleInp = block ? block.querySelector('.ci-social-handle-inp') : null;
            const urlInp = block ? block.querySelector('.ci-social-url-inp') : null;
            if (!handleInp || !urlInp) return;
            const handle = handleInp.value.trim().replace(/^@/,'');
            const bases = {Facebook:'https://facebook.com/',Instagram:'https://instagram.com/',Linkedin:'https://linkedin.com/in/',
                'X (Twitter)':'https://x.com/',TikTok:'https://tiktok.com/@',Other:''};
            if (handle) urlInp.value = (bases[sel.value]||'') + handle;
        }

        // Two-Layer Icon Crossfade HTML builder — used by both the inline
        // Add flow and the Edit-mode save flow. Keeps ONE source of truth
        // so newly-created social rows always get the mono → color hover
        // swap that matches the initial page markup in profile.html.
        //
        // Supported platforms (extend here when adding new networks):
        //   fb → Facebook, li → LinkedIn, ig → Instagram,
        //   x  → X (Twitter), tt → TikTok, other → Other (generic globe)
        function buildSocialIconMarkup(cls) {
            const nameMap = { fb: 'FB', li: 'LinkedIn', ig: 'Instagram', x: 'X', tt: 'TikTok', other: 'Other' };
            const name = nameMap[cls] || 'Other';
            // Hover asset: SVG for flat-color brands (FB, LinkedIn, X, TikTok,
            // Other) — PNG for Instagram because its gradient is hard to
            // reproduce cleanly in SVG at icon scale.
            const hoverTag = cls === 'ig'
                ? `<img src="img/${name}-color.png" srcset="img/${name}-color.png 1x, img/${name}-color@2x.png 2x" class="icon-hover" alt="">`
                : `<img src="img/${name}-color.svg" class="icon-hover" alt="">`;
            return `<img src="img/${name}-mono.svg" class="icon-default" alt="${name}">${hoverTag}`;
        }

        // Normalize a human-readable platform name (e.g. "X (Twitter)",
        // "TikTok", "Facebook") to the short class used everywhere in CSS
        // and the icon markup builder. Accepts any casing / punctuation.
        function resolveSocialClass(platform) {
            const p = (platform || '').toLowerCase();
            if (p.includes('facebook'))                   return 'fb';
            if (p.includes('linkedin'))                   return 'li';
            if (p.includes('instagram'))                  return 'ig';
            if (p.includes('tiktok') || p.includes('tik tok')) return 'tt';
            if (p.includes('twitter') || p === 'x' || p.startsWith('x (')) return 'x';
            return 'other';
        }

        function ciSaveInlineSocial(btn) {
            const block = btn.closest('.social-add-block');
            if(block && block._label) block._label.remove();
            const section = document.getElementById('ci-social');
            const sel = block.querySelector('.ci-social-platform-sel');
            const handleInp = block.querySelector('.ci-social-handle-inp');
            if (!handleInp.value.trim()) { block.remove(); return; }
            const platform = sel.value;
            const cls = resolveSocialClass(platform);
            const sr = document.createElement('div');
            sr.className = 'social-row';
            sr.setAttribute('ontouchstart',"this.classList.add('touching')");
            sr.setAttribute('ontouchend',"setTimeout(()=>this.classList.remove('touching'),300)");
            sr.innerHTML = `<div class="social-icon ${cls}">${buildSocialIconMarkup(cls)}</div><span class="social-platform">• ${platform}:</span><span class="social-name">${handleInp.value.trim()}</span>`;
            section.insertBefore(sr, block);
            block.remove();
        }

        function ciAddSocial(btn) {
            const trash = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="20" viewBox="0 0 19.722 21.5"><path d="M15.739,9.173,15.362,18.4m-5.223,0L9.761,9.173M20.635,5.881c.373.053.744.11,1.115.17m-1.115-.169L19.47,20.119a2.4,2.4,0,0,1-2.448,2.13H8.478a2.4,2.4,0,0,1-2.448-2.13L4.865,5.881m15.77,0q-1.889-.268-3.794-.407M3.75,6.05c.371-.061.742-.117,1.115-.169m0,0q1.889-.268,3.794-.407m8.182,0V4.534a2.3,2.3,0,0,0-2.28-2.257q-1.81-.054-3.622,0a2.3,2.3,0,0,0-2.28,2.257v.939m8.182,0a56.462,56.462,0,0,0-8.182,0" transform="translate(-2.889 -1.499)" fill="none" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/></svg>`;
            const opts = ['Facebook','Instagram','Linkedin','X (Twitter)','TikTok','Other'];
            const options = opts.map(o=>`<option value="${o}">${o}</option>`).join('');
            const container = btn.closest('.ci-edit-container');
            const fRow = document.createElement('div');
            fRow.className = 'ci-edit-field-row';
            fRow.innerHTML = `
                <div class="ci-edit-field ci-platform-field">
                    <div class="ci-edit-input-wrap">
                        <select class="ci-social-platform-sel" style="flex:1;border:none;background:transparent;font:600 16px/24px Inter,sans-serif;color:#000;outline:none;cursor:pointer;appearance:none;-webkit-appearance:none;padding-right:20px" onchange="ciSocialAutoUrl(this)">${options}</select>
                        <svg width="8" height="4" viewBox="0 0 8 4" fill="none" style="flex-shrink:0;pointer-events:none;opacity:0.4"><path d="M0.5 0.5L4 3.5L7.5 0.5" stroke="#000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="ci-edit-label">Platform</div>
                </div>
                <div class="ci-edit-field">
                    <div class="ci-edit-input-wrap">
                        <input type="text" class="ci-social-handle-inp" placeholder="Handle / Username" style="flex:1" oninput="ciSocialAutoUrl(this.closest('.ci-edit-field-row').querySelector('.ci-social-platform-sel'))">
                        <div class="ci-edit-trash" onclick="ciDeleteSocial(this)">${trash}</div>
                    </div>
                    <div class="ci-edit-label">Handle / Username</div>
                </div>`;
            const uRow = document.createElement('div');
            uRow.className = 'ci-edit-field-row';
            uRow.innerHTML = `
                <div class="ci-edit-field">
                    <div class="ci-edit-input-wrap">
                        <input type="url" class="ci-social-url-inp" placeholder="https://" style="flex:1;color:#657EEA;font:400 14px/20px Inter,sans-serif">
                    </div>
                    <div class="ci-edit-label">URL (Optional)</div>
                </div>`;
            container.insertBefore(fRow, btn);
            container.insertBefore(uRow, btn);
            fRow.querySelector('.ci-social-handle-inp').focus();
        }
        function saveCiSocial() {
            const section = document.getElementById('ci-social');
            const editContainer = section.querySelector('.ci-edit-container');
            section.querySelectorAll('.social-row').forEach(r => r.remove());
            section.querySelectorAll('.ci-social-platform-sel').forEach(sel => {
                const fRow = sel.closest('.ci-edit-field-row');
                const handleInp = fRow.querySelector('.ci-social-handle-inp');
                if (!handleInp || !handleInp.value.trim()) return;
                const platform = sel.value;
                const cls = resolveSocialClass(platform);
                const sr = document.createElement('div');
                sr.className = 'social-row';
                sr.setAttribute('ontouchstart',"this.classList.add('touching')");
                sr.setAttribute('ontouchend',"setTimeout(()=>this.classList.remove('touching'),300)");
                sr.innerHTML = `<div class="social-icon ${cls}">${buildSocialIconMarkup(cls)}</div><span class="social-platform">• ${platform}:</span><span class="social-name">${handleInp.value.trim()}</span>`;
                section.insertBefore(sr, editContainer);
            });
            section.classList.remove('ci-editing');
        }
        function addCiFieldById(sectionId) {
            const btn = document.querySelector('#' + sectionId + ' .ci-add-btn');
            if (!btn) return;
            const onclick = btn.getAttribute('onclick');
            const m = onclick.match(/addCiField\(this,'([^']+)','([^']+)','([^']+)'\)/);
            if (m) addCiField(btn, m[1], m[2], m[3]);
        }
        function addCiField(btn, inputType, placeholder, label) {
            const trash_svg = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 19.722 21.5"><path d="M15.739,9.173,15.362,18.4m-5.223,0L9.761,9.173M20.635,5.881c.373.053.744.11,1.115.17m-1.115-.169L19.47,20.119a2.4,2.4,0,0,1-2.448,2.13H8.478a2.4,2.4,0,0,1-2.448-2.13L4.865,5.881m15.77,0q-1.889-.268-3.794-.407M3.75,6.05c.371-.061.742-.117,1.115-.169m0,0q1.889-.268,3.794-.407m8.182,0V4.534a2.3,2.3,0,0,0-2.28-2.257q-1.81-.054-3.622,0a2.3,2.3,0,0,0-2.28,2.257v.939m8.182,0a56.462,56.462,0,0,0-8.182,0" transform="translate(-2.889 -1.499)" fill="none" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/></svg>`;
            const row = document.createElement('div');
            row.className = 'ci-edit-field-row';
            row.innerHTML = `
                <div class="ci-edit-field">
                    <div class="ci-edit-input-wrap">
                        <input type="${inputType}" placeholder="${placeholder}" oninput="this.closest('.ci-edit-input-wrap').classList.remove('error')">
                        <div class="ci-edit-trash" onclick="deleteCiField(this,'social')">${trash_svg}</div>
                    </div>
                    <div class="ci-edit-label">${label}</div>
                </div>`;
            btn.closest('.ci-edit-extra-box, .ci-edit-container').insertBefore(row, btn);
            row.querySelector('input').focus();
        }
        // Esc key exits CI edit mode
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                document.querySelectorAll('.ci-section.ci-editing').forEach(s => s.classList.remove('ci-editing'));
            }
        });

        // Reposition on scroll
        document.addEventListener('scroll', function() {
            document.querySelectorAll('.doc-dropdown.open').forEach(d => {
                if (d._trigger) {
                    const rect = d._trigger.getBoundingClientRect();
                    d.style.top  = rect.top + 'px';
                    d.style.left = (rect.right - 150) + 'px';
                }
            });
        }, true);

        // Close on outside click
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.doc-menu') && !e.target.closest('.doc-dropdown')) {
                closeAllDD();
            }
        });

        // ========== MODULE L3 TOGGLE (expand/collapse children) ==========
        let activeModuleId = null;
        function toggleModule(row, childrenId) {
            const children = document.getElementById(childrenId);
            const isOpen = children.classList.contains('open');
            
            // Close all open modules first
            document.querySelectorAll('.content-children').forEach(c => {
                c.classList.remove('open');
                c.style.maxHeight = '0px';
            });
            // Reset all toggle buttons to +
            document.querySelectorAll('#plan-sub .toggle-btn').forEach(btn => {
                btn.innerHTML = '<svg width="8" height="8" viewBox="0 0 8 8" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><line x1="4" y1="0.5" x2="4" y2="7.5"/><line x1="0.5" y1="4" x2="7.5" y2="4"/></svg>';
            });
            // Reset all module rows active state
            document.querySelectorAll('#plan-sub .module-row').forEach(r => {
                r.classList.remove('active');
                r.classList.remove('expanded');
            });
            
            if (!isOpen) {
                // Expand
                row.classList.add('active');
                row.classList.add('expanded');
                children.classList.add('open');
                children.style.maxHeight = children.scrollHeight + 'px';
                // Update ALL parent containers so content is not clipped
                const parentSub = children.closest('.sub-items');
                if (parentSub) {
                    setTimeout(() => { parentSub.style.maxHeight = 'none'; }, 50);
                }
                // Switch toggle to minus
                const toggleBtn = row.querySelector('.toggle-btn');
                if (toggleBtn) {
                    toggleBtn.innerHTML = '<svg width="8" height="8" viewBox="0 0 8 8" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><line x1="0.5" y1="4" x2="7.5" y2="4"/></svg>';
                }
                activeModuleId = childrenId;
                
                // Auto-scroll the menu to show the expanded module
                setTimeout(() => {
                    const menu = document.querySelector('.menu-section');
                    const rowRect = row.getBoundingClientRect();
                    const menuRect = menu.getBoundingClientRect();
                    if (rowRect.bottom > menuRect.bottom - 40) {
                        menu.scrollBy({ top: rowRect.bottom - menuRect.bottom + 80, behavior: 'smooth' });
                    }
                }, 100);
            } else {
                activeModuleId = null;
            }
        }

        // ========== SIDEBAR CATEGORY SWITCHING ==========
        let currentSidebarCategory = null;

        function switchSidebarCategory(category) {
            const defaultView = document.getElementById('sidebar-default');
            const categoryView = document.getElementById('sidebar-category');
            const dirAssets = document.getElementById('dir-assets');
            const dirLegacy = document.getElementById('dir-legacy');
            const dirSupport = document.getElementById('dir-support');
            const dirHealth = document.getElementById('dir-health');
            const dirGoals = document.getElementById('dir-goals');
            const dirWill = document.getElementById('dir-will');
            const menuSection = document.querySelector('.menu-section');

            // Already showing this category — just keep it (don't toggle back)
            if (currentSidebarCategory === category) {
                return;
            }

            currentSidebarCategory = category;
            { const _el = document.querySelector('.sidebar-photo'); if(_el) _el.style.display = 'none'; }
            { const _el = document.querySelector('.identity-strip'); if(_el) _el.style.display = 'none'; }
            { const _el = document.querySelector('.plan-strip'); if(_el) _el.style.display = 'none'; }
            categoryView.style.display = 'block';
            categoryView.classList.remove('sidebar-fade-in');
            categoryView.offsetHeight;
            categoryView.classList.add('sidebar-fade-in');
            dirAssets.style.display = 'none';
            dirLegacy.style.display = 'none';
            dirSupport.style.display = 'none';
            dirHealth.style.display = 'none';
            dirGoals.style.display = 'none';
            dirWill.style.display = 'none';
            menuSection.classList.add('category-mode');

            if (category === 'assets') dirAssets.style.display = 'flex';
            else if (category === 'legacy') dirLegacy.style.display = 'flex';
            else if (category === 'support') dirSupport.style.display = 'flex';
            else if (category === 'health') dirHealth.style.display = 'flex';
            else if (category === 'goals') dirGoals.style.display = 'flex';
            else if (category === 'will') dirWill.style.display = 'flex';
        }

        function resetSidebarToDefault() {
            currentSidebarCategory = null;
            const defaultView = document.getElementById('sidebar-default');
            { const _el = document.querySelector('.sidebar-photo'); if(_el) _el.style.display = ''; }
            { const _el = document.querySelector('.identity-strip'); if(_el) _el.style.display = ''; }
            { const _el = document.querySelector('.plan-strip'); if(_el) _el.style.display = ''; }
            defaultView.classList.remove('sidebar-fade-in');
            defaultView.offsetHeight;
            defaultView.classList.add('sidebar-fade-in');
            document.getElementById('sidebar-category').style.display = 'none';
            { const _el = document.querySelector('.menu-section'); if(_el) _el.classList.remove('category-mode'); }
        }

        // ========== PHOTO UPLOAD ==========
        // Load from localStorage on every page — persists across navigation
        let planOwnerPhotoURL = localStorage.getItem('planOwnerPhoto') || null;
        let planOwnerCropX = parseFloat(localStorage.getItem('planOwnerCropX')) || 50;
        let planOwnerCropY = parseFloat(localStorage.getItem('planOwnerCropY')) || 50;
        let planOwnerScale = 1;    // transform scale
        // Monogram mode — user explicitly chose initials instead of a photo.
        // Distinguishes "no photo because never uploaded" (show upload CTA)
        // from "no photo because user picked Monogram" (show big SJ in sidebar).
        let planOwnerMonogramMode = localStorage.getItem('planOwnerMonogram') === '1';
        function handlePhotoUpload(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                planOwnerPhotoURL = e.target.result;
                planOwnerCropX = 50; planOwnerCropY = 50; planOwnerScale = 1;
                applyPlanOwnerPhoto();
            };
            reader.readAsDataURL(file);
        }

        // Read-mode avatar click — mobile: browse photo, desktop: delegate to sidebar
        function handleReadAvatarClick() {
            if (window.innerWidth <= 767) {
                document.getElementById('photoUpload').click();
            } else {
                // On desktop, the sidebar photo handles this
                const sidebar = document.querySelector('.sidebar-photo');
                if (sidebar) sidebar.click();
            }
        }

        // Photo container click — no photo: browse, has photo: toggle edit menu
        function handlePhotoClick(e) {
            if (repoMode) return;
            if (e.target.closest('.photo-doc-menu')) return;
            if (planOwnerPhotoURL) {
                const trigger = document.getElementById('photoDots');
                toggleDD(trigger);
            } else {
                document.getElementById('photoUpload').click();
            }
        }

        function applyPlanOwnerPhoto() {
            if (!planOwnerPhotoURL) return;
            const pos = planOwnerCropX + '% ' + planOwnerCropY + '%';
            const sc = 'scale(' + planOwnerScale + ')';

            // A real photo overrides any previous Monogram mode
            planOwnerMonogramMode = false;
            localStorage.removeItem('planOwnerMonogram');
            // Hide any sidebar monogram overlay
            const sbMono = document.getElementById('sidebarMonogram');
            if (sbMono) sbMono.style.display = 'none';

            // ── Persist to localStorage so it survives page navigation ──
            localStorage.setItem('planOwnerPhoto', planOwnerPhotoURL);
            localStorage.setItem('planOwnerCropX', planOwnerCropX);
            localStorage.setItem('planOwnerCropY', planOwnerCropY);
            localStorage.setItem('planOwnerScale', planOwnerScale);

            // Sidebar photo
            const sidebarImg = document.getElementById('sidebarPhotoImg');
            if (sidebarImg) {
                sidebarImg.src = planOwnerPhotoURL;
                sidebarImg.style.display = 'block';
                sidebarImg.style.objectFit = 'cover';
                sidebarImg.style.objectPosition = pos;
                sidebarImg.style.transform = sc;
            }
            const photoPlaceholder = document.getElementById('photoPlaceholder');
            if (photoPlaceholder) photoPlaceholder.style.display = 'none';
            const photoAddCircle = document.getElementById('photoAddCircle');
            if (photoAddCircle) photoAddCircle.style.display = 'none';
            const photoCircleBg = document.getElementById('photoCircleBg');
            if (photoCircleBg) photoCircleBg.style.display = 'none';
            const photoDots = document.getElementById('photoDots');
            if (photoDots) photoDots.classList.add('visible');

            // Header avatar (top-right corner)
            const headerImg = document.getElementById('headerAvatarImg');
            if (headerImg) {
                headerImg.src = planOwnerPhotoURL;
                headerImg.style.display = 'block';
                headerImg.style.objectPosition = pos;
                headerImg.style.transform = sc;
            }
            const headerInitials = document.getElementById('headerInitials');
            if (headerInitials) headerInitials.style.display = 'none';

            // Profile header card avatar (My Profile page top)
            const profAvatar = document.getElementById('profileAvatarImg');
            if (profAvatar) {
                profAvatar.src = planOwnerPhotoURL;
                profAvatar.style.display = '';
                profAvatar.style.objectPosition = pos;
                profAvatar.style.transform = sc;
            }
            const profInitials = document.getElementById('profileAvatarInitials');
            if (profInitials) profInitials.style.display = 'none';

            // Helper: apply crop position + scale uniformly
            function applyCrop(el) {
                if (!el) return;
                el.style.objectFit = 'cover';
                el.style.objectPosition = pos;
                el.style.transform = sc;
                el.style.transformOrigin = 'center center';
            }

            // Essential Info — read mode avatar
            const eiReadAvatar = document.getElementById('eiReadAvatar');
            if (eiReadAvatar) { eiReadAvatar.src = planOwnerPhotoURL; eiReadAvatar.style.display = ''; applyCrop(eiReadAvatar); }
            const eiReadInit2 = document.getElementById('eiReadInitials');
            if (eiReadInit2) eiReadInit2.style.display = 'none';

            // Essential Info — edit mode avatar
            const eiEditAvatar = document.getElementById('eiAvatarPreview');
            if (eiEditAvatar) { eiEditAvatar.src = planOwnerPhotoURL; eiEditAvatar.style.display = 'block'; applyCrop(eiEditAvatar); }
            const eiAvatarInit2 = document.getElementById('eiAvatarInitials');
            if (eiAvatarInit2) eiAvatarInit2.style.display = 'none';
            // Plus layers are controlled by CSS :hover opacity — do NOT set display:none here
            // (that would break the hover-reveals-+ behavior when a photo exists).

            // Essential Info — "Current" picker item reflects active photo
            const eiPickerCurrentImg = document.getElementById('eiPickerCurrentImg');
            if (eiPickerCurrentImg) {
                eiPickerCurrentImg.src = planOwnerPhotoURL;
                eiPickerCurrentImg.style.display = 'block';
                applyCrop(eiPickerCurrentImg);
                // Hide the SJ fallback initials inside Current when photo exists
                const currentSpan = eiPickerCurrentImg.parentElement.querySelector('.ei-picker-initials');
                if (currentSpan) currentSpan.style.display = 'none';
            }

            // Sidebar identity avatar (mobile)
            const idAvatar = document.getElementById('identityAvatarImg');
            if (idAvatar) { idAvatar.src = planOwnerPhotoURL; applyCrop(idAvatar); }
            const idInitials = document.getElementById('identityInitials');
            if (idInitials) idInitials.style.display = 'none';

            // Settings page avatar (if present)
            const settingsAvatar = document.getElementById('settingsAvatarImg');
            if (settingsAvatar) { settingsAvatar.src = planOwnerPhotoURL; settingsAvatar.style.display = 'block'; applyCrop(settingsAvatar); }
            const settingsInitials = document.getElementById('settingsAvatarInitials');
            if (settingsInitials) settingsInitials.style.display = 'none';

            // ── All plan-owner summary cards (family tree, network, etc.) ──
            document.querySelectorAll('.plan-owner-photo').forEach(function(el) {
                el.src = planOwnerPhotoURL;
                el.style.display = 'block';
                applyCrop(el);
            });
            document.querySelectorAll('.plan-owner-initials').forEach(function(el) {
                el.style.display = 'none';
            });

            // ── Profile dropdown avatar ──
            const dropAvatar = document.getElementById('dropdownAvatarImg');
            if (dropAvatar) { dropAvatar.src = planOwnerPhotoURL; dropAvatar.style.display = 'block'; applyCrop(dropAvatar); }
            const dropInitials = document.getElementById('dropdownAvatarInitials');
            if (dropInitials) dropInitials.style.display = 'none';

            // ── Print document: cover avatar + page 2 photo + print sidebar ──
            const printAvatar = document.querySelector('.print-avatar');
            const printAvatarInit = document.querySelector('.print-avatar-initials');
            if (printAvatar) { printAvatar.src = planOwnerPhotoURL; printAvatar.style.display = 'block'; applyCrop(printAvatar); }
            if (printAvatarInit) printAvatarInit.style.display = 'none';

            document.querySelectorAll('.print-profile-photo img').forEach(function(el) {
                el.src = planOwnerPhotoURL; el.style.display = 'block'; applyCrop(el);
            });
            document.querySelectorAll('.print-profile-initials').forEach(function(el) {
                el.style.display = 'none';
            });

            const docSbPhoto = document.querySelector('.doc-sb-photo');
            const docSbInitials = document.querySelector('.doc-sb-initials');
            if (docSbPhoto) { docSbPhoto.src = planOwnerPhotoURL; docSbPhoto.style.display = 'block'; applyCrop(docSbPhoto); }
            if (docSbInitials) docSbInitials.style.display = 'none';

            document.querySelectorAll('.print-owner-avatar').forEach(function(el) {
                el.src = planOwnerPhotoURL;
                el.style.display = 'block';
                applyCrop(el);
                var oi = el.nextElementSibling;
                if (oi && oi.classList.contains('initials')) oi.style.display = 'none';
            });

            // ── Print document: cover avatar + page 2 photo + print sidebar ──
            const printAvatar = document.querySelector('.print-avatar');
            const printAvatarInit = document.querySelector('.print-avatar-initials');
            if (printAvatar) { printAvatar.src = planOwnerPhotoURL; printAvatar.style.display = 'block'; }
            if (printAvatarInit) printAvatarInit.style.display = 'none';

            document.querySelectorAll('.print-profile-photo img').forEach(function(el) {
                el.src = planOwnerPhotoURL; el.style.display = 'block';
            });
            document.querySelectorAll('.print-profile-initials').forEach(function(el) {
                el.style.display = 'none';
            });

            const docSbPhoto = document.querySelector('.doc-sb-photo');
            const docSbInitials = document.querySelector('.doc-sb-initials');
            if (docSbPhoto) { docSbPhoto.src = planOwnerPhotoURL; docSbPhoto.style.display = 'block'; }
            if (docSbInitials) docSbInitials.style.display = 'none';

            document.querySelectorAll('.print-owner-avatar').forEach(function(el) {
                el.src = planOwnerPhotoURL;
                el.style.display = 'block';
                var oi = el.nextElementSibling;
                if (oi && oi.classList.contains('initials')) oi.style.display = 'none';
            });

            // ── Album tab: add to Profile Pictures if not already there ──
            addToAlbumProfilePictures(planOwnerPhotoURL);

            const zoomSlider = document.getElementById('zoomSlider');
            if (zoomSlider) zoomSlider.value = planOwnerScale * 100;
        }

        // Add photo to Album tab > Profile Pictures folder (deduplicated)
        function addToAlbumProfilePictures(dataURL) {
            if (!dataURL) return;
            try {
                let albumPhotos = JSON.parse(localStorage.getItem('albumProfilePictures') || '[]');
                // Avoid duplicates — only add if this exact URL isn't already the latest
                if (albumPhotos[albumPhotos.length - 1] !== dataURL) {
                    albumPhotos.push(dataURL);
                    localStorage.setItem('albumProfilePictures', JSON.stringify(albumPhotos));
                }
                // Refresh album grid if currently visible
                renderAlbumProfilePictures();
            } catch(e) {}
        }

        // Render Album > Profile Pictures grid (called when Album tab is active
        // and whenever a photo is added). Empty-state message is toggled next to it.
        function renderAlbumProfilePictures() {
            const grid  = document.getElementById('albumProfilePicturesGrid');
            const empty = document.getElementById('albumProfilePicturesEmpty');
            if (!grid) return;
            try {
                const photos = JSON.parse(localStorage.getItem('albumProfilePictures') || '[]');
                grid.innerHTML = '';
                if (!photos.length) {
                    if (empty) empty.style.display = 'block';
                    return;
                }
                if (empty) empty.style.display = 'none';
                photos.slice().reverse().forEach(function(url, idx) {
                    const wrap = document.createElement('div');
                    wrap.style.cssText = 'position:relative;border-radius:20px;overflow:hidden;aspect-ratio:1/1;cursor:pointer;background:#EDEDED;';
                    wrap.onclick = function(){ selectAlbumPhoto(url); };
                    const img = document.createElement('img');
                    img.src = url;
                    img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
                    wrap.appendChild(img);
                    if (idx === 0) {
                        const badge = document.createElement('div');
                        badge.style.cssText = 'position:absolute;bottom:10px;left:12px;font:600 11px/14px Inter,sans-serif;color:#fff;text-shadow:0 1px 2px rgba(0,0,0,0.4);';
                        badge.textContent = 'Current';
                        wrap.appendChild(badge);
                    }
                    grid.appendChild(wrap);
                });
            } catch(e) {}
        }
        // Read photos saved to the profile's Album — same storage the Album tab renders.
        function getProfileAlbumPhotos() {
            try { return JSON.parse(localStorage.getItem('albumProfilePictures') || '[]'); }
            catch(_) { return []; }
        }
        // Helper: sync crop state from sidebar img to global + propagate
        function syncCropState() {
            const img = document.getElementById('sidebarPhotoImg');
            if (!img) return;
            const pos = (img.style.objectPosition || '50% 50%').split(' ');
            planOwnerCropX = parseFloat(pos[0]) || 50;
            planOwnerCropY = parseFloat(pos[1]) || 50;
            planOwnerScale = parseFloat(img.style.transform?.match(/scale\(([\d.]+)\)/)?.[1] || 1);
            // Re-apply to ALL sync targets (header, profile, essential info, identity, settings,
            // dropdown, plan-owner-photo class, print cover/content/sidebar/owner-avatar, etc.)
            applyPlanOwnerPhoto();
        }

        // ===== DRAG & DROP =====
        (function() {
            function initDragDrop() {
                const pc = document.querySelector('.sidebar-photo');
                if (!pc) return;
                pc.addEventListener('dragenter', function(e) { e.preventDefault(); e.stopPropagation(); this.classList.add('drag-over'); });
                pc.addEventListener('dragover', function(e) { e.preventDefault(); e.stopPropagation(); this.classList.add('drag-over'); });
                pc.addEventListener('dragleave', function(e) { e.preventDefault(); e.stopPropagation(); this.classList.remove('drag-over'); });
                pc.addEventListener('drop', function(e) {
                    e.preventDefault(); e.stopPropagation();
                    this.classList.remove('drag-over');
                    var files = e.dataTransfer && e.dataTransfer.files;
                    if (files && files.length > 0 && files[0].type.startsWith('image/')) {
                        var reader = new FileReader();
                        reader.onload = function(ev) {
                            planOwnerPhotoURL = ev.target.result;
                            planOwnerCropX = 50; planOwnerCropY = 50; planOwnerScale = 1;
                            applyPlanOwnerPhoto();
                        };
                        reader.readAsDataURL(files[0]);
                    }
                });
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initDragDrop);
            } else {
                initDragDrop();
            }
        })();

        // ===== PHOTO OPTIONS MENU =====
        function closePhotoOptions() {
            const dd = document.querySelector('#photoDots .doc-dropdown');
            if (dd) dd.classList.remove('open');
        }
