/* ══════════════════════════════════════════════════════
   ENTRY FORMS — toggle, category switch, expand/collapse
   ══════════════════════════════════════════════════════ */

function toggleEntryForm(formId, btnId) {
    const form = document.getElementById(formId);
    const btn  = document.getElementById(btnId);
    if (!form) return;
    const isOpen = form.classList.contains('open');
    if (isOpen) {
        form.classList.remove('open');
        if (btn) btn.classList.remove('hidden');
    } else {
        form.classList.add('open');
        if (btn) btn.classList.add('hidden');
        form.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
}

function saveEntry(formId, btnId) {
    const form = document.getElementById(formId);
    const btn  = document.getElementById(btnId);
    if (!form) return;
    // Simple close + toast on save
    form.classList.remove('open');
    if (btn) btn.classList.remove('hidden');
    showToast('Entry saved successfully');
}

/* Medical category selector */
function selectMedCat(btn, groupId) {
    const form = btn.closest('.entry-form-wrap');
    form.querySelectorAll('.ef-cat-btn').forEach(b => b.classList.remove('active'));
    form.querySelectorAll('.ef-group').forEach(g => g.classList.remove('active'));
    btn.classList.add('active');
    const grp = document.getElementById(groupId);
    if (grp) grp.classList.add('active');
}

/* Generic category selector (Education, Employment, Beliefs) */
function selectCat(btn, formId, groupId) {
    const form = document.getElementById(formId);
    if (!form) return;
    form.querySelectorAll('.ef-cat-btn').forEach(b => b.classList.remove('active'));
    form.querySelectorAll('.ef-group').forEach(g => g.classList.remove('active'));
    btn.classList.add('active');
    const grp = document.getElementById(groupId);
    if (grp) grp.classList.add('active');
}

/* Beliefs — show/hide sub-fields based on belief type */
function toggleBeliefFields(select) {
    const relFields = document.getElementById('belReligious');
    const cultFields = document.getElementById('belCultural');
    if (relFields) relFields.style.display = 
        (select.value === 'religious') ? 'block' : 'none';
    if (cultFields) cultFields.style.display = 
        (select.value === 'cultural' || select.value === 'values' || select.value === 'traditions') ? 'block' : 'none';
}

/* Entry row expand / collapse (inline) */
function toggleEntryExpand(row) {
    const expandBody = row.nextElementSibling;
    if (!expandBody || !expandBody.classList.contains('entry-expand-body')) return;
    const isOpen = expandBody.classList.contains('open');
    // Close all others in same card
    const card = row.closest('.accordion-inner');
    if (card) {
        card.querySelectorAll('.entry-expand-body.open').forEach(b => {
            b.classList.remove('open');
            const prevRow = b.previousElementSibling;
            if (prevRow) prevRow.classList.remove('expanded');
        });
    }
    if (!isOpen) {
        expandBody.classList.add('open');
        row.classList.add('expanded');
    }
}

/* Simple toast notification */
function showToast(msg) {
    let t = document.getElementById('globalToast');
    if (!t) {
        t = document.createElement('div');
        t.id = 'globalToast';
        t.style.cssText = `
            position:fixed; bottom:24px; right:24px; z-index:99999;
            background:#000; color:#fff; border-radius:16px;
            padding:12px 20px; font:500 14px/20px 'Inter',sans-serif;
            opacity:0; transform:translateY(12px);
            transition:opacity 0.25s,transform 0.25s;
            pointer-events:none; max-width:300px;
        `;
        document.body.appendChild(t);
    }
    t.textContent = msg;
    t.style.opacity = '1';
    t.style.transform = 'translateY(0)';
    clearTimeout(t._timeout);
    t._timeout = setTimeout(() => {
        t.style.opacity = '0';
        t.style.transform = 'translateY(12px)';
    }, 2800);
}

// ========== MY FAMILY PAGE ==========
let fmCurrentTab = 'tree';
let fmZoomLevel = 1;

function fmInitTabPill() {
    const pill = document.getElementById('fm-tab-pill');
    const activeTab = document.querySelector('.fm-tab.active');
    if (!pill || !activeTab) return;
    pill.style.transition = 'none';
    pill.style.left = activeTab.offsetLeft + 'px';
    pill.style.width = activeTab.offsetWidth + 'px';
    pill.style.top = activeTab.offsetTop + 'px';
    requestAnimationFrame(() => {
        pill.style.transition = 'left 0.3s ease-out, width 0.3s ease-out';
    });
}

function fmSwitchTab(tab) {
    fmCurrentTab = tab;
    // Update tab active state
    document.querySelectorAll('.fm-tab').forEach(t => t.classList.remove('active'));
    const activeTab = document.getElementById('fm-tab-' + tab);
    if (activeTab) activeTab.classList.add('active');
    // Move pill
    const pill = document.getElementById('fm-tab-pill');
    if (pill && activeTab) {
        pill.style.left = activeTab.offsetLeft + 'px';
        pill.style.width = activeTab.offsetWidth + 'px';
        pill.style.top = activeTab.offsetTop + 'px';
    }
    // Show/hide views
    ['tree','members','timeline'].forEach(v => {
        const el = document.getElementById('fm-view-' + v);
        if (el) el.style.display = (v === tab) ? 'block' : 'none';
    });
    // If switching to tree, hide add overlay
    if (tab === 'tree') {
        const overlay = document.getElementById('fm-add-overlay');
        const canvas = document.getElementById('fm-tree-canvas');
        const title = document.getElementById('fm-tree-title');
        if (overlay) overlay.style.display = 'none';
        if (canvas) canvas.style.display = 'block';
        if (title) title.textContent = 'Family Tree';
    }
}

function fmShowAddRelatives() {
    const overlay = document.getElementById('fm-add-overlay');
    const canvas = document.getElementById('fm-tree-canvas');
    const title = document.getElementById('fm-tree-title');
    if (overlay) overlay.style.display = 'block';
    if (canvas) canvas.style.display = 'none';
    if (title) title.textContent = 'Add Relatives';
    fmSwitchTab('tree');
    // Switch to tree tab if not already
    document.querySelectorAll('.fm-tab').forEach(t => t.classList.remove('active'));
    const treeTab = document.getElementById('fm-tab-tree');
    if (treeTab) treeTab.classList.add('active');
    const pill = document.getElementById('fm-tab-pill');
    if (pill && treeTab) {
        pill.style.left = treeTab.offsetLeft + 'px';
        pill.style.width = treeTab.offsetWidth + 'px';
    }
}

function fmHideAddRelatives() {
    const overlay = document.getElementById('fm-add-overlay');
    const canvas = document.getElementById('fm-tree-canvas');
    const title = document.getElementById('fm-tree-title');
    if (overlay) overlay.style.display = 'none';
    if (canvas) canvas.style.display = 'block';
    if (title) title.textContent = 'Family Tree';
}

function fmAddRelative(memberId) {
    // Navigate to tree + show add relatives from this member's perspective
    fmShowAddRelatives();
}

function fmStartAdd(type) {
    alert('Add ' + type + ' — будет реализовано в следващата сесия.');
    fmHideAddRelatives();
}

function fmOpenProfile(memberId) {
    // placeholder — navigate to profile page in real impl
    console.log('Open profile:', memberId);
}

function fmCenter() {
    const canvas = document.getElementById('fm-tree-canvas');
    if (canvas) canvas.scrollTop = 0;
}

function fmZoom(dir) {
    fmZoomLevel = Math.max(0.6, Math.min(1.4, fmZoomLevel + dir * 0.1));
    const gens = document.querySelectorAll('.fm-gen');
    gens.forEach(g => g.style.transform = 'scale(' + fmZoomLevel + ')');
}

// Family members ... menu
let fmlOpenMenuId = null;
function fmlOpenMenu(id, e) {
    e.stopPropagation();
    // close existing
    if (fmlOpenMenuId) {
        const old = document.getElementById('fml-menu-' + fmlOpenMenuId);
        if (old) old.remove();
    }
    if (fmlOpenMenuId === id) { fmlOpenMenuId = null; return; }
    fmlOpenMenuId = id;
    const menu = document.createElement('div');
    menu.id = 'fml-menu-' + id;
    menu.style.cssText = 'position:absolute;right:48px;top:10px;background:#fff;border-radius:16px;box-shadow:0 8px 30px rgba(0,0,0,0.18);padding:8px 0;z-index:999;min-width:180px;';
    const items = [
        { label: 'Open Record', icon: '👤' },
        { label: 'Update Relationship', icon: '🔗' },
        { label: 'Add Family', icon: '➕' },
        { label: 'Update Life Status', icon: '📋' },
    ];
    items.forEach(item => {
        const el = document.createElement('div');
        el.style.cssText = 'padding:10px 18px;font:400 14px/17px Inter,sans-serif;cursor:pointer;display:flex;align-items:center;gap:10px;color:#000;';
        el.onmouseenter = () => el.style.background = 'rgba(0,0,0,0.04)';
        el.onmouseleave = () => el.style.background = '';
        el.textContent = item.icon + ' ' + item.label;
        el.onclick = (ev) => { ev.stopPropagation(); menu.remove(); fmlOpenMenuId = null; };
        menu.appendChild(el);
    });
    // Append to fml-card parent
    const btn = e.currentTarget;
    const card = btn.closest('.fml-card');
    if (card) { card.style.position = 'relative'; card.appendChild(menu); }
    // Close on outside click
    setTimeout(() => {
        document.addEventListener('click', function _close() {
            menu.remove(); fmlOpenMenuId = null;
            document.removeEventListener('click', _close);
        }, { once: true });
    }, 0);
}

// Init family tab pill on load
document.addEventListener('DOMContentLoaded', () => {
