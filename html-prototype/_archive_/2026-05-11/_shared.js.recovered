            const eiAvatarInit = document.getElementById('eiAvatarInitials');
            if (eiAvatarInit) eiAvatarInit.style.display = '';
            const eiAvatarPlus = document.getElementById('eiAvatarPlus');
            if (eiAvatarPlus) eiAvatarPlus.style.display = '';
            // Reset settings avatar
            const settingsAvatar = document.getElementById('settingsAvatarImg');
            if (settingsAvatar) { settingsAvatar.src = ''; settingsAvatar.style.display = 'none'; }
            const settingsInitials = document.getElementById('settingsAvatarInitials');
            if (settingsInitials) settingsInitials.style.display = '';
            // Reset profile dropdown avatar
            const dropAvatar = document.getElementById('dropdownAvatarImg');
            if (dropAvatar) { dropAvatar.src = ''; dropAvatar.style.display = 'none'; }
            const dropInitials = document.getElementById('dropdownAvatarInitials');
            if (dropInitials) dropInitials.style.display = '';
            // Reset all plan-owner summary cards (family tree, network, etc.)
            document.querySelectorAll('.plan-owner-photo').forEach(function(el) {
                el.src = ''; el.style.display = 'none';
            });
            document.querySelectorAll('.plan-owner-initials').forEach(function(el) {
                el.style.display = '';
            });
            // Reset print document photos
            const printAvatar = document.querySelector('.print-avatar');
            const printAvatarInit = document.querySelector('.print-avatar-initials');
            if (printAvatar) { printAvatar.src = ''; printAvatar.style.display = 'none'; }
            if (printAvatarInit) printAvatarInit.style.display = 'flex';
            document.querySelectorAll('.print-profile-photo img').forEach(function(el) {
                el.src = ''; el.style.display = 'none';
            });
            document.querySelectorAll('.print-profile-initials').forEach(function(el) {
                el.style.display = 'flex';
            });
            document.querySelectorAll('.print-owner-avatar').forEach(function(el) {
                el.src = ''; el.style.display = 'none';
                var oi = el.nextElementSibling;
                if (oi && oi.classList.contains('initials')) oi.style.display = '';
            });
            const docSbPhoto = document.querySelector('.doc-sb-photo');
            const docSbInitials = document.querySelector('.doc-sb-initials');
            if (docSbPhoto) { docSbPhoto.src = ''; docSbPhoto.style.display = 'none'; }
            if (docSbInitials) docSbInitials.style.display = '';
        }

        // ===== REPOSITION MODE (drag move + zoom slider) =====
        let repoMode = false;
        let savedPosition = 'center center';
        let savedScale = 1;

        function startReposition() {
            document.querySelectorAll('.doc-dropdown.open').forEach(d => d.classList.remove('open'));
            repoMode = true;
            const img = document.getElementById('sidebarPhotoImg');
            savedPosition = img.style.objectPosition || 'center center';
            savedScale = parseFloat(img.style.transform?.match(/scale\(([\d.]+)\)/)?.[1] || 1);
            document.getElementById('repoBar').classList.add('active');
            document.getElementById('zoomSlider').value = savedScale * 100;
            img.style.cursor = 'grab';
        }
        function saveReposition() {
            repoMode = false;
            document.getElementById('repoBar').classList.remove('active');
            document.getElementById('sidebarPhotoImg').style.cursor = '';
            syncCropState(); // save & propagate crop to all avatars
        }
        function cancelReposition() {
            repoMode = false;
            const img = document.getElementById('sidebarPhotoImg');
            img.style.objectPosition = savedPosition;
            img.style.transform = 'scale(' + savedScale + ')';
            document.getElementById('repoBar').classList.remove('active');
            img.style.cursor = '';
            document.getElementById('zoomSlider').value = savedScale * 100;
        }
        function onZoomChange(val) {
            if (!repoMode) return;
            document.getElementById('sidebarPhotoImg').style.transform = 'scale(' + (val / 100) + ')';
        }

        // Drag to move image — mouse + touch, 60fps rAF
        (function() {
            let dragging = false, lastX = 0, lastY = 0;
            let pendingDx = 0, pendingDy = 0, rafId = null;

            function applyMove() {
                const img = document.getElementById('sidebarPhotoImg');
                if (!img) return;
                const pos = (img.style.objectPosition || '50% 50%').split(' ');
                let curX = parseFloat(pos[0]) || 50;
                let curY = parseFloat(pos[1]) || 50;
                curX = Math.max(0, Math.min(100, curX + pendingDx));
                curY = Math.max(0, Math.min(100, curY + pendingDy));
                img.style.objectPosition = curX + '% ' + curY + '%';
                pendingDx = 0; pendingDy = 0; rafId = null;
            }

            function startDrag(x, y, e) {
                if (!repoMode) return;
                if (e.target.closest && e.target.closest('.reposition-bar')) return;
                e.preventDefault();
                dragging = true;
                lastX = x; lastY = y;
                const img = document.getElementById('sidebarPhotoImg');
                if (img) img.style.cursor = 'grabbing';
            }

            function moveDrag(x, y, e) {
                if (!dragging) return;
                e.preventDefault();
                pendingDx += (x - lastX) * -1.5;
                pendingDy += (y - lastY) * -1.5;
                lastX = x; lastY = y;
                if (!rafId) rafId = requestAnimationFrame(applyMove);
            }

            function endDrag() {
                if (!dragging) return;
                dragging = false;
                if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
                if (pendingDx || pendingDy) applyMove();
                const img = document.getElementById('sidebarPhotoImg');
                if (repoMode && img) img.style.cursor = 'grab';
            }

            function attachDragListeners() {
                const container = document.querySelector('.sidebar-photo');
                if (!container) return;
                container.addEventListener('mousedown', function(e) { startDrag(e.clientX, e.clientY, e); });
                container.addEventListener('touchstart', function(e) {
                    if (!repoMode) return;
                    if (e.target.closest && e.target.closest('.reposition-bar')) return;
                    startDrag(e.touches[0].clientX, e.touches[0].clientY, e);
                }, { passive: false });
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', attachDragListeners);
            } else {
                attachDragListeners();
            }

            document.addEventListener('mousemove', function(e) { moveDrag(e.clientX, e.clientY, e); });
            document.addEventListener('mouseup', endDrag);
            document.addEventListener('touchmove', function(e) {
                if (!dragging) return;
                moveDrag(e.touches[0].clientX, e.touches[0].clientY, e);
            }, { passive: false });
            document.addEventListener('touchend', endDrag);
        })();

        // Close photo options on outside click
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.photo-doc-menu')) {
                document.querySelectorAll('.doc-dropdown.open').forEach(d => d.classList.remove('open'));
            }
        });

        // ========== NAVIGATION ========== 
        function toggleNav(btn, subId) {
            const sub = document.getElementById(subId);
            const isOpen = sub.classList.contains('open');
            // Close all first
            document.querySelectorAll('.sub-items').forEach(s => {
                s.classList.remove('open');
                s.style.maxHeight = '0px';
            });
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            if (!isOpen) {
                sub.classList.add('open');
                sub.style.maxHeight = 'none';
                btn.classList.add('active');
            } else {
                // Closing nav - reset sidebar to default
                resetSidebarToDefault();
            }
        }

        // ========== ARTICLE PAGE — IMPROVED ==========
        var articleData = {
            'estate-planning': {
                cat: 'ESTATE PLANNING', time: '5 min read',
