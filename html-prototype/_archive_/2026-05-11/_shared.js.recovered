});

/* ── Auto-grow textareas ──────────────────────────────────────────────
   Textareas with class .ei-autogrow grow their height to fit content.
   Critical: when the containing panel is hidden (display:none), scrollHeight
   returns 0 — do NOT set height in that case or textarea becomes invisible
   and unwritable. When the edit panel opens we call eiInitAutogrow again,
   which re-runs the sizing (bypassing the bound-guard).                 */
function eiAutogrow(ta) {
    if (!ta) return;
    // Only resize when visible; offsetParent is null for display:none ancestors.
    if (!ta.offsetParent && ta !== document.activeElement) return;
    var prev = ta.style.height;
    ta.style.height = 'auto';
    var h = ta.scrollHeight;
    if (h > 0) {
        ta.style.height = h + 'px';
    } else {
        ta.style.height = prev || '';
    }
}
function eiInitAutogrow(root) {
    var scope = root || document;
    scope.querySelectorAll('textarea.ei-autogrow').forEach(function(ta) {
        if (!ta.dataset.autogrowBound) {
            ta.dataset.autogrowBound = '1';
            ta.addEventListener('input', function(){ eiAutogrow(ta); });
            ta.addEventListener('focus', function(){ eiAutogrow(ta); });
        }
        // Always try to resize (will no-op if still hidden).
        eiAutogrow(ta);
    });
}
document.addEventListener('DOMContentLoaded', function(){ eiInitAutogrow(); });
// Re-run when edit panel opens (textareas may be hidden at load)
window.eiInitAutogrow = eiInitAutogrow;

document.addEventListener('DOMContentLoaded', function() {
    // Default-open the Me, Family & Network group ONLY on records that
    // belong to it (profile / record-*). Other top-level pages (vault,
    // tasks, marketplace, settings) already mark their own nav-item active
    // in their HTML \u2014 don't override that here.
    var alreadyActive = document.querySelector('.nav-item.active');
    if (!alreadyActive) {
        var meBtn = document.querySelector('[onclick*="me-sub"]');
        if (meBtn) {
            meBtn.classList.add('active');
            var sub = document.getElementById('me-sub');
            if (sub) sub.classList.add('open');
        }
    }
    // Right panel: show progress on dashboard, AI card on inner pages
    var progressSection = document.querySelector('#rightPanel > div:first-child');
    var aiCol4 = document.getElementById('aiCardCol4');
    var isDashboard = location.pathname === '/'
        || location.pathname.endsWith('/index.html')
        || location.pathname.endsWith('/');
    if (progressSection) progressSection.style.display = isDashboard ? 'flex' : 'none';
    if (aiCol4) aiCol4.style.display = isDashboard ? 'none' : 'flex';
    // Set tab pill
    requestAnimationFrame(function() {
        var tabsPill = document.getElementById('tabsPill');
        var activeTab = document.querySelector('.profile-tab.active');
        if (tabsPill && activeTab) {
            tabsPill.style.transition = 'none';
            tabsPill.style.left = activeTab.offsetLeft + 'px';
            tabsPill.style.width = activeTab.offsetWidth + 'px';
            requestAnimationFrame(function() {
                tabsPill.style.transition = 'left 0.3s ease-out, width 0.3s ease-out';
            });
        }
    });

    /* ── Document Preview: sidebar expand / collapse ── */
    var docSidebar = document.getElementById('docSidebar');
    if (docSidebar) {
        docSidebar.addEventListener('click', function() {
            docSidebar.classList.toggle('expanded');
        });
    }
});

// Blood Type edit toggle — tap pill to open edit pad, Save/Cancel to close
function emcBloodEdit(trigger, open) {
    const pill = document.querySelector('.emc-blood-pill');
    const pad = document.getElementById('emcBloodEditPad');
    if (!pill || !pad) return;
    if (open) {
        pill.classList.add('editing');
        pad.classList.add('open');
    } else {
        pill.classList.remove('editing');
        pad.classList.remove('open');
        // Close blood-type dropdown on cancel
        const input = pad.querySelector('.emc-edit-pad-input');
        if (input) input.classList.remove('open');
    }
}
// Add Allergy toggle — tap "Add Allergy" pill to open form, Save/Cancel to close
function emcAllergyAdd(trigger, open) {
    const btn = document.querySelector('.emc-add-btn');
    const pad = document.getElementById('emcAllergyAddPad');
    if (!btn || !pad) return;
    if (open) {
        btn.style.display = 'none';
        pad.classList.add('open');
    } else {
        btn.style.display = '';
        pad.classList.remove('open');
        // Reset pad state: close any open dropdowns, hide Custom Allergen, clear values
        pad.classList.remove('has-other');
        pad.querySelectorAll('.emc-edit-pad-input.open').forEach(i => i.classList.remove('open'));
        pad.querySelectorAll('.emc-edit-pad-value').forEach(v => v.textContent = '');
        const other = document.getElementById('emcAllergenOtherInput');
        if (other) other.value = '';
    }
}
// Select a blood type from the dropdown — updates the entry below (creates one
// if it doesn't yet exist, e.g. after user deleted the previous Blood Type
// record) and closes the dropdown. The EMC pill above rebuilds via syncEmcBlood
// so its visual state (normal vs .is-empty placeholder) stays in sync with the
// actual data-group entry. Display rule: "Unknown/Not sure" → "Unknown" on the
// pill only (kept full inside the entry / edit pad).
function emcSetBlood(el, value) {
    const pad = document.getElementById('emcBloodEditPad');
    const valueEl = pad?.querySelector('.emc-edit-pad-value');
    const input = pad?.querySelector('.emc-edit-pad-input');
    if (valueEl) valueEl.textContent = value;     // full text in edit dropdown
    if (input) input.classList.remove('open');
    // Find the existing Blood Type entry (if any). Accept both singular &
    // legacy plural title defensively.
    const titles = [...document.querySelectorAll('.data-group-title')];
    const bloodTitle = titles.find(t => {
        const txt = t.textContent.trim();
        return txt === 'Blood Type' || txt === 'Blood Types';
    });
    if (!bloodTitle) return;
    let existingRow = null;
    let cur = bloodTitle.nextElementSibling;
    while (cur && !cur.classList.contains('data-group-title')) {
        if (cur.classList.contains('entry-row')) { existingRow = cur; break; }
        cur = cur.nextElementSibling;
    }
    const display = value === 'Unknown/Not sure' ? 'Unknown' : value;
    if (existingRow) {
        // Update in place — title + data-entry JSON + expand body value
        const titleEl = existingRow.querySelector('.entry-title');
        if (titleEl) titleEl.textContent = display;
        try {
            const data = JSON.parse(existingRow.getAttribute('data-entry') || '{}');
            data.category = data.category || 'Blood Type';
            data.fields   = data.fields   || [];
            const f = data.fields.find(x => x.label === 'Blood Type');
            if (f) f.value = value;
            else data.fields.unshift({ label: 'Blood Type', value: value, required: true });
            existingRow.setAttribute('data-entry', JSON.stringify(data));
            // Re-render the expand body so view/edit modes pick up the new value
            const body = existingRow.nextElementSibling;
            if (body && body.classList.contains('entry-expand-body')) {
                body.removeAttribute('data-built');
                body.innerHTML = '';
                if (typeof window.buildAllMedicalEntries === 'function') window.buildAllMedicalEntries();
            }
        } catch {}
    } else {
        // No entry existed (user had deleted it previously) — create one now.
        if (typeof window.addMedicalEntry === 'function') {
            window.addMedicalEntry({
                groupTitle: 'Blood Type',
                icon: 'img/drop.svg',
                title: display,
                type: 'Blood Type',
                sub: 'Added today',
                badge: '',
                badgeText: '',
                entryData: {
                    category: 'Blood Type',
                    fields: [{ label: 'Blood Type', value: value, required: true }]
                }
            });
        }
    }
    // Final step — rebuild the EMC pill + snapshot so visual state matches data
    if (typeof window.syncEmcSnapshot === 'function') window.syncEmcSnapshot();
    if (typeof window.updateEmergencyPreparednessScore === 'function') window.updateEmergencyPreparednessScore();
}

// Generic toggle for emc-edit-pad dropdowns — closes any sibling dropdown
// that's currently open within the same pad before toggling this one.
function emcToggleDropdown(input) {
    const pad = input.closest('.emc-edit-pad');
    if (pad) {
        pad.querySelectorAll('.emc-edit-pad-input.open').forEach(other => {
            if (other !== input) other.classList.remove('open');
        });
    }
    input.classList.toggle('open');
}

// Select an Allergen — shows/hides Custom Allergen input when "Other" is picked.
function emcSetAllergen(el, value) {
    const pad = document.getElementById('emcAllergyAddPad');
    if (!pad) return;
    const input = el.closest('.emc-edit-pad-input');
    const valueEl = input && input.querySelector('.emc-edit-pad-value');
    if (valueEl) valueEl.textContent = value;
    if (input) input.classList.remove('open');
    // Toggle the conditional "Custom Allergen" text field
    if (value === 'Other') {
        pad.classList.add('has-other');
        const other = document.getElementById('emcAllergenOtherInput');
        if (other) setTimeout(() => other.focus(), 0);
    } else {
        pad.classList.remove('has-other');
        const other = document.getElementById('emcAllergenOtherInput');
        if (other) other.value = '';
    }
}

// Select a Severity — same pattern as emcSetAllergen without conditional field.
function emcSetSeverity(el, value) {
    const input = el.closest('.emc-edit-pad-input');
    const valueEl = input && input.querySelector('.emc-edit-pad-value');
    if (valueEl) valueEl.textContent = value;
    if (input) input.classList.remove('open');
}

// Add Medical Condition toggle — tap "Add Medical Condition" pill to open form.
function emcConditionAdd(trigger, open) {
    const btn = [...document.querySelectorAll('.emc-add-btn')].find(b => {
        const t = b.querySelector('.emc-add-btn-text');
        return t && t.textContent.trim() === 'Add Medical Condition';
    });
    const pad = document.getElementById('emcConditionAddPad');
    if (!btn || !pad) return;
    if (open) {
        btn.style.display = 'none';
        pad.classList.add('open');
    } else {
        // Full reset — so the NEXT open starts in pristine State 1 (159px, dropdown
        // only). Without this, residual inline height from emcConditionRelayout
        // (set when the user added 2–3 med pads) lingered and re-opened the pad
        // as a huge empty box. Additional cloned med pads are removed; primary
        // med pad values + dosage + Other-custom text are cleared.
        btn.style.display = '';
        pad.classList.remove('open');
        pad.classList.remove('has-condition');
        pad.classList.remove('has-other-condition');
        pad.style.height = '';                           // clear inline height from relayout
        pad.querySelectorAll('.emc-meds-pad.is-additional').forEach(p => p.remove()); // drop clones
        pad.querySelectorAll('.emc-meds-pad').forEach(p => { p.style.top = ''; });   // reset top on primary
        const addBtnMed = pad.querySelector('.emc-add-med-btn');
        if (addBtnMed) addBtnMed.style.top = '';
        pad.querySelectorAll('.emc-edit-pad-input.open').forEach(i => i.classList.remove('open'));
        pad.querySelectorAll('.emc-edit-pad-value').forEach(v => v.textContent = '');
        pad.querySelectorAll('.emc-edit-pad-text').forEach(t => { if (t.tagName === 'INPUT') t.value = ''; });
        const otherInput = document.getElementById('emcConditionOtherInput');
        if (otherInput) otherInput.value = '';
    }
}

// Select a Condition — closes dropdown, sets value, and progressively reveals
// the Medications section + Save button (.has-condition modifier on pad).
// Context-aware dropdown content per Condition (matches prototype's CONDITION_MAP
// + Supplements/Preventive list). When user picks a condition, medication options,
// intake options, and dosage placeholder all adapt to be clinically relevant.
const MED_PROFILE_BY_CONDITION = {
    'Hypertension':     { meds: ['Lisinopril','Amlodipine','Losartan','Hydrochlorothiazide','Other'],
                          intakes: ['Once daily','Twice daily','Before bed','As Needed (PRN)','Other'],
                          dosagePlaceholder: 'e.g., 10 mg, 1 tablet' },
    'Diabetes Type 1':  { meds: ['Insulin Glargine','Insulin Lispro','Humalog','Novolog','Other'],
                          intakes: ['Before meals','Once daily','Twice daily','As Needed (PRN)','Other'],
                          dosagePlaceholder: 'e.g., 10 units, 1 injection' },
    'Diabetes Type 2':  { meds: ['Metformin','Jardiance','Glimepiride','Ozempic','Other'],
                          intakes: ['Once daily','Twice daily','With meals','As Needed (PRN)','Other'],
                          dosagePlaceholder: 'e.g., 500 mg, 1 tablet' },
    'Asthma':           { meds: ['Albuterol','Salbutamol','Fluticasone','Symbicort','Other'],
                          intakes: ['As Needed (PRN)','Twice daily','Three times daily','Every 8 hours','Before bed','Other'],
                          dosagePlaceholder: 'e.g., 2 puffs, 1 inhaler' },
    'Epilepsy':         { meds: ['Levetiracetam','Lamotrigine','Valproate','Topiramate','Other'],
                          intakes: ['Twice daily','Three times daily','Every 8 hours','Before bed','Other'],
                          dosagePlaceholder: 'e.g., 500 mg, 1 tablet' },
    'Supplements / Preventive Medication':
                        { meds: ['Vitamin D3','Vitamin B12','Omega-3 / Fish Oil','Magnesium','Iron','Calcium','Multivitamin','Probiotic','Zinc','Vitamin C','CoQ10','Other'],
                          intakes: ['Once daily','Twice daily','With meals','Before bed','As Needed (PRN)','Other'],
                          dosagePlaceholder: 'e.g., 1000 IU, 1 capsule' },
    // Fallback for "Other" condition or any unmapped value — generic list
    '_default':         { meds: ['Other'],
                          intakes: ['Once daily','Twice daily','Three times daily','Every 8 hours','As Needed (PRN)','Before bed','Other'],
                          dosagePlaceholder: 'Set Dosage' }
};
function applyCondMedProfile(value) {
    const pad = document.getElementById('emcConditionAddPad');
    if (!pad) return;
    const profile = MED_PROFILE_BY_CONDITION[value] || MED_PROFILE_BY_CONDITION._default;
    // Repopulate EVERY medication row (first + any added via emcAddMedicationPad)
    const medPads = pad.querySelectorAll('.emc-meds-pad');
    medPads.forEach(medPad => {
        // Medication dropdown
        const medDropdown = medPad.querySelector('.emc-meds-field--m .emc-blood-dropdown');
        if (medDropdown) {
            medDropdown.innerHTML = profile.meds.map(m =>
                `<div class="emc-blood-opt" onclick="event.stopPropagation();emcSetMedication(this,${JSON.stringify(m).replace(/"/g,'&quot;')})">${m}</div>`
            ).join('');
        }
        // Intake dropdown
        const intakeDropdown = medPad.querySelector('.emc-meds-field--i .emc-blood-dropdown');
        if (intakeDropdown) {
            intakeDropdown.innerHTML = profile.intakes.map(o =>
                `<div class="emc-blood-opt" onclick="event.stopPropagation();emcSetIntake(this,${JSON.stringify(o).replace(/"/g,'&quot;')})">${o}</div>`
            ).join('');
        }
        // Dosage placeholder (context-specific example)
        const dosageInput = medPad.querySelector('.emc-meds-field--d input');
        if (dosageInput) dosageInput.placeholder = profile.dosagePlaceholder;
    });
}
function emcSetCondition(el, value) {
    const input = el.closest('.emc-edit-pad-input');
    const valueEl = input && input.querySelector('.emc-edit-pad-value');
    const pad = document.getElementById('emcConditionAddPad');
    if (valueEl) valueEl.textContent = value;
    if (input) input.classList.remove('open');
    if (pad) {
        pad.classList.add('has-condition');
        // Toggle "Other → Custom Condition" text field (XD: shown when Condition = Other)
        pad.classList.toggle('has-other-condition', value === 'Other');
        if (value === 'Other') {
            // Auto-focus the custom text input so user can type immediately
            const input = document.getElementById('emcConditionOtherInput');
            if (input) setTimeout(() => input.focus(), 0);
        }
        // Repopulate medication/intake/dosage options to be clinically relevant
        applyCondMedProfile(value);
    }
}

// Select a Medication (same pattern as condition, no extra state toggle)
function emcSetMedication(el, value) {
    const input = el.closest('.emc-edit-pad-input');
    const valueEl = input && input.querySelector('.emc-edit-pad-value');
    if (valueEl) valueEl.textContent = value;
    if (input) input.classList.remove('open');
}

// Select an Intake Routine
function emcSetIntake(el, value) {
    const input = el.closest('.emc-edit-pad-input');
    const valueEl = input && input.querySelector('.emc-edit-pad-value');
    if (valueEl) valueEl.textContent = value;
    if (input) input.classList.remove('open');
}

// Clone the primary medication inner pad and insert it after the last medication pad.
// Each clone is tagged .is-additional so its X close button appears. The outer pad,
// "Add Medication" button, and Save button shift downward to accommodate.
// Inner pad 317 tall + 20 gap = 337 per added pad.
function emcAddMedicationPad() {
    const pad = document.getElementById('emcConditionAddPad');
    if (!pad) return;
    const pads = pad.querySelectorAll('.emc-meds-pad');
    const primary = pads[0];
    if (!primary) return;
    const last = pads[pads.length - 1];
    const clone = primary.cloneNode(true);
    clone.classList.add('is-additional');
    // Clear all selected values + close any open dropdowns + clear dosage input
    clone.querySelectorAll('.emc-edit-pad-value').forEach(v => v.textContent = '');
    clone.querySelectorAll('.emc-edit-pad-input.open').forEach(i => i.classList.remove('open'));
    const dosage = clone.querySelector('.emc-edit-pad-text');
    if (dosage) dosage.value = '';
    // Position clone 337px below the last medication pad (317 pad + 20 gap)
    const lastTop = parseInt(last.style.top || getComputedStyle(last).top, 10) || 194;
    clone.style.top = (lastTop + 337) + 'px';
    primary.parentNode.insertBefore(clone, last.nextSibling);
    emcConditionRelayout();
}

// Remove an additional medication pad and reflow positions
function emcRemoveMedicationPad(closeEl) {
    const padEl = closeEl.closest('.emc-meds-pad');
    if (!padEl || !padEl.classList.contains('is-additional')) return;
    padEl.remove();
    emcConditionRelayout();
}

// Reposition Add Medication button, Save button, and outer pad height based on medication count
function emcConditionRelayout() {
    const pad = document.getElementById('emcConditionAddPad');
    if (!pad) return;
    const medsPads = pad.querySelectorAll('.emc-meds-pad');
    const count = medsPads.length;
    // Re-stack pads so tops are 194, 531, 868, ...
    medsPads.forEach((p, idx) => { p.style.top = (194 + idx * 337) + 'px'; });
    // Add Medication button sits 20px below the last medication pad bottom
    // last pad bottom = 194 + count*337 - 20 = 174 + count*337; +20 gap → top = 194 + count*337
    const addBtn = pad.querySelector('.emc-add-med-btn');
    const addBtnTop = 194 + count * 337;
    if (addBtn) addBtn.style.top = addBtnTop + 'px';
    // Outer pad height = addBtnTop + 60 (button) + 20 gap + 60 (save) + 20 bottom
    pad.style.height = (addBtnTop + 160) + 'px';
}

// Save a new Medical Condition from the EMC quick-add pad. Collects:
//   1) Condition name (top field, "Other → Custom Condition" override)
//   2) Every embedded Medications sub-pad (name + intake + dosage), each of
//      which becomes a LINKED child entry in the Medications & Supplements
//      data-group (single source of truth for the EMC med-list).
// Result: condition pill appears in the "Medical Conditions" pill-row above;
// every medication that has at least a name is auto-created as an entry in the
// "Medications & Supplements" data-group below, with linkedFrom=conditionId so
// deleting the parent condition cascades to its medications.
function emcConditionSave() {
    const pad = document.getElementById('emcConditionAddPad');
    if (!pad) return;
    // (1) Condition name
    let value = pad.querySelector('.emc-edit-pad-field--1 .emc-edit-pad-value').textContent.trim();
    if (pad.classList.contains('has-other-condition')) {
        const custom = document.getElementById('emcConditionOtherInput');
        const customValue = custom ? custom.value.trim() : '';
        if (!customValue) return;  // required — block save
        value = customValue;
    }
    if (!value) return;
    // (2) Collect every embedded Medications sub-pad (primary + additional clones).
    // A med pad has three fields: m (Medication), i (Intake), d (Dosage text input).
    // A med is considered "present" if it has at least a name. Intake/dosage are
    // optional at quick-add time — user can fill them later in Edit mode.
    const medPads = pad.querySelectorAll('.emc-meds-pad');
    const meds = [];
    medPads.forEach(medPad => {
        const name   = medPad.querySelector('.emc-meds-field--m .emc-edit-pad-value')?.textContent.trim() || '';
        const intake = medPad.querySelector('.emc-meds-field--i .emc-edit-pad-value')?.textContent.trim() || '';
        const dosage = medPad.querySelector('.emc-meds-field--d input')?.value.trim() || '';
        if (name) meds.push({ name, intake, dosage });
    });
    // (3) Emergency Medical Card pill-row — append the condition pill (above).
    const labels = [...document.querySelectorAll('.emc-section-label')];
    const condLabel = labels.find(l => {
        const t = l.textContent.trim();
        return t === 'Medical Conditions' || t === 'Medical Conditions and Medications';
    });
    const pillRow = condLabel && condLabel.nextElementSibling;
    if (pillRow && pillRow.classList.contains('emc-pill-row')) {
        const pill = document.createElement('span');
        pill.className = 'emc-condition-pill';
        pill.textContent = value;
        pillRow.appendChild(pill);
    }
    // (4) Medical Conditions data-group — meds go INSIDE the condition entry as
    // a structured array (not as separate linked entries). See rule 2026-04-24
    // in saveAnefEntry. The EMC med-list aggregates this array + any standalone
    // Medications & Supplements entries via syncEmcConditions.
    const newRow = addMedicalEntry({
        groupTitle: 'Medical Conditions',
        icon: 'img/pill.png',
        title: value,
        type: 'Medical Conditions',
        sub: 'Added today',
        badge: '',
        badgeText: '',
        entryData: {
            category: 'Medical Condition',
            fields: [{ label: 'Condition', value: value, required: true }],
            ...(meds.length ? { meds } : {})
        }
    });
    emcConditionAdd(null, false);
    // Option B hand-off — auto-open the new entry in Edit mode so user can
    // add Location / File / Contacts / Notes without leaving the card.
    if (typeof window.expandEntryInEditMode === 'function') window.expandEntryInEditMode(newRow);
}

// ─────────────────────────────────────────────────────────────
// Medications & Supplements EMC quick-add — independent of conditions.
// Same pattern as Allergy: show/hide pad, dropdown→set value, Save creates
// both the EMC med-item and an entry-row in the Medications & Supplements
// data-group. Entry has NO linkedFrom (standalone). "Other" reveals a custom
// text input below (same pattern as Allergen Other).
// ─────────────────────────────────────────────────────────────
function emcMedicationAdd(trigger, open) {
    const btn = [...document.querySelectorAll('.emc-add-btn')].find(b => {
        const t = b.querySelector('.emc-add-btn-text');
        return t && t.textContent.trim() === 'Add Medications & Supplements';
    });
    const pad = document.getElementById('emcMedicationAddPad');
    if (!btn || !pad) return;
    if (open) {
        btn.style.display = 'none';
        pad.classList.add('open');
    } else {
        btn.style.display = '';
        pad.classList.remove('open');
        pad.classList.remove('has-other-med');
        pad.querySelectorAll('.emc-edit-pad-input.open').forEach(i => i.classList.remove('open'));
        pad.querySelectorAll('.emc-edit-pad-value').forEach(v => v.textContent = '');
        const other = document.getElementById('emcMedOtherInput');
        if (other) other.value = '';
        const dose = document.getElementById('emcMedDosageInput');
        if (dose) dose.value = '';
    }
}
// Select a standalone medication — sets value + toggles Other→Custom field
function emcSetStandaloneMed(el, value) {
    const input = el.closest('.emc-edit-pad-input');
    const valueEl = input && input.querySelector('.emc-edit-pad-value');
    const pad = document.getElementById('emcMedicationAddPad');
    if (valueEl) valueEl.textContent = value;
    if (input) input.classList.remove('open');
    if (pad) {
        pad.classList.toggle('has-other-med', value === 'Other');
        if (value === 'Other') {
            const other = document.getElementById('emcMedOtherInput');
            if (other) setTimeout(() => other.focus(), 0);
        }
    }
}
// Save a standalone Medications & Supplements entry
function emcMedicationSave() {
    const pad = document.getElementById('emcMedicationAddPad');
    if (!pad) return;
    let medValue    = pad.querySelector('.emc-edit-pad-field--1 .emc-edit-pad-value').textContent.trim();
    const intakeValue = pad.querySelector('.emc-edit-pad-field--2 .emc-edit-pad-value').textContent.trim();
    const dosageValue = (document.getElementById('emcMedDosageInput')?.value || '').trim();
    // Required: medication + intake; if Other → custom text is required instead of "Other"
    if (!medValue || !intakeValue) return;
    if (pad.classList.contains('has-other-med')) {
        const customValue = (document.getElementById('emcMedOtherInput')?.value || '').trim();
        if (!customValue) return;
        medValue = customValue;
    }
    // Build entry and add to the Medications & Supplements data-group. The
    // .emc-med-list will auto-rebuild via syncEmcSnapshot since addMedicalEntry
    // triggers it — so no manual DOM insertion is needed.
    const medFields = [
        { label: 'Medication Name', value: medValue, required: true },
        { label: 'Intake', value: intakeValue, required: true }
    ];
    if (dosageValue) medFields.push({ label: 'Dosage', value: dosageValue });
    const newRow = addMedicalEntry({
        groupTitle: 'Medications & Supplements',
        icon: (window.ANEF_CATEGORY_META && window.ANEF_CATEGORY_META['Medications & Supplements']?.icon) || 'img/pill.png',
        title: medValue,
        type: 'Medications & Supplements',
        sub: 'Added today',
        badge: '',
        badgeText: '',
        entryData: {
            category: 'Medications & Supplements',
            fields: medFields
            // NO linkedFrom — standalone medication (not tied to a condition)
        }
    });
    emcMedicationAdd(null, false);
    // Option B hand-off — auto-open the new entry in Edit mode
    if (typeof window.expandEntryInEditMode === 'function') window.expandEntryInEditMode(newRow);
}
window.emcMedicationAdd = emcMedicationAdd;
window.emcSetStandaloneMed = emcSetStandaloneMed;
window.emcMedicationSave = emcMedicationSave;

// ─────────────────────────────────────────────────────────────
// Medical Device & Implant EMC quick-add — mirrors Allergy pattern.
// Device Type dropdown + optional Location on Body free-text + Save.
// "Other" reveals a custom text field (device type) below the dropdown.
// Save creates an EMC pill + entry-row in Medical Devices & Implants group.
// ─────────────────────────────────────────────────────────────
function emcDeviceAdd(trigger, open) {
    const btn = [...document.querySelectorAll('.emc-add-btn')].find(b => {
        const t = b.querySelector('.emc-add-btn-text');
        return t && t.textContent.trim() === 'Add Medical Device & Implant';
    });
    const pad = document.getElementById('emcDeviceAddPad');
    if (!btn || !pad) return;
    if (open) {
        btn.style.display = 'none';
        pad.classList.add('open');
    } else {
        btn.style.display = '';
        pad.classList.remove('open');
        pad.classList.remove('has-other');
        pad.querySelectorAll('.emc-edit-pad-input.open').forEach(i => i.classList.remove('open'));
        pad.querySelectorAll('.emc-edit-pad-value').forEach(v => v.textContent = '');
        const other = document.getElementById('emcDeviceOtherInput');
        if (other) other.value = '';
        const loc = document.getElementById('emcDeviceLocationInput');
        if (loc) loc.value = '';
    }
}
function emcSetDeviceType(el, value) {
    const input = el.closest('.emc-edit-pad-input');
    const valueEl = input && input.querySelector('.emc-edit-pad-value');
    const pad = document.getElementById('emcDeviceAddPad');
    if (valueEl) valueEl.textContent = value;
    if (input) input.classList.remove('open');
    if (pad) {
        pad.classList.toggle('has-other', value === 'Other');
        if (value === 'Other') {
            const other = document.getElementById('emcDeviceOtherInput');
            if (other) setTimeout(() => other.focus(), 0);
        }
    }
}
function emcDeviceSave() {
    const pad = document.getElementById('emcDeviceAddPad');
    if (!pad) return;
    let typeValue = pad.querySelector('.emc-edit-pad-field--1 .emc-edit-pad-value').textContent.trim();
    const locationValue = (document.getElementById('emcDeviceLocationInput')?.value || '').trim();
    if (!typeValue) return;
    if (pad.classList.contains('has-other')) {
        const customValue = (document.getElementById('emcDeviceOtherInput')?.value || '').trim();
        if (!customValue) return;
        typeValue = customValue;
    }
    const deviceFields = [
        { label: 'Device Type', value: typeValue, required: true }
    ];
    if (locationValue) deviceFields.push({ label: 'Location on Body', value: locationValue });
    const newRow = addMedicalEntry({
        groupTitle: 'Medical Devices & Implants',
        icon: (window.ANEF_CATEGORY_META && window.ANEF_CATEGORY_META['Medical Devices & Implants']?.icon) || 'img/activity.png',
        title: typeValue,
        type: 'Medical Devices & Implants',
        sub: 'Added today',
        badge: '',
        badgeText: '',
        entryData: {
            category: 'Medical Device',
            fields: deviceFields
        }
    });
    emcDeviceAdd(null, false);
    // Option B hand-off — auto-open the new entry in Edit mode
    if (typeof window.expandEntryInEditMode === 'function') window.expandEntryInEditMode(newRow);
}
window.emcDeviceAdd = emcDeviceAdd;
window.emcSetDeviceType = emcSetDeviceType;
window.emcDeviceSave = emcDeviceSave;

// Save a new allergy from the Add Allergy form → create a new .emc-allergy-bar
// inserted above the + Add Allergy pill. Width reflects severity level.
function emcAllergySave() {
    const pad = document.getElementById('emcAllergyAddPad');
    if (!pad) return;
    const allergenValue = pad.querySelector('.emc-edit-pad-field--1 .emc-edit-pad-value').textContent.trim();
    const severityValue = pad.querySelector('.emc-edit-pad-field--2 .emc-edit-pad-value').textContent.trim();
    const isOther = pad.classList.contains('has-other');
    const customValue = isOther ? document.getElementById('emcAllergenOtherInput').value.trim() : '';
    // Validation: need allergen + severity; if Other then also need custom text
    if (!allergenValue || !severityValue) return;
    if (isOther && !customValue) return;
    const displayName = isOther ? customValue : allergenValue;
    // Width by severity (380 total) — Mild 190, Moderate 253, Severe 316, Life-Threatening 380
    const widthMap = { 'Mild': 190, 'Moderate': 253, 'Severe': 316, 'Life-Threatening': 380 };
    const width = widthMap[severityValue] || 190;
    // Build DOM matching existing .emc-allergy-bar markup
    const bar = document.createElement('div');
    bar.className = 'emc-allergy-bar';
    bar.setAttribute('onclick', 'event.stopPropagation();');
    bar.innerHTML = `<div class="emc-allergy-fill" style="width:${width}px;"><span class="emc-allergy-dot"></span><span class="emc-allergy-name">${displayName}</span><span class="emc-allergy-level">${severityValue}</span></div>`;
    // Insert above the + Add Allergy pill
    const addBtn = document.querySelector('.emc-add-btn');
    if (addBtn) addBtn.parentNode.insertBefore(bar, addBtn);
    // Also insert a full Entry Row Card in the Allergies data-group below —
    // returns the new row so Option B can expand it into Edit mode after close.
    const newRow = emcInsertAllergyEntryRow(displayName, severityValue);
    // Close & reset the form
    emcAllergyAdd(null, false);
    // Option B hand-off — auto-open the new entry in Edit mode
    if (typeof window.expandEntryInEditMode === 'function') window.expandEntryInEditMode(newRow);
}

// ─────────────────────────────────────────────────────────────
// Shared helper — append a new medical entry row + expand body at the end of its
// data-group, using the SAME locked template as static entries (data-entry JSON
// → buildEntryExpandBodyHTML via buildAllMedicalEntries). Ensures parity between
// user-added entries and pre-existing ones (Blood Type / Peanuts / Asthma / …).
// opts:
//   groupTitle   → e.g. "Allergies", "Medical Conditions", "Medical Devices & Implants"
//   icon         → img path for .entry-icon-glyph (e.g. "img/shield-allergy.png")
//   title        → collapsed-row .entry-title
//   type         → collapsed-row .entry-type (e.g. "Allergy · Severe")
//   sub          → collapsed-row .entry-sub  (e.g. "Added today")
//   badge        → "digital" | "location" | "both" — status badge class
//   badgeText    → "Digital File" | "Location" | "Digital File & Location"
//   entryData    → the data-entry JSON object (category, fields, etc.)
// ─────────────────────────────────────────────────────────────
function addMedicalEntry(opts) {
    const titles = [...document.querySelectorAll('.data-group-title')];
    const groupTitle = titles.find(t => t.textContent.trim() === opts.groupTitle);
    if (!groupTitle) return null;
    // Locate the LAST element that still belongs to this group
    //   (last entry-row + optional entry-expand-body, or the group-title itself
    //    if the group is currently empty).
    let cursor = groupTitle.nextElementSibling;
    let insertAfter = groupTitle;
    while (cursor && !cursor.classList.contains('data-group-title')) {
        if (cursor.classList.contains('entry-row') || cursor.classList.contains('entry-expand-body')) {
            insertAfter = cursor;
        }
        cursor = cursor.nextElementSibling;
    }
    // Build new entry-row with data-entry JSON attribute
    const row = document.createElement('div');
    row.className = 'entry-row';
    row.setAttribute('onclick', 'toggleEntryExpand(this)');
    row.setAttribute('data-entry', JSON.stringify(opts.entryData || {}));
    row.innerHTML = `
        <div class="entry-icon"><img class="entry-icon-glyph" src="${opts.icon}" alt=""></div>
        <div class="entry-info">
            <div class="entry-title">${opts.title}</div>
            <div class="entry-type">${opts.type}</div>
            <div class="entry-sub">${opts.sub || 'Added today'}</div>
        </div>
        ${opts.badgeText ? `<div class="data-right"><span class="data-badge ${opts.badge || 'digital'}">${opts.badgeText}</span></div>` : ''}
        <div class="entry-menu" onclick="event.stopPropagation()">
            <div class="entry-menu-dots" onclick="toggleEntryMenu(this)"><span></span><span></span><span></span></div>
            <div class="entry-menu-dropdown">
                <div class="entry-menu-item" onclick="handleEntryAction('edit',this)">
                    <span class="entry-menu-item-text">Edit</span>
                    <div class="entry-menu-item-circle"><svg class="icon-edit" viewBox="0 0 21.5 19.5" fill="none"><path d="M-898,710.879h0Zm-8.889-4.206L-893,693.532a2.428,2.428,0,0,1,1.667-.654,2.465,2.465,0,0,1,.9.17,2.348,2.348,0,0,1,.764.484,2.206,2.206,0,0,1,.511.723,2.12,2.12,0,0,1,.18.854,2.117,2.117,0,0,1-.18.854,2.219,2.219,0,0,1-.511.724l-13.888,13.141L-908,710.879Z" transform="translate(908.75 -692.129)" fill="none" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/></svg></div>
                </div>
                <div class="entry-menu-item" onclick="handleEntryAction('archive',this)">
                    <span class="entry-menu-item-text">Archive</span>
                    <div class="entry-menu-item-circle"><svg class="icon-archive" viewBox="0 0 21.5 19.5" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20.712,7.841l-.641,11.6a2.374,2.374,0,0,1-2.3,2.311H6.734a2.374,2.374,0,0,1-2.3-2.311l-.641-11.6m6.41,4.091h4.1M3.4,7.841H21.1A1.193,1.193,0,0,0,22.25,6.614V4.977A1.193,1.193,0,0,0,21.1,3.75H3.4A1.193,1.193,0,0,0,2.25,4.977V6.614A1.193,1.193,0,0,0,3.4,7.841Z" transform="translate(-1.5 -3)" fill="none" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/></svg></div>
                </div>
                <div class="entry-menu-item" onclick="handleEntryAction('delete',this)">
                    <span class="entry-menu-item-text">Delete</span>
                    <div class="entry-menu-item-circle"><svg class="icon-trash" viewBox="0 0 19.722 21.5" fill="none"><path d="M15.739,9.173,15.362,18.4m-5.223,0L9.761,9.173M20.635,5.881c.373.053.744.11,1.115.17m-1.115-.169L19.47,20.119a2.4,2.4,0,0,1-2.448,2.13H8.478a2.4,2.4,0,0,1-2.448-2.13L4.865,5.881m15.77,0q-1.889-.268-3.794-.407M3.75,6.05c.371-.061.742-.117,1.115-.169m0,0q1.889-.268,3.794-.407m8.182,0V4.534a2.3,2.3,0,0,0-2.28-2.257q-1.81-.054-3.622,0a2.3,2.3,0,0,0-2.28,2.257v.939m8.182,0a56.462,56.462,0,0,0-8.182,0" transform="translate(-2.889 -1.499)" fill="none" stroke="#000" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/></svg></div>
                </div>
            </div>
        </div>`;
    const body = document.createElement('div');
    body.className = 'entry-expand-body';
    // Insert row + body after the last element in the group
    insertAfter.parentNode.insertBefore(row, insertAfter.nextSibling);
    row.parentNode.insertBefore(body, row.nextSibling);
    // Populate expand body via locked template
    if (typeof window.buildAllMedicalEntries === 'function') window.buildAllMedicalEntries();
    // Sync EMC snapshot (new allergy/condition/device → pill appears at the top)
    if (typeof window.syncEmcSnapshot === 'function') window.syncEmcSnapshot();
    // Re-compute Emergency Preparedness Score (a new non-archived entry may move the %)
    if (typeof window.updateEmergencyPreparednessScore === 'function') window.updateEmergencyPreparednessScore();
    return row;
}
// Allergy: create a new entry-row from EMC quick-add. Only the fields actually
// captured in the quick-add pad are populated — location / file / person / notes
// stay empty so View mode hides those sections per XD ("Only populated fields
// are displayed"). User adds the rest in Edit mode.
function emcInsertAllergyEntryRow(allergen, severity) {
    return addMedicalEntry({
        groupTitle: 'Allergies',
        icon: 'img/shield-allergy.png',
        title: allergen,
        type: 'Allergies',
        sub: 'Added today',
        badge: '',              // no status badge until location/file added
        badgeText: '',
        entryData: {
            category: 'Allergy',
            fields: [
                { label: 'Allergen', value: allergen, required: true },
                { label: 'Severity', value: severity, required: true }
            ]
            // NO location / file / person / notes — user fills them in Edit mode
        }
    });
}
window.addMedicalEntry = addMedicalEntry;
