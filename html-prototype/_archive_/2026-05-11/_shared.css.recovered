    border-radius: 50%;
    background: rgba(255, 255, 255, 0.33);
    border: 1px solid rgba(255, 255, 255, 0.33);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease-out, border-color 0.3s ease-out;
    padding: 0;
    flex-shrink: 0;
}
.doc-sb-download:hover {
    background: #FFFFFF;
    border-color: #FFFFFF;
}
.doc-sb-download svg {
    width: 20px;
    height: 20px;
    opacity: 1;
    pointer-events: none;
}

/* Print button — same pattern as download */
.doc-sb-print {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.33);
    border: 1px solid rgba(255, 255, 255, 0.33);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease-out, border-color 0.3s ease-out;
    padding: 0;
    flex-shrink: 0;
}
.doc-sb-print:hover {
    background: #FFFFFF;
    border-color: #FFFFFF;
}
.doc-sb-print svg {
    width: 20px;
    height: 20px;
    opacity: 1;
    pointer-events: none;
}

.doc-sb-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: visible;
    background: rgba(255, 255, 255, 0.33);
    box-shadow: 0px 10px 30px #00000029;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
    transition: all 0.3s ease-out;
    position: relative;
}
.doc-sb-avatar-wrap {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    background: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}
.doc-sb-photo {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    opacity: 1;
}
/* Hide initials only when photo img is actually displayed (JS toggles display:block when src is set) */
.doc-sb-avatar-wrap:has(.doc-sb-photo:not([style*="display:none"]):not([style*="display: none"])) .doc-sb-initials {
    display: none;
}
.doc-sb-initials {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    font: 600 24px/33px 'Source Serif 4', serif;
    color: rgba(0,0,0,0.4);
    letter-spacing: 0.05em;
}
.doc-sb-spacer {
    flex: 1;
}

/* Document viewer area — dark pad (XD: #3A3045, 1160×1020, radius 30, blur 10) */
.doc-viewer {
    flex: 1;
    position: relative;
    overflow-y: auto;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 40px 20px;
    margin: 0 0 0 40px;
    background: #3A3045 0% 0% no-repeat padding-box;
    border: 1px solid #3A3045;
    border-radius: 30px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    height: auto;
    align-self: stretch;
}
.doc-close {
    position: fixed;
    top: 116px;
    right: 24px;
    width: 32px;
    height: 32px;
    border: none;
    background: none;
    cursor: pointer;
    color: rgba(0,0,0,0.4);
    z-index: 110;
    transition: color 0.2s;
}
.doc-close:hover { color: rgba(0,0,0,0.7); }
.doc-close svg { width: 32px; height: 32px; }

/* Zoom controls — auto-hide on idle */
.doc-zoom-bar {
    position: fixed;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 6px 16px;
    z-index: 200;
    opacity: 0;
    transition: opacity 0.3s ease-out;
    pointer-events: none;
}
.doc-zoom-bar.visible {
    opacity: 1;
    pointer-events: auto;
}
.doc-zoom-btn {
    width: 28px;
    height: 28px;
    border: none;
    background: rgba(255,255,255,0.15);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    transition: background 0.2s;
    padding: 0;
    line-height: 1;
}
.doc-zoom-btn:hover { background: rgba(255,255,255,0.3); }
.doc-zoom-level {
    font: normal normal 600 13px/16px 'Inter', sans-serif;
    color: #fff;
    min-width: 40px;
    text-align: center;
    user-select: none;
}
.doc-zoom-fit {
    border: none;
    background: rgba(255,255,255,0.15);
    border-radius: 12px;
    cursor: pointer;
    color: #fff;
    font: normal normal 500 11px/14px 'Inter', sans-serif;
    padding: 4px 10px;
    transition: background 0.2s;
    white-space: nowrap;
}
.doc-zoom-fit:hover { background: rgba(255,255,255,0.3); }

/* Pages container — flex-wrap grid, zoom changes page size */
.doc-pages {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 24px;
    padding: 40px 20px;
    --page-width: 800px;
}

/* Drag-to-pan when zoomed in beyond fit */
.doc-viewer.pan-mode {
    cursor: grab;
    overflow: hidden;
}
.doc-viewer.pan-mode:active {
    cursor: grabbing;
}

/* Hover highlight on pages when zoomed out (thumbnail mode) */
.doc-viewer.thumbnail-mode .print-page {
    cursor: pointer;
    transition: transform 0.15s ease-out, box-shadow 0.15s ease-out;
}
.doc-viewer.thumbnail-mode .print-page:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 40px rgba(0,0,0,0.25);
}

/* Page indicator in zoom bar */
.doc-zoom-page {
    font: normal normal normal 13px/16px 'Inter', sans-serif;
    color: rgba(255,255,255,0.6);
    min-width: 36px;
    text-align: center;
    user-select: none;
    border-left: 1px solid rgba(255,255,255,0.2);
    padding-left: 8px;
    margin-left: 4px;
}
.print-page {
    position: relative;
    width: var(--page-width);
    aspect-ratio: 1200 / 1920;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 4px 30px rgba(0,0,0,0.12);
    background-color: #F8F8F8;
    flex-shrink: 0;
    transition: width 0.3s ease-out;
}

.print-content-page {
    background-color: #f8f8f8;
}

/* Cover page: background image fills the entire page */
.print-cover {
    background: transparent url('img/Background image print Portrait.png') 0% 0% / cover no-repeat padding-box;
}

/* Print page inner — 1200×1920 scaled to fit page container */
.print-inner {
    position: absolute;
    top: 0;
    left: 0;
    width: 1200px;
    height: 1920px;
    transform-origin: top left;
    /* scale set by JS based on page width */
}

/* Print page elements — XD px values directly */
.print-left-strip {
    position: absolute;
    top: 0;
    left: 0;
    width: 60px;
    height: 1920px;
    background: #FFFFFF;
    opacity: 0.5;
}
.print-glass-card {
    position: absolute;
    top: 420px;
    left: 160px;
    width: 240px;
    height: 240px;
    background: rgba(0, 0, 0, 0.08);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    display: flex;
    align-items: center;
    justify-content: center;
}
.print-avatar-wrap {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    background: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}
.print-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
}
.print-avatar-initials {
    display: none;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: #FFFFFF;
    align-items: center;
    justify-content: center;
    font: normal normal 600 64px/72px 'Source Serif 4', serif;
    color: rgba(0,0,0,0.4);
    letter-spacing: 0.05em;
    user-select: none;
}
.print-person-name {
    position: absolute;
    top: 690px;
    left: 190px;
    font: normal normal 600 48px/72px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
    text-align: left;
}
.print-green-bar {
    position: absolute;
    top: 1660px;
    left: 0;
    width: 1200px;
    height: 100px;
    background: #61C553;
    box-shadow: inset 0px 2px 0px #FFFFFF47, 0px 3px 6px #00000029;
    opacity: 0.85;
}
.print-bar-dot {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #FFFFFF;
}
.print-bar-disclaimer {
    position: absolute;
    width: 430px;
    font: normal normal 600 16px/24px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #FFFFFF;
    text-align: right;
}
.print-bar-divider {
    position: absolute;
    font: normal normal normal 14px/17px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #FFFFFF;
    opacity: 0.5;
}
.print-bar-value {
    position: absolute;
    font: normal normal 600 16px/20px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #FFFFFF;
    white-space: nowrap;
}
.print-bar-label {
    position: absolute;
    font: normal normal normal 14px/17px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #FFFFFF;
    white-space: nowrap;
}
.print-confidential {
    position: absolute;
    top: 1516px;
    left: 839px;
    width: 201px;
    font: normal normal normal 36px/44px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
    opacity: 0.5;
    text-align: right;
}
.print-record-title {
    position: absolute;
    top: 1164px;
    left: 250px;
    width: 790px;
    font: normal normal 500 128px/176px 'Source Serif 4', serif;
    letter-spacing: 0px;
    color: #000000;
    text-align: right;
}
.print-person-role {
    position: absolute;
    top: 762px;
    left: 190px;
    font: normal normal normal 36px/44px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
    opacity: 0.5;
    text-align: left;
}
.print-logo {
    position: absolute;
    top: 160px;
    left: 730px;
    width: 310px;
    height: auto;
    opacity: 1;
}

/* Content page — PlanAfter logo (no outline) */
/* Content page — full logo pill (same as dashboard header) */
.print-page-pill {
    position: absolute;
    top: 80px;
    left: 173px;
    width: 215px;
    height: 60px;
    pointer-events: none;
}
/* Print logo-pill — exact platform styling (no overrides). Outline PNG + shadow + translucent bg */
.print-page-pill .logo-pill {
    cursor: default;
}
/* Content page — name card pad */
.print-name-pad {
    position: absolute;
    top: 453px;
    left: 100px;
    width: 360px;
    height: 1215px;
    background: rgba(255,255,255,0.45);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0px 4px 12px rgba(0,0,0,0.06);
    border: 1px solid rgba(255,255,255,0.6);
    border-radius: 0 0 30px 30px;
}
/* Content page — green plan line */
.print-plan-bar {
    position: absolute;
    top: 548px;
    left: 100px;
    width: 360px;
    height: 24px;
    background: transparent linear-gradient(270deg, #61C553 0%, #31632A 100%) 0% 0% no-repeat padding-box;
    box-shadow: inset 0px 0px 6px #00000029;
}
/* Content page — avatar with life indicator */
.print-avatar-outer {
    position: absolute;
    top: 160px;
    left: 520px;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.33);
    box-shadow: 0px 10px 30px #00000029;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 1;
}
.print-avatar-inner {
    position: absolute;
    top: 170px;
    left: 530px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    background: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
}
.print-avatar-inner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
}
.print-avatar-inner .initials {
    font: normal normal 600 24px/33px 'Source Serif 4', serif;
    color: rgba(0,0,0,0.4);
    letter-spacing: 0.05em;
    display: flex; align-items: center; justify-content: center;
    width: 100%; height: 100%;
}
/* Life indicator dot: .lived=#61C553, .deceased=#FF0000, .unknown=#FF9500 */
.print-life-dot {
    position: absolute;
    top: 222px;
    left: 540px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #61C553;
}
.print-life-dot.deceased { background: #FF0000; }
.print-life-dot.unknown { background: #FF9500; }
/* Content page — document circles */
.print-doc-circle {
    position: absolute;
    left: 540px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #FFFFFF;
    border: 1px solid #61C553;
    display: flex;
    align-items: center;
    justify-content: center;
}
.print-doc-circle img {
    width: 20px;
    height: 20px;
}
/* Green = Digital File & Location */
.print-doc-circle.file-location { border-color: #61C553; }
/* Blue = Digital File only */
.print-doc-circle.file-only { border-color: #667EEA; }
/* Orange = Location only */
.print-doc-circle.location-only { border-color: #FF9500; }
/* Content page — document legend label + dot */
.print-doc-legend {
    position: absolute;
    font: normal normal normal 10px/12px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
    opacity: 0.5;
    text-align: right;
}
.print-doc-legend-dot {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
}
/* Content page — subsection heading */
.print-subsection-heading {
    position: absolute;
    font: normal normal 600 20px/24px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
}
/* Content page — data field label (right side) */
.print-field-label {
    position: absolute;
    font: normal normal normal 12px/15px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
    opacity: 0.5;
}
/* Content page — data field value (right side) */
.print-field-value {
    position: absolute;
    font: normal normal 600 16px/24px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
}
/* Content page — section heading inside pad */
.print-pad-heading {
    position: absolute;
    font: normal normal 600 36px/44px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
}
/* Content page — section description text */
.print-pad-desc {
    position: absolute;
    font: normal normal normal 16px/24px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
}
/* Content page — footer values */
.print-footer-value {
    position: absolute;
    font: normal normal 600 16px/20px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
}
/* Content page — footer labels */
.print-footer-label {
    position: absolute;
    font: normal normal normal 14px/17px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
}
/* Content page — disclaimer text at bottom */
.print-page-disclaimer {
    position: absolute;
    top: 1688px;
    left: 120px;
    width: 320px;
    height: 68px;
    font: normal normal 600 16px/24px 'Inter', sans-serif;
    letter-spacing: 0px;
    color: #000000;
