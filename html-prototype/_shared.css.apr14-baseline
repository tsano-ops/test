        .emergency-card { background: linear-gradient(135deg, rgba(229,57,53,0.08), rgba(229,57,53,0.03)); border: 1px solid rgba(229,57,53,0.15); border-radius: 20px; padding: 20px; margin-bottom: 16px; }
        .emergency-card .ec-title { font-size: 14px; font-weight: 700; color: #E53935; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
        .blood-type-badge { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 50%; background: rgba(229,57,53,0.1); color: #E53935; font-size: 18px; font-weight: 800; border: 2px solid rgba(229,57,53,0.3); }
        .allergy-tag { display: inline-block; padding: 4px 12px; border-radius: 12px; background: rgba(0,0,0,0.06); font-size: 12px; font-weight: 500; margin: 2px; }
        .condition-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; }
        .condition-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

        .entry-row {
            display: flex; align-items: center; gap: 10px;
            padding: 0 30px 0 170px; margin: 0 -30px; position: relative;
            height: 100px;
            background: rgba(255,255,255,0.5);
            border-top: 1px solid rgba(0,0,0,0.1);
            overflow: visible;
        }
        .entry-row:first-of-type { border-top: none; }
        .entry-row:hover { background: rgba(255,255,255,1.0); }
        .entry-row:active { background: rgba(255,255,255,0.2); }
        /* Icon — 60×60 circle, absolute left:100px — identical to doc-icon */
        .entry-icon {
            position: absolute; left: 100px; top: 50%; transform: translateY(-50%);
            width: 60px; height: 60px; border-radius: 50%;
            background: #FFFFFF; border: 1px solid rgba(0,0,0,0.12);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .entry-icon img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; }
        .entry-info { flex: 1; min-width: 0; }
        .entry-title { font: 600 16px/20px 'Inter', sans-serif; color: #000; }
        .entry-type  { font: 400 12px/15px 'Inter', sans-serif; color: #000; margin-top: 4px; }
        .entry-sub   { font: 400 12px/15px 'Inter', sans-serif; color: rgba(0,0,0,0.5); margin-top: 4px; }
        .entry-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
        .entry-role { font-size: 11px; opacity: 0.45; white-space: nowrap; }
        .data-badge { display: inline-flex; align-items: center; font-size: 10px; font-weight: 500; padding: 3px 8px; border-radius: 8px; white-space: nowrap; }
        
        .data-right { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }

        /* Family subsections */
        /* ========== FAMILY & RELATIONSHIPS CARD ========== */

        /* Status row (Married / Children / Minors) */
        .fr-status-row { display: flex; gap: 40px; margin: 16px 0 20px; }
        .fr-status-item { display: flex; flex-direction: column; }
        .fr-status-value { font: 600 20px/24px 'Inter', sans-serif; color: #000; }
        .fr-status-label { font: 400 12px/15px 'Inter', sans-serif; color: rgba(0,0,0,0.5); margin-top: 4px; }
        .fr-status-counts { display: flex; gap: 30px; margin-top: 4px; }
        .fr-status-count-item { display: flex; flex-direction: column; }
        .fr-status-count-num { font: 600 20px/24px 'Inter', sans-serif; color: #000; }
        .fr-status-count-lbl { font: 400 12px/15px 'Inter', sans-serif; color: rgba(0,0,0,0.5); margin-top: 4px; }

        /* Section header (• Immediate Family  —) */
        /* ---- FR SECTIONS — collapsed state: single shared glass card ---- */
        .fr-sections-outer {
            width: calc(100% + 60px);
            margin-left: -30px;
            margin-right: -30px;
            margin-top: 20px;
            margin-bottom: 8px;
        }

        /* fr-section-wrap no longer used as structural element */

        /* Section header — XD spec: full width × 60px */
        .fr-section-header {
            display: flex; align-items: center; justify-content: space-between;
            width: 100%; height: 60px; padding: 0 30px;
            background: transparent;
            cursor: pointer;
            transition: background 0.2s ease-out;
            box-sizing: border-box;
        }
        .fr-section-header          { background: rgba(255,255,255,0.5); }
        .fr-section-header:hover    { background: rgba(255,255,255,1.0); }
        .fr-section-header:active   { background: rgba(255,255,255,0.0); }
        .fr-section-header.open     { background: rgba(255,255,255,0.0); }

        .fr-section-header-left { display: flex; align-items: center; gap: 12px; }
        .fr-section-bullet { width: 8px; height: 8px; border-radius: 50%; background: #000; flex-shrink: 0; }
        .fr-section-title { font: 600 16px/20px 'Inter', sans-serif; color: #000; }

        /* +/− toggle */
        .fr-section-toggle {
            width: 32px; height: 32px;
            display: flex; align-items: center; justify-content: center;
            font: 300 24px/1 'Inter', sans-serif; color: rgba(0,0,0,0.4);
            transition: color 0.15s; user-select: none;
        }
        .fr-section-header:hover .fr-section-toggle,
        .fr-section-toggle:hover { color: rgba(0,0,0,0.8); }

        /* Section body — contains pill cards with side padding */
        .fr-section-body {
            width: 100%;
            padding: 8px 0;
            box-sizing: border-box;
            display: flex; flex-direction: column; align-items: center;
        }
        #fr-ext { margin-top: 4px; }
        .fr-section-body.collapsed { display: none; }

        /* Group label */
        .fr-group-label {
            font: 600 16px/24px 'Inter', sans-serif;
            color: rgba(0,0,0,0.5); text-align: center;
            padding: 8px 0 6px;
            display: block;
            width: 100%;
        }

        /* ── Inner Summary Card — XD: 400×100, bg#FFF op:0.33→1→0, r:50px ── */
        .fr-member-card {
            position: relative;
            width: 400px;
            min-height: 100px;
            background: rgba(255,255,255,0.33);
            border-radius: 50px;
            box-shadow: 0px 10px 30px rgba(0,0,0,0.16);
            cursor: pointer;
            transition: background 0.2s ease-out;
            box-sizing: border-box;
            margin: 0 0 8px 0;
            overflow: visible;
        }
        /* ── fr-card-wrap: wraps card + expand/edit panels as one pill ── */
        .fr-card-wrap { width: 400px; border-radius: 50px; box-shadow: 0px 10px 30px rgba(0,0,0,0.16); background: rgba(255,255,255,0.33); margin: 0 0 8px 0; overflow: visible; transition: background 0.2s ease-out; }
        .fr-card-wrap:hover { background: rgba(255,255,255,1.0); }
        .fr-card-wrap.expanded { background: transparent; border-radius: 30px; box-shadow: none; overflow: visible; }
        .fr-card-wrap.expanded.edit-open { width: 400px; margin-left: 0; overflow: visible; }
        .fr-card-wrap.expanded:hover { background: transparent; }
        /* Remove shadow/radius/margin from inner card when inside wrap */
        .fr-card-wrap .fr-member-card { width: 100%; border-radius: 0; box-shadow: none; margin: 0; background: transparent; }
        .fr-card-wrap .fr-member-card:hover { background: transparent; }
        .fr-card-wrap .fr-member-card:active { background: transparent; }
        .fr-card-wrap .fr-card-top { border-radius: 0; }
        /* When not expanded, card-top should have full pill radius */
        .fr-card-wrap:not(.expanded) .fr-card-top { border-radius: 50px; }
        /* expand/edit panels inside wrap */
        .fr-card-wrap .fr-expand-panel { background: transparent; width: 100%; }
        .fr-card-wrap .fr-edit-panel { background: rgba(255,255,255,0.5); }

        /* edit-open: edit panel appears below summary card (card stays visible) */
        .fr-card-wrap.expanded.edit-open .fr-card-top {
            background: transparent;
            border-radius: 50px;
        }



        /* fr-card-top: 100px, clips avatar/bg, preserves pill shape */
        .fr-card-top {
            position: relative;
            width: 100%; height: 100px;
            box-sizing: border-box; flex-shrink: 0;
            border-radius: 50px;
            overflow: visible;
        }

        /* Avatar wrap — 80×80, left:10 top:10 (right:310 bottom:10 спрямо pad) */
        .fr-avatar-wrap {
            position: absolute;
            left: 10px; top: 10px;
            width: 80px; height: 80px;
            border-radius: 50%;
        }
        .fr-avatar-wrap::before {
            content: '';
            position: absolute; inset: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.33);
            box-shadow: 0px 10px 30px #00000029;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        /* Photo — 60×60 вътре в wrap (inset 10px от wrap) */
        .fr-avatar {
            position: absolute;
            left: 10px; top: 10px;
            width: 60px; height: 60px;
            border-radius: 50%;
            object-fit: cover;
            z-index: 1;
        }
        /* Initials */
        .fr-avatar-initials {
            position: absolute;
            left: 10px; top: 10px;
            width: 60px; height: 60px;
            border-radius: 50%;
            background: #FFFFFF;
            display: flex; align-items: center; justify-content: center;
            font: 600 15px/1 'Inter', sans-serif;
            color: rgba(0,0,0,0.4);
            z-index: 1;
        }

        /* Life dot — 8×8, left:30 top:72 спрямо pad */
        .fr-life-dot {
            position: absolute;
            left: 30px; top: 72px;
            width: 8px; height: 8px;
            border-radius: 50%;
            background: #61C553;
            z-index: 3;
        }
        .fr-life-dot.deceased { background: #FF2C55; }

        /* fr-card-info: left:95 top:24 спрямо pad */
        .fr-card-info {
            position: absolute;
            left: 95px; top: 24px; right: 55px;
            display: flex; flex-direction: column;
        }
        /* Name: 600 14/17, top:24 */
        .fr-card-name { font: 600 14px/17px 'Inter', sans-serif; color: #000; }
        /* Role row: 400 12/15, top:45 = 24+17+4 */
        .fr-card-role {
            display: flex; align-items: center;
            font: 400 12px/15px 'Inter', sans-serif;
            color: rgba(0,0,0,0.5);
            margin-top: 4px;
            white-space: nowrap;
        }
        /* Role separator: кръг 4×4, 10px от всяка страна */
        .fr-role-sep {
            display: inline-block;
            width: 4px; height: 4px;
            border-radius: 50%;
            background: rgba(0,0,0,0.5);
            margin: 0 10px;
            flex-shrink: 0;
        }
        /* DOB: 400 10/12, top:64 = 45+15+4 */
        .fr-card-dob { font: 400 10px/12px 'Inter', sans-serif; color: rgba(0,0,0,0.5); margin-top: 4px; }

        /* Plan Role badge — Inter 600 10/12, top:12 left:239 спрямо pad */
        .fr-card-right {
            position: absolute;
            top: 12px; left: 239px;
            display: flex; flex-direction: column;
            align-items: flex-start;
        }
        .fr-role-badge      { font: 600 10px/12px 'Inter', sans-serif; color: rgba(0,0,0,0.5); white-space: nowrap; }
        .fr-in-memory-badge { font: 600 10px/12px 'Inter', sans-serif; color: #FF2C55; white-space: nowrap; }

        /* ••• button — 50×50, right:0 top:25px спрямо pad (standalone absolute) */
        .fr-menu-btn {
            position: absolute;
            right: 0; top: 25px;
            width: 50px; height: 50px;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            transition: background 0.15s;
            z-index: 10;
        }
        .fr-menu-btn:hover { }
        /* Dots — 3×3px кръгчета, gap:5px, общо 13px ширина */
        .fr-menu-dots {
            display: flex; align-items: center; justify-content: center;
            gap: 2px;
        }
        .fr-menu-dots span {
            display: block;
            width: 3px; height: 3px;
            border-radius: 50%;
            background: rgba(0,0,0,0.4);
            transition: background 0.15s;
        }
        .fr-menu-btn:hover .fr-menu-dots span { background: rgba(0,0,0,0.7); }
        .fr-menu-btn:active .fr-menu-dots span,
        .fr-menu-btn.open   .fr-menu-dots span { background: #000; }

        /* Dropdown — left:250 top:25 спрямо pad, 150×170, glass — идентично с entry-menu-dropdown */
        .fr-dropdown {
            display: none;
            position: absolute;
            left: auto; right: 0; top: 25px;
            width: 150px; height: 170px;
            background: rgba(255,255,255,0.33);
            box-shadow: 0px 10px 20px rgba(0,0,0,0.08);
            border: 1px solid #FFFFFF;
            border-radius: 25px;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 500;
            overflow: hidden;
            padding: 10px 0;
        }
        .fr-dropdown.open { display: block; }

        /* Trigger row — трите точки, сиви, 50px hit area, не е кликаем */
        .fr-dropdown-trigger {
            display: flex; align-items: center; justify-content: flex-end;
            height: 50px; padding: 0;
            pointer-events: none;
        }
        .fr-dropdown-trigger .fr-menu-dots {
            width: 50px; height: 50px;
            display: flex; align-items: center; justify-content: center;
        }
        .fr-dropdown-trigger .fr-menu-dots span {
            background: rgba(0,0,0,0.4);
        }

        /* Item — 50px hit area, justify-content:flex-end, no right padding so icon aligns under dots */
        .fr-dropdown-item {
            position: relative;
            display: flex; align-items: center;
            justify-content: flex-end;
            height: 50px; padding: 0 0 0 10px;
            cursor: pointer; gap: 8px;
        }

        /* Текст — 400 12/15, right-aligned, движи се 10px на ляво при hover */
        .fr-dropdown-item-text {
            font: 400 12px/15px 'Inter', sans-serif;
            color: #000;
            text-align: right;
            white-space: nowrap;
            transition: margin-right 0.2s ease-out;
        }
        .fr-dropdown-item.remove .fr-dropdown-item-text { color: #FF2C55; }

        /* Icon wrap — 50×50, икона винаги видима, кръг ::before opacity 0→1 hover */
        .fr-dropdown-item-circle {
            position: relative;
            width: 50px; height: 50px;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .fr-dropdown-item-circle::before {
            content: '';
            position: absolute; inset: 0;
            border-radius: 50%;
            background: #FFFFFF;
            opacity: 0;
            transition: opacity 0.2s ease-out;
        }
        .fr-dropdown-item-circle svg {
            position: relative; z-index: 1;
            flex-shrink: 0; width: 20px; height: 20px;
        }

        /* Hover — кръг се появява, текст се мести 10px на ляво */
        .fr-dropdown-item:hover .fr-dropdown-item-circle::before { opacity: 1; }
        .fr-dropdown-item:hover .fr-dropdown-item-text { margin-right: 10px; }

        /* ── Expanded panel — inside same pill, below card-top ── */
        /* ── Expand panel — XD exact values ── */
        .fr-expand-panel { display: none; padding: 0; overflow: visible; }

        /* Fields section: padding matches note text at left:780, card left:660 → 120px */
        .fr-expand-fields { padding: 20px 20px 20px 20px; }
        .fr-expand-type-row { display: flex; flex-direction: column; gap: 0; }
        .fr-expand-field { display: flex; flex-direction: column; gap: 0; margin-bottom: 18px; }
        .fr-expand-field:last-child { margin-bottom: 0; }
        /* Value: 600 16px/24px */
        .fr-expand-field-value { font: 600 16px/24px 'Inter', sans-serif; color: #000; }
        /* Label: 400 12px/15px op0.5 mt:4px */
        .fr-expand-field-label { font: 400 12px/15px 'Inter', sans-serif; color: rgba(0,0,0,0.5); margin-top: 4px; }

        /* "Relationship Timeline" divider: 400 14px/17px op0.5 centered, full width */
        .fr-timeline-label {
            font: 400 14px/17px 'Inter', sans-serif;
            color: rgba(0,0,0,0.5);
            text-align: center;
            padding: 14px 20px;
            margin-bottom: 0;
        }

        /* Timeline block: light wide panel 600px, 5px gap between */
        .fr-timeline-item {
            background: rgba(255,255,255,0.5);
            border-radius: 0;
            padding: 20px 100px;
            width: calc(100% + 200px);
            margin-left: -100px;
            box-sizing: border-box;
        }
        .fr-timeline-item + .fr-timeline-item {
            margin-top: 5px;
        }

        /* Date label: 600 16px/24px, left:780 → padding already handled by block */
        .fr-timeline-date { font: 600 16px/24px 'Inter', sans-serif; color: #000; margin-bottom: 14px; padding-left: 20px; }

        /* Note box: w:400px (760-660=100 from left + 100 from right), h auto, border 1px #00000029, r20px */
        .fr-timeline-note {
            width: 100%;
            background: transparent;
            border: 1px solid rgba(0,0,0,0.14);
            border-radius: 20px;
            padding: 16px 20px;
            font: 600 16px/24px 'Inter', sans-serif;
            color: #000;
            box-sizing: border-box;
        }

        /* "Details & Notes": 400 12px/15px op0.5, left:780 → same as note left edge */
        .fr-timeline-note-label {
            font: 400 12px/15px 'Inter', sans-serif;
            color: rgba(0,0,0,0.5);
            margin-top: 4px;
            padding-left: 20px;
        }

        /* Hide Details: line w:60px h:4px r:2px centered, text 600 14px/17px */
        .fr-hide-btn {
            display: flex; flex-direction: column; align-items: center;
            gap: 8px; padding: 24px 0 28px;
            cursor: pointer; transition: opacity 0.2s;
            border-top: 1px solid rgba(0,0,0,0.06);
        }
        .fr-hide-btn:hover { opacity: 1; }
        .fr-hide-btn span { font: 600 14px/17px 'Inter', sans-serif; color: #000; }
        .fr-hide-line {
            width: 60px; height: 4px; background: #000; border-radius: 2px;
            transition: width 0.2s ease-out;
        }
        .fr-hide-btn:hover .fr-hide-line { width: 100px; }



        /* + Add button */
        .fr-add-btn { display: flex; align-items: center; gap: 10px; padding: 6px 0 8px; cursor: pointer; opacity: 0.5; transition: opacity 0.2s; justify-content: center; }
        .fr-add-btn:hover { opacity: 1; }
        .fr-add-circle { width: 30px; height: 30px; border-radius: 50%; border: 1.5px solid #000; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .fr-add-label { font: 400 14px/17px 'Inter', sans-serif; color: #000; }

        /* ── FR Edit Panel — uses EI edit mode field specs exactly ── */
        /* ── FR Edit Panel — pixel-exact per XD ── */
        /* FR edit panel — 100% width of fr-card-wrap (400px), no overflow */
        /* FR edit panel — 600px wide (accordion-inner 540 + 30px overflow each side)
           Centered over fr-card-wrap (400px): margin-left: -100px
           XD: background #FFFFFF opacity 0.5, border-radius 30px */
        .fr-edit-panel {
            background: rgba(255,255,255,0.5);
            border-radius: 30px;
            padding: 20px 0 30px;
            position: relative;
            width: 600px;
            margin-left: -100px;
            box-sizing: border-box;
        }

        /* X close */
        .fr-edit-close { display: none; }

        /* Dropdown field — 20px padding L/R, line spans full field width */
        /* ── FR edit fields — identical to EI/CI design standard ── */

        /* Field container: padding-left/right 100px → line from 100px to 500px of 600px panel */
        .fr-ep-field {
            margin-bottom: 0; position: relative;
            padding: 10px 100px 10px 100px;
        }

        /* Input wrap: flex row, border-bottom only, 10px top+bottom padding */
        .fr-ep-select-row {
            display: flex; align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid rgba(0,0,0,0.14);
            transition: border-color 0.15s;
        }
        .fr-ep-select-row:hover { border-bottom-color: #000; }
        .fr-ep-select-row:focus-within { border-bottom-color: #000; }

        /* Select/input: 600 16/24px Inter, padding-left 20px → text at 120px from card edge */
        .fr-ep-select-row select {
            flex: 1; border: none; background: transparent; outline: none;
            font: normal normal 600 16px/24px 'Inter', sans-serif;
            color: #000; min-width: 0;
            padding: 0 0 0 20px;
            cursor: pointer; -webkit-appearance: none; appearance: none;
        }

        /* Chevron */
        .fr-ep-chevron {
            width: 8px; height: 4px; flex-shrink: 0; margin-left: 8px;
            opacity: 0.4; pointer-events: none;
        }

        /* Label: 400 12/15px Inter, op 0.5, margin-top 4px, padding-left 20px */
        .fr-ep-label {
            font: normal normal 400 12px/15px 'Inter', sans-serif;
            color: #000; opacity: 0.5;
            margin-top: 4px; margin-bottom: 0;
            padding-left: 20px;
            display: flex; align-items: center; gap: 4px;
        }
        .fr-ep-label .fr-req {
            color: #FF2C55; opacity: 1;
            font: normal normal 600 12px/15px 'Inter', sans-serif;
        }

        /* Timeline section — same 100px padding */
        .fr-timeline-section { padding: 0 100px; }
        .fr-timeline-section-title {
            font: normal normal 400 14px/17px 'Inter', sans-serif;
            color: #000; opacity: 0.5;
            text-align: center;
            padding: 8px 0 16px;
        }

        .fr-milestone-block {
            background: rgba(255,255,255,0.5);
            border-radius: 0;
            padding: 20px 100px;
            width: calc(100% + 200px);
            margin-left: -100px;
            box-sizing: border-box;
        }
        .fr-milestone-block + .fr-milestone-block { margin-top: 5px; }

        /* Milestone title row — 600 16/24 + X-circle */
        .fr-date-label {
            font: normal normal 600 16px/24px 'Inter', sans-serif;
            color: #000;
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 20px;
            padding-left: 20px;
        }
        .fr-date-clear {
            width: 24px; height: 24px; border-radius: 50%;
            border: 1px solid rgba(0,0,0,0.25);
            background: none; cursor: pointer; padding: 0; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            opacity: 0.5; transition: opacity 0.15s;
        }
        .fr-date-clear:hover { opacity: 1; }

        /* Date column labels — Year * / Month / Day */
        .fr-date-col-label {
