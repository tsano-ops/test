           ══════════════════════════════════════════════════════════ */
        .entry-row { cursor: pointer; position: relative; transition: background 0.15s; }

        /* Expand body */
        .entry-expand-body {
            display: none;
            padding: 4px 30px 20px 96px;
            border-bottom: 1px solid rgba(0,0,0,0.06);
