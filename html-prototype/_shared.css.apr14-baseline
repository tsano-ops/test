        /* ── pa-btn: unified arrow button component (mobile only) ──
           Structure: [label] [dash] [circle > arrow]
           Desktop uses existing ei-save / plan-strip classes unchanged.
           Mobile (≤767px) overrides both to use pa-btn layout.        */
        .pa-btn {
            -webkit-tap-highlight-color: transparent;
            cursor: pointer;
        }
        .pa-btn-label {
            font: normal normal 400 16px/24px 'Inter', sans-serif;
            white-space: nowrap;
            flex-shrink: 0;
            position: relative; z-index: 3;
            transition: color 0.2s ease-out;
        }
        .pa-btn-dash {
            width: 6px; height: 1px;
            flex-shrink: 0;
            position: relative; z-index: 3;
            transition: background 0.2s ease-out, width 0.2s ease-out;
        }
        .pa-btn-circle {
            width: 40px; height: 40px; border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            position: relative; z-index: 3;
            transition: border-color 0.2s ease-out;
        }
        /* Pill — grows from right to left, behind elements (z-index:2) */
        .pa-btn::before {
            content: '';
            position: absolute;
            right: 0; top: 0;
            width: 0; height: 100%;
            border-radius: 20px;
            background: transparent;
            z-index: 2;
            transition: width 0.25s ease-out, background 0.25s ease-out;
        }
        .pa-btn.active::before {
            width: calc(100% + 20px);
            background: #FFFFFF;
        }
        /* Save colors (dark on light) */
        .pa-btn--save .pa-btn-label { color: #000; }
        .pa-btn--save .pa-btn-dash  { background: rgba(0,0,0,0.35); }
        .pa-btn--save .pa-btn-circle { border: 0.75px solid #000; }
        .pa-btn--save .pa-btn-circle svg { stroke: #000; }
        .pa-btn--save.active .pa-btn-label { color: #000; }
        .pa-btn--save.active .pa-btn-dash  { background: #000; width: 20px; }
        .pa-btn--save.active .pa-btn-circle { border-color: transparent; }
        /* Upgrade colors (light on colored) */
        .pa-btn--upgrade .pa-btn-label { color: #FFF; }
        .pa-btn--upgrade .pa-btn-dash  { background: rgba(255,255,255,0.8); }
        .pa-btn--upgrade .pa-btn-circle { border: 0.75px solid rgba(255,255,255,0.9); }
        .pa-btn--upgrade .pa-btn-circle svg { stroke: #FFF; }
        .pa-btn--upgrade.active .pa-btn-label { color: var(--plan-color); }
        .pa-btn--upgrade.active .pa-btn-dash  { background: var(--plan-color); width: 20px; }
        .pa-btn--upgrade.active .pa-btn-circle { border-color: transparent; }
        .pa-btn--upgrade.active .pa-btn-circle svg { stroke: var(--plan-color); }

        /* LOCKED: Add Entry/Document button — 80×80 op0.33, inner 40→60 hover, plus 20×20 #000 op0.16→1 */
        .add-entry-btn { display: flex; flex-direction: column; align-items: center; gap: 20px; padding: 0; cursor: pointer; margin-bottom: 20px; }
        .add-entry-circle {
            width: 80px; height: 80px; border-radius: 50%;
            background: rgba(255,255,255,0.33);
            display: flex; align-items: center; justify-content: center;
            transition: all 0.2s ease-out;
            border: none; position: relative;
        }
        .add-entry-circle-inner {
            width: 40px; height: 40px; border-radius: 50%;
            background: #FFFFFF;
            display: flex; align-items: center; justify-content: center;
            transition: all 0.2s ease-out;
        }
        /* Plus icon — 20×20, 2px solid #000, op0.16 default, BLACK always */
        .plus-icon {
            width: 20px; height: 20px; position: relative;
            opacity: 0.16; transition: opacity 0.2s ease-out;
        }
        .plus-icon::before, .plus-icon::after {
            content: ''; position: absolute; background: #000; border-radius: 1px;
        }
        .plus-icon::before { top: 50%; left: 0; width: 20px; height: 2px; transform: translateY(-50%); }
        .plus-icon::after { left: 50%; top: 0; width: 2px; height: 20px; transform: translateX(-50%); }
        /* Dashed lines — 150px 1.5px dashed op0.16 */
        .add-entry-circle::before, .add-entry-circle::after {
            content: ''; position: absolute; top: 50%; width: 150px; height: 0;
            border-top: 1.5px dashed rgba(0,0,0,0.16);
        }
        .add-entry-circle::before { right: calc(100% + 10px); }
        .add-entry-circle::after { left: calc(100% + 10px); }
        /* Hover: inner→60×60, plus op→1, outer op→0.5 scale(1.05) */
        .add-entry-btn:hover .add-entry-circle { background: rgba(255,255,255,0.5); transform: scale(1.05); }
        .add-entry-btn:hover .add-entry-circle-inner { width: 60px; height: 60px; }
        .add-entry-btn:hover .plus-icon { opacity: 1; }
        /* Tap&Hold: same + outer op→0.65 scale(0.97) */
        .add-entry-btn:active .add-entry-circle { background: rgba(255,255,255,0.65); transform: scale(0.97); }
        .add-entry-btn:active .add-entry-circle-inner { width: 60px; height: 60px; }
        .add-entry-btn:active .plus-icon { opacity: 1; }
        .add-entry-label { font: normal normal 600 16px/24px 'Inter', sans-serif; letter-spacing: 0px; color: #000000; opacity: 1; }

