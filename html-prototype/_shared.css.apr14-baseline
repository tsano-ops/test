/* ═══════════════════════════════════════════════
   PRINT DOCUMENT STYLES — My Profile Print
   Portrait format: 1200×1920px per page
   ═══════════════════════════════════════════════ */

/* ---- Document Preview Mode: hide sidebar + right panel ---- */
.doc-preview-mode .sidebar-fixed { display: none !important; }
.doc-preview-mode .rightpanel-fixed { display: none !important; }
.doc-preview-mode .mobile-bottom-nav { display: none !important; }
.doc-preview-mode .greeting-zone { display: none !important; }

/* Document Preview container — fills viewport below header */
/* XD says top:30px but XD has no header; our header ≈70px → 70+30=100 */
.doc-preview {
    position: fixed;
    top: 100px;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    z-index: 100;
    /* Content = 1280px (80+40+1160). Remaining space split equally both sides.
       At 1920px → 320px each. Shrinks to 0 at ≤1280px. */
    padding-left: max(0px, calc((100vw - 1280px) / 2));
    padding-right: max(0px, calc((100vw - 1280px) / 2));
}

/* Left controls strip — collapsed pad (XD: 80×1020, radius 30, white blur) */
.doc-sidebar {
    width: 80px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1px 0 20px 0;
    gap: 8px;
    margin: 0;
    background: rgba(255, 255, 255, 0.33) 0% 0% no-repeat padding-box;
    border: 1px solid #FFFFFF;
    border-radius: 30px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 1;
    cursor: pointer;
    position: relative;
    transition: width 0.3s ease-out, border-radius 0.3s ease-out;
    overflow: hidden;
    align-self: stretch;
    height: auto;
}
.doc-sidebar.expanded {
    width: 300px;
}
.doc-sb-btn {
    width: 40px;
    height: 40px;
    border: none;
    background: none;
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #333;
    transition: all 0.2s ease-out;
}
.doc-sb-btn:hover {
    background: rgba(0,0,0,0.06);
}
.doc-sb-btn svg {
    width: 20px;
    height: 20px;
}
.doc-sb-back:hover {
    background: transparent !important;
}
.doc-sb-back svg {
    width: 12px;
    height: 10px;
    transition: transform 0.3s ease-out;
}
.doc-sidebar.expanded .doc-sb-back {
    align-self: flex-end;
    margin-right: 18px;
}
.doc-sidebar.expanded .doc-sb-back svg {
    transform: scaleX(-1);
}
.doc-sidebar.expanded .doc-sb-avatar {
    align-self: flex-start;
