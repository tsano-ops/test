        /* ── Card strip arrow button — v9 model, 60×60 circle ── */
        /* label(fixed-w, right-align) | 10gap | dash(10→30hover, 1.5px) | 10gap | circle(60×60) */
        /* Upgrade: label=61px, dash@71, circle@91, wrap=151px, pill left:0→-30px w:181px */
        /* Manage:  label=57px, dash@67, circle@87, wrap=147px, pill left:0→-30px w:177px */
