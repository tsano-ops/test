        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html, body {
            width: 100%;
            min-height: 100vh;
            overflow-x: hidden;
            font-family: 'Inter', sans-serif;
            font-size: 16px;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            background: url('data:image/png;base64,') center center / cover no-repeat fixed;
            color: #111;
        }
        .font-source-serif { font-family: 'Source Serif 4', serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .bg-layer {
            position: absolute; inset: 0; z-index: 0;
            opacity: 0; pointer-events: none; overflow: hidden;
        }
        .bg-layer img {
            width: 100%; height: 100%; object-fit: cover;
            transform: scale(1.02); filter: blur(2px);
        }
        .bg-layer svg {
            width: 100%; height: 100%; position: absolute; top: 0; left: 0;
        }
        .bg-layer .gradient-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to bottom, rgba(255,255,255,0.15), rgba(255,255,255,0.05));
        }
        .header {
            position: fixed; top: 0; left: 0; width: 100%; height: 100px; z-index: 9999;
            pointer-events: none;
            overflow: visible;
        }
        .header-col-left {
            position: fixed; top: 0; height: 100px;
            left: calc(50% - 640px); width: 300px;
            display: flex; align-items: center; justify-content: center;
            gap: 10px;
            pointer-events: auto;
            z-index: 9100;
        }
        .header-col-right {
            position: fixed; top: 0; height: 100px;
            left: calc(50% + 340px); width: 300px;
            display: flex; align-items: center; justify-content: center;
            pointer-events: auto;
            z-index: 9100;
        }
        .header-inner { display: contents; }
        .header-spacer { display: none; }

        /* Logo Pill: 215x60, centered in 300px col */
        .logo-pill {
            width: 215px; height: 60px; position: relative;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; pointer-events: auto;
            background: rgba(255,255,255,0.33);
            border-radius: 30px;
            backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
            box-shadow: 0px 10px 20px rgba(0,0,0,0.16);
        }
        .logo-pill .logo-outline {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        }
        .logo-pill .logo-text-svg {
            position: relative; z-index: 1; width: 155px; height: 20px;
        }
        .logo-pill:hover, .logo-pill:active, .logo-pill.scrolled {
            background: rgba(255,255,255,0.33);
            box-shadow: 0px 10px 20px rgba(0,0,0,0.16);
        }

        /* Utility Buttons - outline circle per Adobe spec (circle - Outline.png) */
        .utility-btn {
            width: 60px; height: 60px; border-radius: 50%;
            display: flex; align-items: center;
            justify-content: center; cursor: pointer; pointer-events: auto;
            background: rgba(255,255,255,0.33);
            backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
            box-shadow: 0px 10px 20px rgba(0,0,0,0.08);
            transition: all 0.3s ease-out;
            position: relative;
        }
        .utility-btn .btn-outline {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        }
        .utility-btn .btn-icon {
            position: relative; z-index: 1;
        }
        .utility-btn:hover { background: rgba(255,255,255,1.0); }
        .utility-btn:active { transform: scale(0.95); }
        .utility-btn.active { background: #FFFFFF; box-shadow: 0px 10px 20px #00000029; }
        .utility-btn svg.btn-icon { width: 20px; height: 20px; }
        .notif-dot {
            position: absolute; top: 17px; right: 20px; width: 6px; height: 6px;
            background: #FF0000; border-radius: 50%; z-index: 2;
        }
        .utility-group { display: flex; align-items: center; gap: 10px; pointer-events: auto; }

        .avatar-btn {
            width: 80px; height: 80px; border-radius: 50%;
            cursor: pointer;
            pointer-events: auto; display: flex; align-items: center;
            justify-content: center; position: relative;
        }
        .avatar-btn::before {
            content: ''; position: absolute; top: 0; left: 0;
            width: 100%; height: 100%; border-radius: 50%;
            background: #FFFFFF;
            box-shadow: 0px 10px 20px #00000029;
            backdrop-filter: blur(2px); -webkit-backdrop-filter: blur(2px);
            opacity: 0.33;
            transition: opacity 0.3s ease-out;
        }
        .avatar-btn:hover::before, .avatar-btn.active::before {
            opacity: 1;
        }
        .avatar-btn .avatar-photo-inner {
            width: 60px; height: 60px; border-radius: 50%; overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            background: #E8E8E8; position: relative; z-index: 1;
            box-shadow: inset -1px -1px 2px #FFFFFF;
        }
        .avatar-btn .initials {
            font-family: 'Source Serif 4', serif; font-weight: 600; font-size: 24px; line-height: 33px;
            color: rgba(0,0,0,0.4); letter-spacing: 0.05em;
            user-select: none;
        }
        .profile-dropdown {
            position: fixed; top: 100px; right: calc(50% - 640px);
            width: 300px; height: 560px; background: #FFFFFF;
            border-radius: 20px; box-shadow: 0px 10px 20px #00000014;
            border: 1px solid #FFFFFF;
            opacity: 0; pointer-events: none; transform: translateY(-10px);
            transition: all 0.25s cubic-bezier(0.2, 1, 0.3, 1);
            z-index: 9999; overflow: hidden;
        }
        .profile-dropdown.open { opacity: 1; pointer-events: auto; transform: translateY(0); }
        .profile-dropdown-header {
            padding: 28px 24px 20px; text-align: right;
            background: #FFFFFF;
        }
        .profile-dropdown-name {
            font-family: 'Source Serif 4', serif; font-size: 20px;
            font-weight: 500; color: #000; line-height: 28px; letter-spacing: 0;
        }
        .profile-dropdown-email {
            font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 400;
            color: #000; opacity: 0.5; line-height: 17px; margin-top: 4px; letter-spacing: 0;
        }
        .profile-dropdown-section { padding: 0; }
        /* All sections on white pad background */
        .profile-dropdown-section.section-primary {
            background: #FFFFFF;
        }
        /* Bottom sections on white */
        .profile-dropdown-section.section-secondary {
            background: #FFFFFF;
        }
        .profile-dropdown-section.section-logout {
            background: #FFFFFF;
        }
        .profile-dropdown-item {
            display: flex; align-items: center; justify-content: flex-end;
            gap: 12px; padding: 0 24px; cursor: pointer;
            position: relative; height: 50px;
            background: #FFFFFF;
        }
        .section-primary .profile-dropdown-item {
            background: #F8F8F8;
        }
        /* Text + icon shift left on hover (opposite of sidebar right-shift) */
        .profile-dropdown-item span,
        .profile-dropdown-item svg,
        .profile-dropdown-item .dd-icon {
            transition: transform 0.2s ease-out;
        }
        .profile-dropdown-item:hover span,
        .profile-dropdown-item:hover svg,
        .profile-dropdown-item:hover .dd-icon {
            transform: translateX(-5px);
        }
        /* Hover bar on right side */
        .profile-dropdown-item::after {
            content: ''; position: absolute; right: 0; top: 50%; transform: translateY(-50%);
            width: 3px; height: 32px; background: #000; border-radius: 3px 0 0 3px;
            opacity: 0; transition: opacity 0.15s;
        }
        .profile-dropdown-item:hover::after { opacity: 1; }
        .profile-dropdown-item span {
            font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600;
            color: #000; line-height: 24px; letter-spacing: 0;
        }
        /* Bottom section items (Help, Terms) use normal weight */
        .section-secondary .profile-dropdown-item span {
            font-weight: 400;
        }
        /* Log Out uses 600 weight */
        .section-logout .profile-dropdown-item span {
            font-weight: 600;
        }
        .profile-dropdown-item svg:not(.dd-icon) { width: 24px; height: 24px; color: #000; flex-shrink: 0; display: none; }
        .profile-dropdown-item .dd-icon { flex-shrink: 0; object-fit: contain; }
        .profile-dropdown-backdrop {
            display: none; position: fixed; inset: 0; z-index: 9998;
        }
        .profile-dropdown-backdrop.open { display: block; }
        .notif-panel {
            position: fixed; top: 100px; left: calc(50% + 340px);
            width: 300px; height: 560px;
            background: #FFFFFF;
            box-shadow: 0px 10px 20px #00000014;
            border: 1px solid #FFFFFF;
            border-radius: 20px;
            opacity: 0; pointer-events: none; transform: translateY(-10px);
            transition: all 0.25s cubic-bezier(0.2, 1, 0.3, 1);
            z-index: 9999; overflow: hidden;
            display: flex; flex-direction: column;
        }
        .notif-panel.open { opacity: 1; pointer-events: auto; transform: translateY(0); }
        .notif-panel-header {
            position: absolute; top: 0; left: 0; right: 0;
            height: 101px; background: #FFFFFF; z-index: 2;
            border-radius: 20px 20px 0 0;
        }
        .notif-panel-title {
            position: absolute; top: 30px; left: 30px;
            font-family: 'Inter', sans-serif; font-size: 20px; font-weight: 600;
            line-height: 24px; color: #000; letter-spacing: 0;
        }
        .notif-badge {
            position: absolute; top: 12px; right: 12px;
            width: 30px; height: 30px;
            background: #FF0000; border-radius: 15px;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Inter', sans-serif; font-weight: 600;
            font-size: 14px; line-height: 17px;
            color: #FFFFFF; letter-spacing: 0;
            z-index: 3;
        }
        .notif-badge.hidden { display: none; }
        .notif-actions {
            position: absolute; top: 62px; left: 30px; right: 30px;
            display: flex; gap: 20px;
            z-index: 2;
        }
        .notif-action-btn {
            font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 400;
            line-height: 17px; color: #000; opacity: 0.5; letter-spacing: 0;
            background: none; border: none; cursor: pointer; padding: 0;
            transition: opacity 0.2s;
        }
        .notif-action-btn:hover { opacity: 1; }
        .notif-list {
            overflow-y: auto; flex: 1; padding-top: 101px; padding-bottom: 86px;
            display: flex; flex-direction: column; gap: 2px;
        }
        .notif-item {
            padding: 15px 30px; cursor: pointer; position: relative;
            box-sizing: border-box;
            display: flex; flex-direction: column; justify-content: flex-start;
            transition: background 0s;
        }
        .notif-item { background: #F8F8F8; }
        .notif-item.read { background: #FFFFFF; }
        /* Priority color bar — stretches with content, 15px inset top/bottom */
        .notif-bar {
            position: absolute; left: 0; top: 15px; bottom: 15px;
            width: 3px; border-radius: 0 3px 3px 0;
        }
        .notif-item.priority-info .notif-bar { background: #61C553; }
        .notif-item.priority-medium .notif-bar { background: #FF9500; }
        .notif-item.priority-high .notif-bar { background: #FF2C55; }
        .notif-item.priority-low .notif-bar { background: #657EEA; }
        .notif-item-meta {
            display: flex; align-items: center; gap: 0; margin-bottom: 8px;
        }
        .notif-priority {
            font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 400;
            line-height: 12px; letter-spacing: 0; text-transform: uppercase;
            color: #000000;
        }
        .notif-time {
            font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 400;
            line-height: 12px; color: #000; opacity: 0.5; letter-spacing: 0;
        }
        .notif-dot-sep {
            width: 3px; height: 3px; border-radius: 50%;
            background: #000; opacity: 0.3; margin: 0 6px;
        }
        .notif-item-title {
            font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600;
            line-height: 17px; color: #000; letter-spacing: 0; margin-bottom: 4px;
        }
        .notif-item-desc {
            font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 400;
            line-height: 15px; color: #000; opacity: 0.5; letter-spacing: 0;
            width: 240px;
        }
        .notif-footer {
            position: absolute; bottom: 0; left: 0; right: 0;
            height: 86px; cursor: pointer; user-select: none;
            background: #FFFFFF; z-index: 2;
            border-radius: 0 0 20px 20px;
        }
        .notif-footer-line {
            position: absolute; z-index: 20; top: 30px; height: 4px;
            background: #000; border-radius: 2px;
            left: 120px; width: 60px; transition: all 0.2s ease-out;
        }
        .notif-footer:hover .notif-footer-line { left: 100px; width: 100px; }
        .notif-footer-label {
            position: absolute; z-index: 20; top: 49px;
            left: 0; right: 0; text-align: center;
            font-family: 'Inter', sans-serif; font-size: 14px; line-height: 17px;
            font-weight: 600; letter-spacing: 0; color: #000;
            white-space: nowrap;
        }
        /* Empty state */
        .notif-empty {
            padding: 0 30px; position: absolute; top: 111px; left: 0;
        }
        .notif-empty-title {
            font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600;
            line-height: 17px; color: #000; letter-spacing: 0;
            width: 240px; margin-bottom: 4px;
        }
        .notif-empty-desc {
            font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 400;
            line-height: 15px; color: #000; opacity: 0.5; letter-spacing: 0;
            width: 240px;
        }
        .notif-backdrop {
            display: none; position: fixed; inset: 0; z-index: 9998;
        }
        .notif-backdrop.open { display: block; }
        .sidebar-fixed {
            position: fixed; z-index: 500; width: 300px;
            top: 100px; left: calc(50% - 640px);
            height: calc(100vh - 100px);
            display: flex; flex-direction: column;
            overflow: hidden; /* Sidebar itself doesn't scroll */
            scrollbar-width: none;
            transition: all 0.5s;
        }
        .sidebar-fixed::-webkit-scrollbar { display: none; } /* Chrome/Safari: hide scrollbar */
        #sidebar-default { flex-shrink: 0; transition: opacity 0.4s ease-out; }
        #sidebar-category { flex-shrink: 0; transition: opacity 0.4s ease-out; }
        .sidebar-fade-in { animation: sidebarFadeIn 0.4s ease-out; }
        @keyframes sidebarFadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
        .rightpanel-fixed {
            position: fixed; z-index: 500; width: 300px;
            top: 100px; left: calc(50% + 340px);
            transition: all 0.5s;
        }
        .scroll-container {
            width: 100%; height: 100vh; overflow-y: auto; position: relative; z-index: 10;
        }
        .scroll-inner {
            margin: 0 auto; display: flex; width: 100%; min-height: 100%;
            max-width: 1280px; padding-top: 100px; padding-bottom: 48px;
            gap: 40px; justify-content: center;
        }
        .col-placeholder { width: 300px; flex-shrink: 0; pointer-events: none; }
        .middle-col { display: flex; flex-direction: column; flex-shrink: 0; width: 600px; }

        /* Greeting Zone: starts at y=34px (inside header), scrolls with content
           scroll-inner padding-top:100px → content at y=100 → margin-top:-66px pulls to y=34
           height:33px ends at y=67 → margin-bottom:33px → next card at y=100 */
        .greeting-zone {
            width: 252px; height: 33px; margin: -66px auto 33px auto;
            display: flex; justify-content: center; align-items: center;
            position: relative; z-index: 10000;
            pointer-events: none;
        }
        .greeting-text {
            font-family: 'Source Serif 4', serif; font-size: 24px;
            font-weight: 500; color: #000; line-height: 33px; letter-spacing: 0;
            white-space: nowrap; text-align: center;
        }
        .sidebar-surface { background: rgba(255,255,255,0.33); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); }

        /* Photo Zone */
        .sidebar-photo {
            width: 300px; height: 275px; border-radius: 30px 30px 0 0;
            border: 1px solid #FFFFFF; overflow: hidden; cursor: pointer;
            position: relative;
        }
        /* Soft vignette/blur glow inside the photo container */
        .sidebar-photo::before {
            content: ''; position: absolute; inset: 0; z-index: 1;
            background: radial-gradient(ellipse 220px 200px at center 60%,
                rgba(255,255,255,0.25) 0%,
                rgba(255,255,255,0.08) 50%,
                transparent 100%);
            pointer-events: none;
        }
        .sidebar-photo .placeholder-text {
            position: absolute; top: 30px; left: 0; right: 0;
            text-align: center; white-space: nowrap;
            font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 400;
            line-height: 17px; letter-spacing: 0;
            color: #000000; opacity: 0.5;
            z-index: 3;
        }
        /* Background gray circle - 180px, ALWAYS visible, opacity 0.33 */
        .sidebar-photo .add-circle-bg {
            position: absolute; left: 50%; top: 150px;
            transform: translate(-50%, -50%);
            width: 180px; height: 180px; border-radius: 50%;
            background: #FFFFFF;
            opacity: 0.33;
            z-index: 2;
            pointer-events: none;
        }
        /* White circle - 100px default, grows to 140px on hover */
        .sidebar-photo .add-circle {
            position: absolute; left: 50%; top: 150px;
            transform: translate(-50%, -50%);
            width: 100px; height: 100px; border-radius: 50%;
            background: #FFFFFF;
            display: flex; align-items: center; justify-content: center;
            z-index: 3;
            transition: width 0.2s ease-out, height 0.2s ease-out;
        }
        .sidebar-photo:hover .add-circle {
            width: 140px; height: 140px;
        }
        .sidebar-photo:hover .add-circle {
            box-shadow: 0 10px 30px rgba(0,0,0,0.16);
        }
        /* Plus icon container - 50px */
        .sidebar-photo .add-inner {
            width: 50px; height: 50px;
            display: flex; align-items: center; justify-content: center;
            opacity: 0.16;
            transition: opacity 0.2s ease-out;
        }
        .sidebar-photo:hover .add-inner { opacity: 1; }
        .sidebar-photo .add-inner svg {
            width: 50px; height: 50px;
            stroke: #000000; stroke-width: 2;
            stroke-linecap: round;
        }
        /* Uploaded photo overlay - maintains hover interaction */
        .sidebar-photo .photo-overlay {
            position: absolute; inset: 0; z-index: 6;
            display: flex; align-items: center; justify-content: center;
            opacity: 0; transition: opacity 0.3s ease;
            cursor: pointer;
        }
        .sidebar-photo:hover .photo-overlay.has-photo {
            opacity: 1;
        }
        /* Photo doc-menu — горен десен ъгъл, идентично с doc-menu от entry rows */
        .sidebar-photo .photo-doc-menu {
            position: absolute; z-index: 100; top: 30px; right: 30px;
            opacity: 0; transition: opacity 0.2s;
            overflow: visible !important;
        }
        .sidebar-photo:hover .photo-doc-menu.visible { opacity: 1; }
        .sidebar-photo .photo-doc-menu .doc-menu-dots span { background: #FFF; }


        /* Photo option ред — идентично с dd-row */
        .sidebar-photo .photo-option {
            display: flex; align-items: center;
            justify-content: flex-end;
            height: 50px; cursor: pointer;
            padding: 0; border: none; background: none; width: 100%;
        }
        .sidebar-photo .photo-option-label {
            font: normal normal normal 12px/15px 'Inter', sans-serif;
            color: #000; white-space: nowrap;
            margin-right: 5px;
            transition: margin-right 0.2s ease-out;
        }
        .sidebar-photo .photo-option:hover .photo-option-label,
        .sidebar-photo .photo-option:active .photo-option-label { margin-right: 15px; }
        .sidebar-photo .photo-option-icon {
            position: relative;
            width: 50px; height: 50px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
        }
        .sidebar-photo .photo-option-icon::before {
            content: ''; position: absolute; top: 0; left: 0;
            width: 50px; height: 50px; background: #FFFFFF;
            border-radius: 50%; z-index: 0;
            opacity: 0; transition: opacity 0.2s ease-out;
            box-shadow: 0 4px 15px rgba(0,0,0,0.10);
        }
        .sidebar-photo .photo-option:hover .photo-option-icon::before,
        .sidebar-photo .photo-option:active .photo-option-icon::before { opacity: 1; }
        .sidebar-photo .photo-option-icon svg {
            display: block; width: 20px; height: 20px;
            position: relative; z-index: 1;
        }
        /* Reposition mode bar */
        .sidebar-photo .reposition-bar {
            position: absolute; z-index: 32; bottom: 0; left: 0; right: 0;
            height: 54px; background: rgba(0,0,0,0.55);
            backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
            display: none; align-items: center; justify-content: center; gap: 10px;
        }
        .sidebar-photo .reposition-bar.active { display: flex; }
        .sidebar-photo .reposition-bar button {
            font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600;
            border: none; border-radius: 25px;
            padding: 0 20px; height: 34px;
            cursor: pointer; transition: opacity 0.15s ease-out;
        }
        .sidebar-photo .reposition-bar button:hover { opacity: 0.85; }
        .sidebar-photo .reposition-bar .repo-save {
            background: #FFFFFF; color: #000;
        }
        .sidebar-photo .reposition-bar .repo-cancel {
            background: rgba(255,255,255,0.15);
            color: #FFF;
            border: 1px solid rgba(255,255,255,0.4);
        }
        /* Drag-drop highlight */
        .sidebar-photo.drag-over::after {
            content: 'Drop image here'; position: absolute; inset: 0; z-index: 40;
            background: rgba(0,0,0,0.5); color: #FFF; display: flex;
            align-items: center; justify-content: center;
            font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600;
            border-radius: 30px 30px 0 0;
        }
        /* Reposition mode — zoom slider */
        .sidebar-photo .reposition-bar .zoom-slider {
            width: 80px; height: 3px; -webkit-appearance: none; appearance: none;
            background: rgba(255,255,255,0.3); border-radius: 2px; outline: none;
        }
        .sidebar-photo .reposition-bar .zoom-slider::-webkit-slider-thumb {
            -webkit-appearance: none; width: 14px; height: 14px;
            border-radius: 50%; background: #FFF; cursor: pointer;
        }

        /* Identity Strip */
        .identity-strip {
            height: 65px; background: #FFFFFF; position: relative; z-index: 10;
            display: flex; flex-direction: column; align-items: center;
            justify-content: space-between; padding: 10px 0;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        .identity-name {
            font-family: 'Source Serif 4', serif; font-size: 20px;
            font-weight: 500; color: #000; line-height: 28px; white-space: nowrap;
        }
        .identity-role {
            font-size: 14px; color: #000; opacity: 0.5;
            line-height: 17px; font-weight: 400; white-space: nowrap;
        }
        /* Mobile sidebar avatar (hidden on desktop) */
        .identity-avatar-mobile { display: none; }
        .identity-text-wrap { display: contents; } /* transparent wrapper on desktop */
        /* Sidebar quick actions (hidden on desktop, shown on mobile) */
