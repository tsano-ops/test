        /* ── Three-dot dropdown menu ── */
        /* ── ENTRY MENU — XD LOCKED ── */
        .entry-menu {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 10;
            width: 44px; height: 44px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 50%;
        }
        .entry-menu:hover { background: rgba(0,0,0,0.04); }


        /* Three dots trigger — 13×3px, opacity 0.3→1 */
        .entry-menu-dots {
            display: flex; align-items: center; justify-content: center;
            gap: 3px; width: 30px; height: 30px;
            cursor: pointer; opacity: 0.30;
            transition: opacity 0.2s ease-out;
            flex-shrink: 0;
        }
        .entry-menu-dots:hover { opacity: 1; }
        .entry-menu-dots span {
            display: block; width: 3px; height: 3px;
            border-radius: 50%; background: #000;
        }

        /* Dropdown container — XD: 150×220px, r:25, glass */
        .entry-menu-dropdown {
            display: none;
            position: absolute;
            right: -10px;
            top: 36px;
            width: 150px;
            height: 220px;
            background: rgba(255,255,255,0.33);
            box-shadow: 0px 10px 20px rgba(0,0,0,0.08);
            border: 1px solid #FFFFFF;
            border-radius: 25px;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 500;
            overflow: hidden;
        }
        .entry-menu-dropdown.open { display: block; }

        /* Each item — 50px height, centered vertically */
        .entry-menu-item {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            height: 50px;
            padding: 0 15px 0 10px;
            cursor: pointer;
            gap: 8px;
            /* vertical distribution: top offset per XD */
        }
        .entry-menu-item:first-child  { margin-top: 20px; }  /* Edit   — ~60px from top */
        .entry-menu-item:nth-child(2) { margin-top: 0; }     /* Archive — ~50px gap     */
        .entry-menu-item:last-child   { margin-top: 0; }     /* Delete  — ~50px gap     */

        /* Item text — 12px/15px Inter, right-aligned */
        .entry-menu-item-text {
            font: normal 400 12px/15px 'Inter', sans-serif;
            color: #000;
            text-align: right;
            transition: margin-right 0.2s ease-out;
            white-space: nowrap;
        }

        /* Circle — 50×50px, white, opacity 0→1 on hover */
        .entry-menu-item-circle {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #FFFFFF;
            border: 1px solid #FFFFFF;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            flex-shrink: 0;
            transition: opacity 0.2s ease-out;
        }

        /* SVG icons — 20×18px (edit/archive), 18×20px (trash), stroke 1.5 */
        .entry-menu-item-circle svg { flex-shrink: 0; }
        .entry-menu-item .icon-edit    { width: 20px; height: 18px; }
        .entry-menu-item .icon-archive { width: 20px; height: 18px; }
        .entry-menu-item .icon-trash   { width: 18px; height: 20px; }

        /* Hover state — circle appears + text shifts 10px left */
        .entry-menu-item:hover .entry-menu-item-circle { opacity: 1; }
        .entry-menu-item:hover .entry-menu-item-text   { margin-right: 10px; }
        

    



