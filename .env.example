# ═══════════════════════════════════════════════
# PlanAfter - Environment Variables
# Copy this file to .env and fill in values
# ═══════════════════════════════════════════════

# ─── Database ───
DATABASE_URL="postgresql://planafter:planafter_dev_2026@localhost:5432/planafter?schema=public"

# ─── Redis ───
REDIS_URL="redis://localhost:6379"

# ─── API Server ───
API_PORT=4000
API_PREFIX=/api/v1
NODE_ENV=development

# ─── JWT Auth ───
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (SendGrid) ───
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@planafter.com
SENDGRID_FROM_NAME=PlanAfter

# ─── Stripe Payments ───
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── PayPal ───
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ─── AI Assistant (Anthropic Claude) ───
ANTHROPIC_API_KEY=

# ─── AWS S3 (Document Storage) ───
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=planafter-vault

# ─── Encryption ───
ENCRYPTION_KEY=your-32-char-encryption-key-here

# ─── Frontend ───
VITE_API_URL=http://localhost:4000/api/v1
VITE_APP_NAME=PlanAfter
